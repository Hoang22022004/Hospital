@page "{id:int}"
@model MedicalRecordDetailsModel
@using Hospital.Models
@using System.Reflection
@using System.ComponentModel.DataAnnotations
@{
    ViewData["Title"] = "Chi tiết hồ sơ bệnh án";

    string GetDisplayName(Enum enumValue)
    {
        return enumValue.GetType()
                        .GetMember(enumValue.ToString())
                        .First()
                        .GetCustomAttribute<DisplayAttribute>()
                        ?.GetName() ?? enumValue.ToString();
    }
}

@section Styles {
    <link rel="stylesheet" href="~/css/account_manage.css" asp-append-version="true" />
    <style>
        /* --- HIỂN THỊ TRÊN MÀN HÌNH (WEB VIEW) --- */
        .bg-navy {
            background-color: #002d5b !important;
            color: white !important;
        }

        .text-navy {
            color: #002d5b !important;
        }

        .border-dashed {
            border-style: dashed !important;
        }

        .italic {
            font-style: italic;
        }

        /* --- CSS CHO IN ẤN (A4) --- */
        @@media print {
            @@page {
                size: A4;
                margin: 8mm;
            }

            .no-print, .manage-sidebar, .navbar, .hp-footer, .btn {
                display: none !important;
            }

            body, .container-fluid, .card, .card-body {
                margin: 0 !important;
                padding: 0 !important;
                box-shadow: none !important;
                border: none !important;
            }

            .row {
                display: flex !important;
                flex-wrap: nowrap !important;
            }

            .col-lg-8 {
                width: 68% !important;
                flex: 0 0 68% !important;
            }

            .col-lg-4 {
                width: 32% !important;
                flex: 0 0 32% !important;
                border-left: 1px solid #eee !important;
                padding-left: 10px !important;
            }

            p, span, td, th, small, div {
                font-size: 10px !important;
                line-height: 1.2 !important;
            }

            .badge {
                border: 1px solid #ccc !important;
                color: #000 !important;
                background: none !important;
            }

            .bg-navy {
                background-color: #002d5b !important;
                -webkit-print-color-adjust: exact;
            }
        }
    </style>
}

<div class="container-fluid py-2 animate__animated animate__fadeIn">
    @* Nút điều hướng (Ẩn khi in) *@
    <div class="d-flex justify-content-between mb-3 no-print">
        <a asp-page="./MedicalHistory" class="btn btn-sm btn-outline-secondary rounded-pill px-3">
            <i class="bi bi-arrow-left"></i> Quay lại hành trình
        </a>
        <button onclick="window.print()" class="btn btn-sm btn-navy rounded-pill px-4 shadow-sm">
            <i class="bi bi-printer me-2"></i> In Phiếu Khám (A4)
        </button>
    </div>

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="card-body p-4">
            <div class="row g-0">
                @* CỘT TRÁI: NỘI DUNG CHÍNH *@
                <div class="col-lg-8 pe-lg-4">
                    <div class="d-flex justify-content-between border-bottom pb-2 mb-3">
                        <div>
                            <h5 class="fw-bold text-primary mb-0">HELLO PARIS CLINIC</h5>
                            <small class="text-muted">Mã HS: #@Model.HoSo.Id | Ngày: @Model.HoSo.NgayKham.ToString("dd/MM/yyyy")</small>
                        </div>
                        <div class="text-end">
                            <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-1 border border-success border-opacity-25">
                                @GetDisplayName(Model.HoSo.TrangThai)
                            </span>
                        </div>
                    </div>

                    @* Chẩn đoán của bác sĩ *@
                    <div class="bg-light p-3 rounded-4 mb-3 border-start border-4 border-primary">
                        <div class="row">
                            <div class="col-md-7 mb-1">
                                <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.6rem;">Chẩn đoán chuyên khoa</small>
                                <span class="fw-bold text-navy">@Model.HoSo.ChanDoan</span>
                            </div>
                            <div class="col-md-5 mb-1 text-md-end">
                                <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.6rem;">Thông tin da</small>
                                <span class="badge bg-info bg-opacity-10 text-info">Da: @Model.HoSo.TinhTrangDa</span>
                            </div>
                        </div>
                    </div>

                    @* Bảng Dịch vụ *@
                    <h6 class="fw-bold small mb-2 text-primary text-uppercase"><i class="bi bi-stars me-1"></i> Dịch vụ thực hiện</h6>
                    <table class="table table-sm align-middle mb-4 border-bottom">
                        <tbody>
                            @foreach (var dv in Model.HoSo.ChiTietDichVus)
                            {
                                <tr>
                                    <td class="py-1"><strong>@dv.DichVu.TenDichVu</strong></td>
                                    <td class="text-end py-1 fw-bold text-navy">@dv.DichVu.Gia.ToString("N0") đ</td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    @* Bảng Đơn thuốc (ĐÃ CẬP NHẬT GIAO DIỆN MỚI) *@
                    <h6 class="fw-bold small mb-2 text-success text-uppercase"><i class="bi bi-capsule me-1"></i> Đơn thuốc chỉ định</h6>
                    <table class="table table-sm align-middle mb-3 border-bottom">
                        <thead class="bg-light">
                            <tr style="font-size: 0.65rem;">
                                <th>TÊN THUỐC & LIỀU DÙNG</th>
                                <th class="text-center">SỐ LƯỢNG</th>
                                <th class="text-end">THÀNH TIỀN</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in Model.HoSo.ChiTietDonThuocs)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-bold text-navy">@t.Thuoc.TenThuoc</div>
                                        @* Lộ trình uống thuốc *@
                                        <div class="mt-1" style="font-size: 0.75rem;">
                                            <span class="badge bg-light text-dark border-0 p-0 me-2">☀️ @(t.LieuSang ?? "-")</span>
                                            <span class="badge bg-light text-dark border-0 p-0 me-2">🌤️ @(t.LieuTrua ?? "-")</span>
                                            <span class="badge bg-light text-dark border-0 p-0 me-2">⛅ @(t.LieuChieu ?? "-")</span>
                                            <span class="badge bg-light text-dark border-0 p-0 me-2">🌙 @(t.LieuToi ?? "-")</span>
                                        </div>
                                        @* Số ngày và ghi chú *@
                                        <div class="small text-muted mt-1 italic">
                                            <i class="bi bi-calendar-check"></i> Dùng trong: <strong>@t.SoNgayDung ngày</strong>
                                            @if (!string.IsNullOrEmpty(t.GhiChu))
                                            {
                                                <span class="ms-2">| Lưu ý: <span class="text-danger">@t.GhiChu</span></span>
                                            }
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <span class="fw-bold">@t.SoLuong.ToString("G29")</span> @(t.Thuoc?.DonViTinh ?? "Viên")
                                    </td>
                                    <td class="text-end fw-bold">
                                        @(((decimal)t.SoLuong * t.Thuoc.GiaBan).ToString("N0")) đ
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    @* --- KHỐI TỔNG TIỀN --- *@
                    <div class="p-3 rounded-4 bg-navy text-white shadow-sm mt-4">
                        <div class="row align-items-center">
                            <div class="col-7">
                                <small class="opacity-75 text-uppercase fw-bold" style="font-size: 0.6rem;">Bác sĩ dặn dò:</small>
                                <p class="small mb-0 italic" style="font-size: 0.8rem;">"@Model.HoSo.LoiDan"</p>
                            </div>
                            <div class="col-5 text-end border-start border-white border-opacity-25">
                                <small class="opacity-75 d-block text-uppercase fw-bold" style="font-size: 0.6rem;">Tổng chi phí phác đồ:</small>
                                <h4 class="fw-bold mb-0">@((Model.TongDichVu + Model.TongThuoc).ToString("N0")) VNĐ</h4>
                            </div>
                        </div>
                    </div>
                </div>

                @* CỘT PHẢI: BÁC SĨ & HÌNH ẢNH *@
                <div class="col-lg-4 ps-lg-4 border-start">
                    <div class="text-center mb-4 pb-3 border-bottom">
                        <div class="bg-light p-3 rounded-4 mb-2">
                            <i class="bi bi-person-badge text-primary fs-3"></i>
                            <h6 class="fw-bold text-navy mt-1 mb-0">BS. @Model.HoSo.BacSi?.HoTen</h6>
                            <small class="text-muted" style="font-size: 0.65rem;">Chuyên khoa Da liễu</small>
                        </div>
                    </div>

                    <h6 class="fw-bold small mb-2 text-uppercase text-secondary">Tư liệu hình ảnh</h6>
                    <div class="row g-2 mb-4">
                        @foreach (var img in Model.HoSo.HinhAnhBenhAns.Take(4))
                        {
                            <div class="col-6">
                                <div class="ratio ratio-1x1 shadow-sm rounded-3 overflow-hidden border">
                                    <img src="@img.DuongDan" class="object-fit-cover" alt="Ảnh">
                                </div>
                            </div>
                        }
                    </div>

                    @if (Model.HoSo.NgayTaiKham.HasValue)
                    {
                        <div class="p-2 border border-danger border-dashed rounded-3 text-center bg-danger bg-opacity-10 mb-4">
                            <small class="text-danger fw-bold text-uppercase" style="font-size: 0.55rem;">Tái khám dự kiến</small>
                            <h6 class="fw-bold text-danger mb-0">@Model.HoSo.NgayTaiKham.Value.ToString("dd/MM/yyyy")</h6>
                        </div>
                    }

                    <div class="mt-auto pt-5 border-top text-center row">
                        <div class="col-6"><small class="text-muted d-block mb-5">Bệnh nhân</small><strong>@Model.HoSo.BenhNhan?.HoTen</strong></div>
                        <div class="col-6"><small class="text-muted d-block mb-5">Bác sĩ khám</small><strong class="text-primary">@Model.HoSo.BacSi?.HoTen</strong></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>