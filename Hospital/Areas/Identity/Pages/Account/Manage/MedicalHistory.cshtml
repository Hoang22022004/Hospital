@page
@model MedicalHistoryModel
@using Hospital.Models
@using System.Reflection
@using System.ComponentModel.DataAnnotations
@{
    ViewData["Title"] = "Hành trình sắc đẹp";
    ViewData["ActivePage"] = "MedicalHistory";

    // Hàm hỗ trợ lấy nội dung trong [Display(Name = "...")]
    string GetDisplayName(Enum enumValue)
    {
        return enumValue.GetType()
                        .GetMember(enumValue.ToString())
                        .First()
                        .GetCustomAttribute<DisplayAttribute>()
                        ?.GetName() ?? enumValue.ToString();
    }
}

<div class="animate__animated animate__fadeIn">
    @* TIÊU ĐỀ TRANG *@
    <div class="d-flex align-items-center mb-5 pb-3 border-bottom">
        <div class="bg-primary bg-opacity-10 p-3 rounded-circle me-3 shadow-sm">
            <i class="bi bi-journal-medical text-primary fs-3"></i>
        </div>
        <div>
            <h4 class="fw-bold text-navy mb-0 Montserrat uppercase">HÀNH TRÌNH ĐIỀU TRỊ</h4>
            <small class="text-muted">Theo dõi phác đồ và sự thay đổi làn da của bạn qua từng giai đoạn</small>
        </div>
    </div>

    @if (Model.MedicalHistories.Any())
    {
        <div class="timeline-container px-3">
            @foreach (var item in Model.MedicalHistories)
            {
                <div class="timeline-item mb-5 position-relative ps-5 border-start border-2 border-primary border-opacity-25">
                    @* Nút tròn Timeline *@
                    <div class="timeline-dot shadow-sm"></div>

                    <div class="card border-0 shadow-sm rounded-4 overflow-hidden hp-card-hover">
                        <div class="card-body p-4">
                            <div class="row align-items-center g-3">
                                @* THỜI GIAN *@
                                <div class="col-md-3 border-end text-center text-md-start">
                                    <h5 class="fw-bold text-primary mb-1">@item.NgayKham.ToString("dd/MM/yyyy")</h5>
                                    <p class="small text-muted mb-3">Lúc @item.NgayKham.ToString("HH:mm")</p>

                                    <div class="mt-2">
                                        @if (item.TrangThai == TrangThaiHoSo.HoanThanh)
                                        {
                                            <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2 border border-success border-opacity-25">
                                                <i class="bi bi-check-circle-fill me-1"></i> @GetDisplayName(item.TrangThai)
                                            </span>
                                        }
                                        else if (item.TrangThai == TrangThaiHoSo.ChoThanhToan)
                                        {
                                            <span class="badge bg-info bg-opacity-10 text-info rounded-pill px-3 py-2 border border-info border-opacity-25">
                                                <i class="bi bi-credit-card me-1"></i> @GetDisplayName(item.TrangThai)
                                            </span>
                                        }
                                        else if (item.TrangThai == TrangThaiHoSo.DaHuy)
                                        {
                                            <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-3 py-2 border border-danger border-opacity-25">
                                                <i class="bi bi-x-circle me-1"></i> @GetDisplayName(item.TrangThai)
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning bg-opacity-10 text-warning rounded-pill px-3 py-2 border border-warning border-opacity-25">
                                                <i class="bi bi-clock-history me-1"></i> @GetDisplayName(item.TrangThai)
                                            </span>
                                        }
                                    </div>
                                </div>

                                @* CHẨN ĐOÁN *@
                                <div class="col-md-6 px-lg-4">
                                    <small class="text-muted text-uppercase fw-bold ls-1 mb-2 d-block" style="font-size: 0.65rem;">Chẩn đoán chuyên khoa</small>
                                    <h6 class="fw-bold text-navy mb-3 lh-base">@(string.IsNullOrEmpty(item.ChanDoan) ? "Đang cập nhật..." : item.ChanDoan)</h6>

                                    <div class="d-flex align-items-center small text-muted bg-light p-2 rounded-3 d-inline-flex">
                                        <i class="bi bi-person-badge me-2 text-primary"></i>
                                        Bác sĩ: <span class="text-dark fw-bold ms-1">@item.BacSi?.HoTen</span>
                                    </div>
                                </div>

                                @* HÀNH ĐỘNG (ĐÃ CẬP NHẬT TRẠNG THÁI CHỜ THANH TOÁN) *@
                                <div class="col-md-3 text-center text-md-end">
                                    @if (item.TrangThai == TrangThaiHoSo.ChoKham)
                                    {
                                        <form asp-page-handler="HuyHoSo" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn hủy lịch khám này không?')">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-outline-danger rounded-pill px-4 fw-bold small shadow-sm">
                                                <i class="bi bi-x-circle me-1"></i> HỦY LỊCH
                                            </button>
                                        </form>
                                    }
                                    else if (item.TrangThai == TrangThaiHoSo.ChoThanhToan)
                                    {
                                        @* HIỂN THỊ CẢ THANH TOÁN VÀ XEM PHÁC ĐỒ *@
                                        <div class="d-flex flex-column gap-2">
                                            <a asp-area="Admin" asp-controller="HoSoBenhAn" asp-action="ThanhToanVnpay" asp-route-id="@item.Id"
                                               class="btn btn-success rounded-pill px-4 fw-bold small shadow-sm animate__animated animate__pulse animate__infinite">
                                                <i class="bi bi-credit-card me-1"></i> THANH TOÁN
                                            </a>
                                            <a asp-page="./MedicalRecordDetails" asp-route-id="@item.Id"
                                               class="btn btn-navy-outline rounded-pill px-4 fw-bold small">
                                                XEM PHÁC ĐỒ <i class="bi bi-arrow-right ms-1"></i>
                                            </a>
                                        </div>
                                    }
                                    else if (item.TrangThai == TrangThaiHoSo.DangKham || item.TrangThai == TrangThaiHoSo.HoanThanh)
                                    {
                                        <a asp-page="./MedicalRecordDetails" asp-route-id="@item.Id"
                                           class="btn btn-navy-outline rounded-pill px-4 fw-bold small">
                                            XEM PHÁC ĐỒ <i class="bi bi-arrow-right ms-1"></i>
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <div class="mb-4">
                <i class="bi bi-clipboard2-x display-1 text-light opacity-50"></i>
            </div>
            <h5 class="fw-bold text-navy">Bạn chưa có hồ sơ bệnh án nào</h5>
            <p class="text-muted small mb-4">Mọi lịch sử thăm khám và kết quả sẽ hiện ở đây sau lần khám đầu tiên.</p>
            <a asp-controller="DatLich" asp-action="Index" asp-area="" class="btn btn-hello-paris rounded-pill px-5 shadow-sm">ĐẶT LỊCH KHÁM NGAY</a>
        </div>
    }
</div>

<style>
    .timeline-item:hover {
        transform: scale(1.01);
        transition: 0.3s;
    }

    .ls-1 {
        letter-spacing: 1px;
    }

    .text-navy {
        color: #002d5b;
    }

    .timeline-dot {
        position: absolute;
        left: -8px;
        top: 12px;
        width: 16px;
        height: 16px;
        background: #45c3d2;
        border: 3px solid #fff;
        border-radius: 50%;
        box-shadow: 0 0 0 5px rgba(69, 195, 210, 0.1);
    }

    .btn-navy-outline {
        border: 1.5px solid #002d5b;
        color: #002d5b;
        transition: 0.3s;
    }

        .btn-navy-outline:hover {
            background: #002d5b;
            color: #fff;
        }

    /* Hiệu ứng cho nút Thanh toán */
    .btn-success {
        background-color: #28a745;
        border-color: #28a745;
    }

        .btn-success:hover {
            background-color: #218838;
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(40, 167, 69, 0.2);
        }

    /* Đảm bảo các nút trong d-flex flex-column có chiều rộng đồng nhất nếu cần */
    .gap-2 {
        gap: 0.5rem !important;
    }
</style>