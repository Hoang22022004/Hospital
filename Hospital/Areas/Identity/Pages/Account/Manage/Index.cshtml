@page
@model IndexModel
@{
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<div class="animate__animated animate__fadeIn">
    <h4 class="fw-bold text-navy mb-4"><i class="bi bi-stars text-primary me-2"></i>HỒ SƠ CỦA TÔI</h4>
    <partial name="_StatusMessage" for="StatusMessage" />

    <form id="profile-form" method="post" class="row">
        <div class="col-md-7">
            <div class="form-floating mb-3">
                <input asp-for="Username" class="form-control border-0 bg-light" disabled />
                <label>Tên đăng nhập (Email)</label>
            </div>
            <div class="form-floating mb-4">
                <input asp-for="Input.PhoneNumber" class="form-control border-0 bg-light" placeholder="Số điện thoại" />
                <label>Số điện thoại liên hệ</label>
                <span asp-validation-for="Input.PhoneNumber" class="text-danger small"></span>
            </div>
            <button id="update-profile-button" type="submit" class="btn btn-hello-paris px-5 py-2 fw-bold shadow-sm">
                LƯU THAY ĐỔI
            </button>
        </div>
    </form>
</div>