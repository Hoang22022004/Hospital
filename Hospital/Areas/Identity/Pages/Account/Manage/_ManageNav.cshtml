@inject SignInManager<ApplicationUser> SignInManager
<ul class="nav nav-pills flex-column hp-manage-nav">
    <li class="nav-item mb-2">
        <a class="nav-link @ManageNavPages.IndexNavClass(ViewContext)" id="profile" asp-page="./Index">
            <i class="bi bi-person-vcard me-2"></i> Thông tin chung
        </a>
    </li>
    <li class="nav-item mb-2">
        <a class="nav-link @ManageNavPages.ChangePasswordNavClass(ViewContext)" id="change-password" asp-page="./ChangePassword">
            <i class="bi bi-shield-lock me-2"></i> Đổi mật khẩu
        </a>
    </li>
    <li class="nav-item mb-2">
        <a class="nav-link @ManageNavPages.TwoFactorAuthenticationNavClass(ViewContext)" id="two-factor" asp-page="./TwoFactorAuthentication">
            <i class="bi bi-patch-check me-2"></i> Bảo mật 2 lớp
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @ManageNavPages.PersonalDataNavClass(ViewContext)" id="personal-data" asp-page="./PersonalData">
            <i class="bi bi-trash3 me-2"></i> Xóa tài khoản
        </a>
    </li>
    @* Thêm mục Lịch sử khám vào cuối danh sách *@
    <li class="nav-item mb-2">
        <a class="nav-link @(ViewContext.RouteData.Values["Page"]?.ToString() == "/Account/Manage/MedicalHistory" ? "active" : "")"
           id="medical-history" asp-page="./MedicalHistory">
            <i class="bi bi-clock-history me-2"></i> Lịch sử khám bệnh
        </a>
    </li>
</ul>