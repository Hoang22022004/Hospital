@page
@model AccessDeniedModel
@{
    ViewData["Title"] = "Truy cập bị từ chối";
    Layout = null; // Trang độc lập để đảm bảo hiển thị đúng
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MEDICINE MIS</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
        :root {
            --bg-color: #f8fafc;
            --primary-indigo: #6366f1; /* Indigo đồng bộ Layout */
            --slate-900: #0f172a;
            --slate-600: #475569;
            --danger-soft: #fff1f2;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-color);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            overflow: hidden;
        }

        .denied-card {
            text-align: center;
            max-width: 500px;
            width: 90%;
            padding: 50px 40px;
            background: white;
            border-radius: 32px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.08);
            position: relative;
        }

        /* Hiệu ứng vòng tròn cảnh báo */
        .icon-wrapper {
            width: 120px;
            height: 120px;
            background-color: var(--danger-soft);
            color: #e11d48;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 30px;
            font-size: 50px;
            position: relative;
        }

            .icon-wrapper::after {
                content: '';
                position: absolute;
                width: 140px;
                height: 140px;
                border: 2px dashed #fda4af;
                border-radius: 50%;
                animation: rotate 10s linear infinite;
            }

        @@keyframes rotate {
            from {
                transform: rotate(0deg);
            }

            to {
                transform: rotate(360deg);
            }
        }

        h1 {
            font-weight: 800;
            color: var(--slate-900);
            font-size: 1.8rem;
            margin-bottom: 15px;
            letter-spacing: -0.5px;
        }

        p {
            color: var(--slate-600);
            font-size: 1rem;
            margin-bottom: 35px;
            line-height: 1.6;
        }

        .btn-back {
            background-color: var(--slate-900);
            color: white;
            padding: 14px 30px;
            border-radius: 14px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            border: none;
            width: 100%;
            justify-content: center;
        }

            .btn-back:hover {
                background-color: var(--primary-indigo);
                transform: translateY(-2px);
                box-shadow: 0 10px 15px -3px rgba(99, 102, 241, 0.3);
                color: white;
            }

        .support-text {
            margin-top: 25px;
            font-size: 0.85rem;
            color: #94a3b8;
        }

        .brand-footer {
            position: absolute;
            bottom: -60px;
            left: 0;
            right: 0;
            font-weight: 700;
            color: #cbd5e1;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-size: 0.75rem;
        }
    </style>
</head>
<body>

    <div class="denied-card">
        <div class="icon-wrapper">
            <i class="bi bi-shield-lock-fill"></i>
        </div>

        <h1>Dừng lại một chút!</h1>
        <p>Tài khoản của bạn không có quyền truy cập vào tài nguyên này. Vui lòng liên hệ Quản trị viên nếu bạn cho rằng đây là một sự nhầm lẫn.</p>

        <a href="javascript:history.back()" class="btn-back">
            <i class="bi bi-arrow-left"></i> Quay lại trang trước
        </a>

        <div class="support-text">
            Bạn đang đăng nhập với vai trò:
            <span class="badge bg-light text-dark border">
                @(User.IsInRole("Admin") ? "Quản trị viên" : User.IsInRole("Doctor") ? "Bác sĩ" : "Lễ tân")
            </span>
        </div>

        <div class="brand-footer">Medicine Clinic Management System</div>
    </div>

</body>
</html>