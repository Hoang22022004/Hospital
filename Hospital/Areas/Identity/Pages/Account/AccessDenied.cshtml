@page
@model AccessDeniedModel
@{
    ViewData["Title"] = "Truy cập bị từ chối";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PHÒNG KHÁM DA LIỄU HELLO PARIS</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
        :root {
            --bg-color: #f8fafc;
            --primary-indigo: #6366f1;
            --slate-900: #0f172a;
            --slate-600: #475569;
            --danger-soft: #fff1f2;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-color);
            min-height: 100vh; /* Sửa thành min-height để tránh lỗi hiển thị trên mobile */
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            padding: 20px;
        }

        .denied-card {
            text-align: center;
            max-width: 500px;
            width: 100%;
            padding: 50px 40px;
            background: white;
            border-radius: 32px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.08);
            position: relative;
        }

        .icon-wrapper {
            width: 120px;
            height: 120px;
            background-color: var(--danger-soft);
            color: #e11d48;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 30px;
            font-size: 50px;
            position: relative;
        }

            .icon-wrapper::after {
                content: '';
                position: absolute;
                width: 140px;
                height: 140px;
                border: 2px dashed #fda4af;
                border-radius: 50%;
                animation: rotate 10s linear infinite;
            }

        @@keyframes rotate {
            from {
                transform: rotate(0deg);
            }

            to {
                transform: rotate(360deg);
            }
        }

        h1 {
            font-weight: 800;
            color: var(--slate-900);
            font-size: 1.8rem;
            margin-bottom: 15px;
        }

        p {
            color: var(--slate-600);
            font-size: 1rem;
            margin-bottom: 35px;
            line-height: 1.6;
        }

        .btn-group-custom {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .btn-back {
            background-color: var(--slate-900);
            color: white;
            padding: 14px 30px;
            border-radius: 14px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            border: none;
        }

            .btn-back:hover {
                background-color: var(--primary-indigo);
                transform: translateY(-2px);
                box-shadow: 0 10px 15px -3px rgba(99, 102, 241, 0.3);
                color: white;
            }

        .btn-home {
            background-color: transparent;
            color: var(--slate-600);
            padding: 12px;
            border-radius: 14px;
            text-decoration: none;
            font-weight: 500;
            border: 1px solid #e2e8f0;
            transition: all 0.2s;
        }

            .btn-home:hover {
                background-color: #f1f5f9;
                color: var(--slate-900);
            }

        .support-text {
            margin-top: 25px;
            font-size: 0.9rem;
            color: #64748b;
            padding: 10px;
            background: #f8fafc;
            border-radius: 12px;
        }

        .role-badge {
            font-weight: 700;
            color: var(--primary-indigo);
            text-transform: uppercase;
        }

        .brand-footer {
            margin-top: 30px;
            font-weight: 700;
            color: #cbd5e1;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-size: 0.7rem;
        }
    </style>
</head>
<body>

    <div class="denied-card">
        <div class="icon-wrapper">
            <i class="bi bi-shield-lock-fill"></i>
        </div>

        <h1>Dừng lại một chút!</h1>
        <p>Tài khoản của bạn không có quyền truy cập vào tài nguyên này. Vui lòng liên hệ Quản trị viên nếu bạn cho rằng đây là một sự nhầm lẫn.</p>

        <div class="btn-group-custom">
            <a href="javascript:history.back()" class="btn-back">
                <i class="bi bi-arrow-left"></i> Quay lại trang trước
            </a>
            <a href="/" class="btn-home">
                Về trang chủ
            </a>
        </div>

        <div class="support-text">
            Vai trò hiện tại:
            <span class="role-badge">
                @{
                    if (User.IsInRole("Admin"))
                    {
                        <text>Quản trị viên</text>
                    }
                    else if (User.IsInRole("Doctor"))
                    {
                        <text>Bác sĩ</text>
                    }
                    else if (User.IsInRole("Receptionist"))
                    {
                        <text>Lễ tân</text>
                    }
                    else if (User.IsInRole("Customer"))
                    {
                        <text>Khách hàng</text>
                    }
                    else
                    {
                        <text>Thành viên</text>
                    }
                }
            </span>
        </div>

        <div class="brand-footer">Medicine Clinic Management System</div>
    </div>

</body>
</html>