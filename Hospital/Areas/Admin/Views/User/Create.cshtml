@model Hospital.Areas.Admin.Models.CreateUserViewModel

@{
    ViewData["Title"] = "Tạo Tài khoản mới";
}

@* --- CSS TÙY CHỈNH --- *@
<style>
    .form-floating > label {
        color: #6c757d;
    }

    .form-floating > .form-control:focus ~ label,
    .form-floating > .form-control:not(:placeholder-shown) ~ label {
        color: #0d6efd; /* Màu primary khi focus */
        font-weight: 500;
    }

    .role-guide-card {
        background-color: #f8f9fa;
        border-left: 4px solid #0d6efd;
    }
</style>

<div class="container-fluid p-0">

    @* --- HEADER & BACK BUTTON --- *@
    <div class="d-flex justify-content-between align-items-center pt-4 pb-3">
        <div>
            <h2 class="text-primary fw-bold mb-0">Tạo Tài khoản Mới</h2>
            <p class="text-muted small mb-0">Điền thông tin để cấp quyền truy cập hệ thống.</p>
        </div>
        <div>
            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
        </div>
    </div>

    <hr class="mt-0 mb-4" />

    <div class="row">
        @* --- CỘT TRÁI: FORM NHẬP LIỆU --- *@
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <h5 class="fw-bold text-secondary mb-4"><i class="bi bi-person-badge me-2"></i>Thông tin đăng nhập</h5>

                        <div class="row g-3">
                            @* 1. Họ và Tên *@
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="FullName" class="form-control" placeholder="Nhập họ tên" />
                                    <label asp-for="FullName">Họ và Tên <span class="text-danger">*</span></label>
                                    <span asp-validation-for="FullName" class="text-danger small"></span>
                                </div>
                            </div>

                            @* 2. Email (Username) *@
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                                    <label asp-for="Email">Email đăng nhập <span class="text-danger">*</span></label>
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>
                            </div>

                            @* 3. Mật khẩu *@
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Password" class="form-control" placeholder="Mật khẩu" />
                                    <label asp-for="Password">Mật khẩu khởi tạo <span class="text-danger">*</span></label>
                                    <span asp-validation-for="Password" class="text-danger small"></span>
                                </div>
                            </div>

                            @* 4. Vai trò (Role) *@
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <select asp-for="Role" asp-items="@Model.RoleList" class="form-select" id="roleSelect">
                                        <option disabled selected>-- Chọn Vai trò --</option>
                                    </select>
                                    <label asp-for="Role">Phân quyền <span class="text-danger">*</span></label>
                                    <span asp-validation-for="Role" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="mt-4 pt-3 border-top text-end">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 shadow-sm">
                                <i class="bi bi-check-lg"></i> Hoàn tất 
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        @* --- CỘT PHẢI: HƯỚNG DẪN & GHI CHÚ --- *@
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 role-guide-card mb-4">
                <div class="card-body">
                    <h6 class="fw-bold text-primary"><i class="bi bi-info-circle-fill me-2"></i>Lưu ý về Phân quyền</h6>
                    <p class="small text-muted mb-3">Chọn đúng vai trò để đảm bảo bảo mật dữ liệu:</p>

                    <ul class="list-unstyled small text-muted">
                        <li class="mb-2">
                            <span class="badge bg-danger bg-opacity-10 text-danger me-2">Admin</span>
                            <strong>Quản trị viên:</strong> Toàn quyền hệ thống (User, Bác sĩ, Thống kê...).
                        </li>
                        <li class="mb-2">
                            <span class="badge bg-primary bg-opacity-10 text-primary me-2">Doctor</span>
                            <strong>Bác sĩ:</strong> Xem lịch hẹn, hồ sơ bệnh án, kê đơn. <em>(Tài khoản này cần được liên kết trong mục "Quản lý Bác sĩ")</em>.
                        </li>
                        <li class="mb-2">
                            <span class="badge bg-success bg-opacity-10 text-success me-2">Patient</span>
                            <strong>Bệnh nhân:</strong> Chỉ xem lịch sử khám và đặt lịch cá nhân.
                        </li>
                    </ul>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body text-center p-4">
                    <div class="bg-light rounded-circle d-inline-flex p-3 mb-3 text-secondary">
                        <i class="bi bi-shield-lock fs-1"></i>
                    </div>
                    <h6>Bảo mật mặc định</h6>
                    <p class="small text-muted mb-0">
                        Mật khẩu nên có ít nhất 6 ký tự, bao gồm chữ hoa, chữ thường và số để đảm bảo an toàn.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        // Script nhỏ để tự động focus vào ô Tên khi trang tải
        $(document).ready(function() {
            $('input[name="FullName"]').focus();
        });
    </script>
}