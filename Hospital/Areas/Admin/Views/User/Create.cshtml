@model Hospital.Areas.Admin.Models.CreateUserViewModel

@{
    ViewData["Title"] = "Tạo Tài khoản mới";
}

@* --- CSS TÙY CHỈNH ĐỂ GIAO DIỆN CÂN ĐỐI --- *@
<style>
    .form-floating > label {
        color: #6c757d;
    }

    .form-floating > .form-control:focus ~ label,
    .form-floating > .form-control:not(:placeholder-shown) ~ label {
        color: #0d6efd;
        font-weight: 600;
    }

    .role-guide-card {
        background-color: #f8f9fa;
        border-left: 4px solid #0d6efd;
    }

    .card {
        transition: transform 0.2s;
    }
</style>

<div class="container-fluid p-0">

    @* --- HEADER & BACK BUTTON --- *@
    <div class="d-flex justify-content-between align-items-center pt-4 pb-3">
        <div>
            <h2 class="text-primary fw-bold mb-0">Tạo Tài khoản Mới</h2>
            <p class="text-muted small mb-0">Cấp quyền truy cập hệ thống cho nhân viên hoặc bệnh nhân.</p>
        </div>
        <div>
            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                <i class="bi bi-arrow-left me-1"></i> Quay lại
            </a>
        </div>
    </div>

    <hr class="mt-0 mb-4" />

    <div class="row g-4">
        @* --- CỘT TRÁI: FORM NHẬP LIỆU --- *@
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <form method="post">
                        @* Chỉ hiện thông báo lỗi chung, tránh hiện mã lỗi kỹ thuật loằng ngoằng *@
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <h5 class="fw-bold text-secondary mb-4">
                            <i class="bi bi-person-badge me-2"></i>Thông tin đăng nhập
                        </h5>

                        <div class="row g-3">
                            @* 1. Họ và Tên *@
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="FullName" class="form-control border-0 bg-light" placeholder="Nhập họ tên" />
                                    <label asp-for="FullName">Họ và Tên <span class="text-danger">*</span></label>
                                    <span asp-validation-for="FullName" class="text-danger small"></span>
                                </div>
                            </div>

                            @* 2. Email (Username) *@
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Email" class="form-control border-0 bg-light" placeholder="name@example.com" />
                                    <label asp-for="Email">Email đăng nhập <span class="text-danger">*</span></label>
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>
                            </div>

                            @* 3. Mật khẩu *@
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Password" type="password" class="form-control border-0 bg-light" placeholder="Mật khẩu" />
                                    <label asp-for="Password">Mật khẩu khởi tạo <span class="text-danger">*</span></label>
                                    <span asp-validation-for="Password" class="text-danger small"></span>
                                </div>
                            </div>

                            @* 4. Vai trò (Role) *@
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <select asp-for="Role" asp-items="@Model.RoleList" class="form-select border-0 bg-light">
                                        <option disabled selected>-- Chọn Vai trò --</option>
                                    </select>
                                    <label asp-for="Role">Phân quyền hệ thống <span class="text-danger">*</span></label>
                                    <span asp-validation-for="Role" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="mt-4 pt-3 border-top text-end">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 shadow-sm">
                                <i class="bi bi-person-plus-fill me-2"></i>Hoàn tất tạo mới
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        @* --- CỘT PHẢI: HƯỚNG DẪN & GHI CHÚ --- *@
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 role-guide-card mb-4">
                <div class="card-body">
                    <h6 class="fw-bold text-primary"><i class="bi bi-info-circle-fill me-2"></i>Quyền hạn vai trò</h6>
                    <p class="small text-muted mb-3">Vui lòng chọn đúng vai trò để đảm bảo an toàn dữ liệu:</p>

                    <ul class="list-unstyled small text-muted">
                        <li class="mb-3">
                            <span class="badge bg-danger bg-opacity-10 text-danger me-2">Admin</span>
                            <strong>Quản trị:</strong> Toàn quyền quản lý nhân sự, danh mục và thống kê.
                        </li>
                        <li class="mb-3">
                            <span class="badge bg-primary bg-opacity-10 text-primary me-2">Doctor</span>
                            <strong>Bác sĩ:</strong> Quản lý hồ sơ bệnh án, kê đơn và thực hiện khám.
                        </li>
                        <li class="mb-3">
                            <span class="badge bg-info bg-opacity-10 text-info me-2">Receptionist</span>
                            <strong>Lễ tân:</strong> Tiếp nhận bệnh nhân, đặt lịch và thanh toán.
                        </li>
                        <li>
                            <span class="badge bg-success bg-opacity-10 text-success me-2">Patient</span>
                            <strong>Bệnh nhân:</strong> Xem lịch sử khám và thông tin cá nhân.
                        </li>
                    </ul>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4 bg-white">
                <div class="card-body text-center p-4">
                    <div class="bg-light rounded-circle d-inline-flex p-3 mb-3 text-secondary">
                        <i class="bi bi-shield-lock fs-1"></i>
                    </div>
                    <h6>Bảo mật mặc định</h6>
                    <p class="small text-muted mb-0">
                        Mật khẩu khởi tạo nên có ít nhất 6 ký tự để đảm bảo tiêu chuẩn an toàn của hệ thống.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            // Tự động focus vào ô nhập liệu đầu tiên để tăng trải nghiệm người dùng
            $('input[name="FullName"]').focus();
        });
    </script>
}