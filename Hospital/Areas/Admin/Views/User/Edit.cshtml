@model Hospital.Areas.Admin.Models.EditUserViewModel

@{
    ViewData["Title"] = "Cập nhật Tài khoản";
}

<style>
    .form-floating > label {
        color: #6c757d;
    }

    .form-floating > .form-control:focus ~ label,
    .form-floating > .form-control:not(:placeholder-shown) ~ label {
        color: #e67e22; /* Màu cam cho trang Edit để phân biệt */
        font-weight: 500;
    }

    .password-section {
        background-color: #fff3cd;
        border: 1px dashed #ffecb5;
        border-radius: 8px;
    }
</style>

<div class="container-fluid p-0">
    @* --- HEADER --- *@
    <div class="d-flex justify-content-between align-items-center pt-4 pb-3">
        <div>
            <h2 class="text-primary fw-bold mb-0">Cập nhật Tài khoản</h2>
            <p class="text-muted small mb-0">Chỉnh sửa thông tin, phân quyền hoặc đặt lại mật khẩu.</p>
        </div>
        <div>
            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
        </div>
    </div>

    <hr class="mt-0 mb-4" />

    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <form method="post">
                        <input type="hidden" asp-for="Id" />
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        @* 1. Thông tin Readonly *@
                        <div class="mb-4">
                            <label class="form-label text-muted small text-uppercase fw-bold">Tài khoản (Email)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="bi bi-envelope-fill text-secondary"></i></span>
                                <input asp-for="Email" class="form-control bg-light border-0 fw-bold text-dark" readonly />
                            </div>
                            <small class="text-muted fst-italic ms-2">* Không thể thay đổi Email đăng nhập.</small>
                        </div>

                        @* 2. Thông tin chính *@
                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="FullName" class="form-control" placeholder="Họ tên" />
                                    <label asp-for="FullName">Họ và Tên</label>
                                    <span asp-validation-for="FullName" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <select asp-for="Role" asp-items="@Model.RoleList" class="form-select">
                                    </select>
                                    <label asp-for="Role">Phân quyền</label>
                                    <span asp-validation-for="Role" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        @* 3. Khu vực Reset Mật khẩu *@
                        <div class="password-section p-3 mb-4">
                            <div class="d-flex align-items-center mb-2">
                                <i class="bi bi-key-fill text-warning fs-5 me-2"></i>
                                <h6 class="fw-bold text-dark mb-0">Đặt lại Mật khẩu (Reset Password)</h6>
                            </div>
                            <p class="small text-muted mb-2">Chỉ nhập vào ô bên dưới nếu bạn muốn thay đổi mật khẩu cho người dùng này. Nếu không, hãy để trống.</p>

                            <div class="form-floating bg-white rounded">
                                <input asp-for="NewPassword" class="form-control" placeholder="Mật khẩu mới" autocomplete="new-password" />
                                <label asp-for="NewPassword">Mật khẩu mới...</label>
                                <span asp-validation-for="NewPassword" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="text-end">
                            <button type="submit" class="btn btn-warning text-white btn-lg rounded-pill px-5 shadow-sm">
                                <i class="bi bi-save"></i> Lưu thay đổi
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}