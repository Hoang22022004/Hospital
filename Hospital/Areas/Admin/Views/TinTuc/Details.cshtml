@model Hospital.Models.TinTuc

@{
    ViewData["Title"] = "Chi tiết bài viết";
}

<div class="container-fluid">
    <div class="d-flex align-items-center mb-3">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm me-3">
            <i class="bi bi-arrow-left"></i> Quay lại danh sách
        </a>
        <h4 class="mb-0 fw-bold text-primary text-uppercase">Xem chi tiết bài viết</h4>
    </div>

    <div class="row">
        <div class="col-md-9">
            <div class="card shadow-sm border-0 mb-4">
                @if (!string.IsNullOrEmpty(Model.HinhAnhUrl))
                {
                    <img src="@Model.HinhAnhUrl" class="card-img-top" style="max-height: 400px; object-手fit: cover;" alt="@Model.TieuDe">
                }
                <div class="card-body p-4">
                    <div class="mb-3">
                        <span class="badge bg-info text-dark mb-2">@Model.DanhMuc</span>
                        <h1 class="fw-bold">@Model.TieuDe</h1>
                        <div class="text-muted small d-flex gap-3 border-bottom pb-3">
                            <span><i class="bi bi-person me-1"></i> Tác giả: <strong>@Model.TacGia</strong></span>
                            <span><i class="bi bi-calendar3 me-1"></i> Ngày đăng: @Model.NgayDang.ToString("dd/MM/yyyy HH:mm")</span>
                            <span>
                                @if (Model.IsPublished)
                                {
                                    <span class="text-success"><i class="bi bi-check-circle-fill"></i> Đang hiển thị</span>
                                }
                                else
                                {
                                    <span class="text-secondary"><i class="bi bi-eye-slash-fill"></i> Đang ẩn</span>
                                }
                            </span>
                        </div>
                    </div>

                    <div class="news-content mt-4" style="line-height: 1.8; font-size: 1.1rem;">
                        @Html.Raw(Model.NoiDung)
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0 sticky-top" style="top: 20px;">
                <div class="card-header bg-light fw-bold">THAO TÁC NHANH</div>
                <div class="card-body">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning w-100 mb-2">
                        <i class="bi bi-pencil-square me-1"></i> Chỉnh sửa bài viết
                    </a>
                    <button type="button" class="btn btn-outline-danger w-100" data-bs-toggle="modal" data-bs-target="#deleteModal">
                        <i class="bi bi-trash me-1"></i> Xóa bài viết
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Xác nhận xóa</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Bạn có chắc chắn muốn xóa bài viết "<strong>@Model.TieuDe</strong>" không? Hành động này không thể hoàn tác.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                    <button type="submit" class="btn btn-danger">Xác nhận xóa</button>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    /* Đảm bảo ảnh trong nội dung không bị tràn */
    .news-content img {
        max-width: 100%;
        height: auto !important;
        border-radius: 8px;
    }
</style>