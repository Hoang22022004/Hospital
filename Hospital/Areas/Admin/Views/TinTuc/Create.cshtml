@model Hospital.Models.TinTuc
@{
    ViewData["Title"] = "Thêm bài viết mới";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-white py-3">
        <h5 class="mb-0 fw-bold text-primary"><i class="bi bi-pencil-square me-2"></i>SOẠN THẢO BÀI VIẾT</h5>
    </div>
    <div class="card-body p-4">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <div class="row">
                <div class="col-md-8">
                    <div class="mb-3">
                        <label asp-for="TieuDe" class="form-label fw-bold">Tiêu đề bài viết</label>
                        <input asp-for="TieuDe" class="form-control" placeholder="Nhập tiêu đề..." />
                        <span asp-validation-for="TieuDe" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="NoiDung" class="form-label fw-bold">Nội dung chi tiết</label>
                        <textarea asp-for="NoiDung" id="tiny-editor"></textarea>
                        <span asp-validation-for="NoiDung" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card bg-light border-0 p-3">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Ảnh minh họa</label>
                            <input type="file" name="imageFile" class="form-control" accept="image/*" onchange="previewImage(this)" />
                            <img id="preview" src="/images/no-image.png" class="img-thumbnail mt-2" style="max-height: 200px; width: 100%; object-fit: cover;" />
                        </div>
                        <div class="mb-3">
                            <label asp-for="DanhMuc" class="form-label fw-bold">Chuyên mục</label>
                            <select asp-for="DanhMuc" class="form-select">
                                <option value="Kiến thức da liễu">Kiến thức da liễu</option>
                                <option value="Tin tức phòng khám">Tin tức phòng khám</option>
                                <option value="Khuyến mãi">Khuyến mãi</option>
                            </select>
                        </div>
                        <div class="mb-3 text-start">
                            <label asp-for="TacGia" class="form-label fw-bold">Tác giả</label>
                            <input asp-for="TacGia" class="form-control" />
                        </div>
                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" asp-for="IsPublished" checked>
                            <label class="form-check-label fw-bold">Công khai ngay</label>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 mb-2">Lưu bài viết</button>
                        <a asp-action="Index" class="btn btn-outline-secondary w-100">Quay lại</a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.tiny.cloud/1/vy399c75h6gyw1xkemhoj245q01aqnsusy14yaiket9jmz1h/tinymce/6/tinymce.min.js" referrerpolicy="origin"></script>

    <script>
        tinymce.init({
            selector: '#tiny-editor',
            height: 500,
            plugins: 'advlist autolink lists link image charmap preview anchor searchreplace visualblocks code fullscreen insertdatetime media table help wordcount',
            toolbar: 'undo redo | blocks | bold italic backcolor | alignleft aligncenter alignright alignjustify | bullist numlist outdent indent | image media table | removeformat | help',

            // Cấu hình upload ảnh trực tiếp từ máy tính vào nội dung bài viết
            images_upload_url: '/Admin/TinTuc/UploadImageTiny',
            automatic_uploads: true,
            file_picker_types: 'image',

            language: 'vi',
            branding: false,
            placeholder: 'Viết nội dung tại đây...'
        });

        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('preview').src = e.target.result;
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}