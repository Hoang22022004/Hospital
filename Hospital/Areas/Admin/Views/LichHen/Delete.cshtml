@model Hospital.Models.LichHen
@{
    ViewData["Title"] = "Xóa Lịch hẹn";
}

<div class="border p-4 mt-4 bg-white shadow-sm rounded">
    <div class="row pb-2">
        <h2 class="text-danger">Xác nhận Xóa Lịch hẹn</h2>
        <hr />
    </div>

    <h4 class="mb-4">Bạn có chắc chắn muốn xóa lịch hẹn này không? Hành động này không thể hoàn tác.</h4>

    <form method="post" asp-action="DeletePost">
        <input type="hidden" asp-for="LichHenId" />

        <div class="row">
            <div class="col-md-6">
                <h3>Thông tin Khách hàng</h3>
                <hr class="mb-3 mt-0" />

                <dl class="row">
                    <dt class="col-sm-4">@Html.DisplayNameFor(model => model.TenKhachHang)</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.TenKhachHang)</dd>

                    <dt class="col-sm-4">@Html.DisplayNameFor(model => model.SoDienThoai)</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.SoDienThoai)</dd>

                    <dt class="col-sm-4">Triệu chứng</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.TrieuChung)</dd>
                </dl>
            </div>

            <div class="col-md-6">
                <h3>Thông tin Lịch hẹn</h3>
                <hr class="mb-3 mt-0" />

                <dl class="row">
                    <dt class="col-sm-4">@Html.DisplayNameFor(model => model.BacSi)</dt>
                    <dd class="col-sm-8">@Model.BacSi.HoTen</dd>

                    <dt class="col-sm-4">Ca làm việc</dt>
                    <dd class="col-sm-8">@Model.LichLamViec.NgayLamViec.ToString("dd/MM/yyyy") (@Model.LichLamViec.GioBatDau.ToString("HH:mm"))</dd>

                    <dt class="col-sm-4">@Html.DisplayNameFor(model => model.DichVu)</dt>
                    <dd class="col-sm-8">@Model.DichVu.TenDichVu</dd>

                    <dt class="col-sm-4">Ngày đặt</dt>
                    <dd class="col-sm-8">@Model.ThoiGianDat.ToString("dd/MM/yyyy HH:mm")</dd>

                    <dt class="col-sm-4">Trạng thái hiện tại</dt>
                    @{
                        string statusText = Model.TrangThai switch
                        {
                            Hospital.Models.TrangThaiLichHen.DaXacNhan => "Đã Xác Nhận",
                            Hospital.Models.TrangThaiLichHen.ChoDuyet => "Chờ Duyệt",
                            Hospital.Models.TrangThaiLichHen.DaHuy => "Đã Hủy",
                            Hospital.Models.TrangThaiLichHen.HoanThanh => "Hoàn Thành",
                            _ => Model.TrangThai.ToString()
                        };
                    }
                    <dd class="col-sm-8"><span class="badge bg-danger">@statusText</span></dd>
                </dl>
            </div>
        </div>

        <div class="mt-4 pt-3 border-top text-end">
            <button type="submit" class="btn btn-danger btn-lg shadow-lg" style="width:200px">
                <i class="bi bi-trash-fill"></i> Xác nhận Xóa
            </button>
            <a asp-controller="LichHen" asp-action="Index" class="btn btn-secondary btn-lg" style="width:180px">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
        </div>
    </form>
</div>