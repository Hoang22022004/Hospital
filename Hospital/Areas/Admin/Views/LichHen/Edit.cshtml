@model Hospital.Models.LichHen
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Chỉnh sửa Lịch hẹn";
    var bacSiList = ViewData["BacSiId"] as SelectList;

    // Dữ liệu hiện tại để JS sử dụng
    var currentLichHenId = Model.LichHenId.ToString();
    var currentBacSiId = Model.BacSiId.ToString();
    var currentLichLamViecId = Model.LichLamViecId.ToString();
    var currentKhungGioBatDau = Model.KhungGioBatDau.ToString(@"hh\:mm");
    var currentDichVuId = Model.DichVuId.ToString();
}

<form method="post">
    <input type="hidden" asp-for="LichHenId" />
    <input type="hidden" asp-for="ThoiGianDat" />
    <input type="hidden" asp-for="TrangThai" />

    <div class="border p-4 mt-4 bg-white shadow-sm rounded">
        <div class="row pb-2">
            <h2 class="text-primary">Chỉnh sửa Lịch hẹn</h2>
            <hr />
        </div>
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="row">
            <div class="col-md-6">
                <h3>Thông tin Khách hàng</h3>
                <hr class="mb-3 mt-0" />

                <div class="mb-3">
                    <label asp-for="TenKhachHang" class="form-label"></label>
                    <input asp-for="TenKhachHang" class="form-control" />
                    <span asp-validation-for="TenKhachHang" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="SoDienThoai" class="form-label"></label>
                    <input asp-for="SoDienThoai" class="form-control" />
                    <span asp-validation-for="SoDienThoai" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="TrieuChung" class="form-label">Triệu chứng/Yêu cầu</label>
                    <textarea asp-for="TrieuChung" rows="3" class="form-control"></textarea>
                </div>
            </div>

            <div class="col-md-6">
                <h3>Thông tin Lịch hẹn</h3>
                <hr class="mb-3 mt-0" />

                @* --- PHẦN PHÂN QUYỀN DOCTOR --- *@
                <div class="mb-3">
                    <label asp-for="BacSiId" class="form-label">Bác sĩ phụ trách</label>

                    @if (User.IsInRole("Doctor"))
                    {
                        @* Doctor: Không được đổi bác sĩ *@
                        <input type="hidden" id="BacSiDropdown" asp-for="BacSiId" />
                        <div class="input-group">
                            <span class="input-group-text bg-light"><i class="bi bi-person-badge-fill text-primary"></i></span>
                            <input class="form-control bg-light fw-bold" value="@Model.BacSi?.HoTen" readonly />
                        </div>
                        <small class="text-muted fst-italic">Bác sĩ không thể thay đổi thông tin người phụ trách.</small>
                    }
                    else
                    {
                        @* Admin/Receptionist: Được đổi bác sĩ để điều phối *@
                        <select id="BacSiDropdown" asp-for="BacSiId" asp-items="@bacSiList" class="form-select select2-dropdown-full">
                            <option value="">-- Chọn Bác sĩ --</option>
                        </select>
                    }
                    <span asp-validation-for="BacSiId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="LichLamViecId" class="form-label">Chọn Ngày và Ca làm việc</label>
                    <select id="LichLamViecId" asp-for="LichLamViecId" class="form-select select2-dropdown-full" disabled>
                        <option value="">Đang tải...</option>
                    </select>
                    <span asp-validation-for="LichLamViecId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="KhungGioBatDau" class="form-label">Chọn Khung giờ</label>
                    <select id="KhungGioBatDau" asp-for="KhungGioBatDau" class="form-select" disabled>
                        <option value="">Đang tải...</option>
                    </select>
                    <span asp-validation-for="KhungGioBatDau" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="DichVuId" class="form-label">Chọn Dịch vụ</label>
                    <select id="DichVuId" asp-for="DichVuId" class="form-select select2-dropdown-full" disabled>
                        <option value="">Đang tải...</option>
                    </select>
                    <span asp-validation-for="DichVuId" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="mt-4 pt-3 border-top text-end">
            <button type="submit" class="btn btn-primary btn-lg shadow-lg">
                <i class="bi bi-floppy"></i> Cập nhật Lịch hẹn
            </button>
            <a asp-action="Index" class="btn btn-secondary btn-lg">Quay lại</a>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        // Các hàm helper giữ nguyên
        function timeToMinutes(timeStr) {
            if (!timeStr) return 0;
            var parts = timeStr.split(':');
            return parseInt(parts[0]) * 60 + parseInt(parts[1]);
        }

        function generateTimeSlots(gioBatDauStr, gioKetThucStr, thoiLuongPhut, bookedSlots, currentSlotTimeStr) {
            var slots = [];
            var startMinutes = timeToMinutes(gioBatDauStr);
            var endMinutes = timeToMinutes(gioKetThucStr);
            for (var currentMinutes = startMinutes; currentMinutes < endMinutes; currentMinutes += thoiLuongPhut) {
                var hour = Math.floor(currentMinutes / 60);
                var minute = currentMinutes % 60;
                if (currentMinutes + thoiLuongPhut > endMinutes) continue;
                var startTimeValue = ('0' + hour).slice(-2) + ':' + ('0' + minute).slice(-2);
                var isCurrentSlot = startTimeValue === currentSlotTimeStr;
                var isBooked = bookedSlots.includes(startTimeValue) && !isCurrentSlot;
                slots.push({
                    value: startTimeValue + ':00',
                    text: startTimeValue + ' - ' + ('0' + Math.floor((currentMinutes + thoiLuongPhut) / 60)).slice(-2) + ':' + ('0' + (currentMinutes + thoiLuongPhut) % 60).slice(-2),
                    disabled: isBooked,
                    selected: isCurrentSlot
                });
            }
            return slots;
        }

        function loadDichVuByBacSi(selectedBacSiId) {
            var dvDropdown = $('#DichVuId');
            var isInitial = $('#BacSiDropdown').data('isInitialLoad');
            $.ajax({
                url: '@Url.Action("GetDichVuByBacSi", "LichHen")',
                data: { bacSiId: selectedBacSiId },
                success: function (data) {
                    dvDropdown.empty().append('<option value="">-- Tìm kiếm Dịch vụ --</option>');
                    $.each(data, function (i, item) {
                        dvDropdown.append($('<option>', {
                            value: item.value,
                            text: item.text,
                            selected: isInitial && item.value.toString() === '@currentDichVuId'
                        }));
                    });
                    dvDropdown.attr('disabled', false).trigger('change.select2');
                }
            });
        }

        $(document).ready(function () {
            var bacSiDropdown = $('#BacSiDropdown');
            var caDropdown = $('#LichLamViecId');
            var slotDropdown = $('#KhungGioBatDau');

            bacSiDropdown.data('isInitialLoad', true);

            $('.select2-dropdown-full').select2({ theme: 'bootstrap-5', width: '100%' });

            function loadLichLamViec(selectedBacSiId) {
                var isInitial = bacSiDropdown.data('isInitialLoad');
                $.ajax({
                    url: '@Url.Action("GetLichLamViecByBacSi", "LichHen")',
                    data: { bacSiId: selectedBacSiId, excludeLichHenId: '@currentLichHenId' },
                    success: function (data) {
                        caDropdown.empty().append('<option value="">-- Chọn Ca làm việc --</option>');
                        $.each(data, function (i, item) {
                            caDropdown.append($('<option>', {
                                value: item.id,
                                text: item.text,
                                selected: isInitial && item.id.toString() === '@currentLichLamViecId'
                            }));
                        });
                        caDropdown.attr('disabled', false).trigger('change.select2');
                        if (isInitial) {
                            loadKhungGio(caDropdown.val());
                            bacSiDropdown.data('isInitialLoad', false);
                        }
                    }
                });
            }

            function loadKhungGio(caId) {
                if (!caId) return;
                var ca = (window.caLamViecData || []).find(x => x.id.toString() === caId) ||
                         (typeof caLamViecData !== 'undefined' ? caLamViecData.find(x => x.id.toString() === caId) : null);
                // Vì caLamViecData được gán trong success của AJAX loadLichLamViec
                // Ta cần đảm bảo biến này có thể truy cập được hoặc lấy từ cache AJAX.
                // Cách đơn giản nhất là gọi AJAX lại hoặc lưu vào biến global.
            }

            // Ghi đè hàm loadLichLamViec để lưu data
            var originalAjax = $.ajax;
            $.ajax = function(obj) {
                var originalSuccess = obj.success;
                if (obj.url.indexOf('GetLichLamViecByBacSi') !== -1) {
                    obj.success = function(data) {
                        window.caLamViecData = data;
                        originalSuccess(data);
                    };
                }
                return originalAjax(obj);
            };

            caDropdown.on('change', function() {
                var caId = $(this).val();
                if(!caId) return;
                var ca = window.caLamViecData.find(x => x.id.toString() === caId);
                var isInitial = bacSiDropdown.val() === '@currentBacSiId';
                var slots = generateTimeSlots(ca.gioBatDau, ca.gioKetThuc, ca.thoiLuongPhut, ca.bookedSlots, '@currentKhungGioBatDau');
                slotDropdown.empty().append('<option value="">-- Chọn Khung giờ --</option>');
                $.each(slots, function (i, s) {
                    slotDropdown.append($('<option>', { value: s.value, text: s.text, disabled: s.disabled, selected: s.selected }));
                });
                slotDropdown.attr('disabled', false);
            });

            bacSiDropdown.on('change', function () {
                loadLichLamViec($(this).val());
                loadDichVuByBacSi($(this).val());
            });

            // Trigger lần đầu
            if (bacSiDropdown.val()) {
                bacSiDropdown.trigger('change');
            }
        });
    </script>
}