@model IEnumerable<Hospital.Models.LichHen>
@using Microsoft.AspNetCore.Mvc.Rendering
@using Hospital.Models
@{
    ViewData["Title"] = "Quản lý Lịch hẹn";
    var bacSiList = ViewData["BacSiId"] as SelectList;
    var trangThaiList = ViewData["TrangThaiList"] as List<SelectListItem>;
}

@* Thư viện bổ trợ *@
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    /* CSS CŨ CỦA HUY - GIỮ NGUYÊN */
    .text-choDuyet {
        color: #ffc107 !important;
        font-weight: bold !important;
    }

    .text-daXacNhan {
        color: #198754 !important;
        font-weight: bold !important;
    }

    .text-daHuy {
        color: #dc3545 !important;
        font-weight: bold !important;
    }

    .text-hoanThanh {
        color: #0dcaf0 !important;
        font-weight: bold !important;
    }

    #tblData tbody td {
        vertical-align: middle;
        text-align: center;
    }

        #tblData tbody td.text-start {
            text-align: left !important;
        }

    .hidden-column {
        display: none !important;
    }

    /* CSS DASHBOARD & MODERN BADGES */
    .stat-card {
        background: white;
        border-radius: 16px;
        padding: 20px;
        border: 1px solid #e2e8f0;
        transition: 0.3s;
    }

    .icon-box {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
    }

    .badge-status {
        padding: 6px 12px;
        border-radius: 8px;
        font-weight: 700;
        font-size: 0.75rem;
        display: inline-block;
        border: 1px solid rgba(0,0,0,0.05);
    }

    .bg-cho-duyet {
        background-color: #fffbeb;
        color: #b45309;
    }

    .bg-da-xac-nhan {
        background-color: #f0fdf4;
        color: #15803d;
    }

    .bg-da-huy {
        background-color: #fef2f2;
        color: #b91c1c;
    }

    .bg-hoan-thanh {
        background-color: #eff6ff;
        color: #1d4ed8;
    }

    .btn-duyet-modern {
        background: #3b82f6;
        color: white;
        border: none;
        border-radius: 8px;
        padding: 6px 14px;
        font-weight: 600;
        font-size: 0.8rem;
        transition: 0.2s;
    }

        .btn-duyet-modern:hover {
            background: #2563eb;
            transform: scale(1.05);
            color: white;
        }
</style>

<div class="container-fluid p-0">
    <div class="row pt-4 align-items-center px-3">
        <div class="col-6">
            <h2 class="text-primary mb-0 fw-bold"><i class="fas fa-calendar-check me-2"></i>Danh sách Lịch hẹn</h2>
        </div>
        <div class="col-6 text-end">
            <a asp-controller="LichHen" asp-action="Create" class="btn btn-primary shadow-sm" style="border-radius:10px;">
                <i class="fas fa-plus-circle"></i> &nbsp; Đặt Lịch hẹn mới
            </a>
        </div>
    </div>
    <hr class="mt-2 mb-4" />

    <div class="row g-3 mb-4 px-3">
        <div class="col-md-3">
            <div class="stat-card">
                <div class="d-flex align-items-center">
                    <div class="icon-box bg-warning bg-opacity-10 text-warning me-3"><i class="fas fa-clock"></i></div>
                    <div>
                        <p class="text-muted mb-0 small fw-bold">CHỜ DUYỆT</p>
                        <h4 class="fw-bold mb-0">@Model.Count(x => x.TrangThai == TrangThaiLichHen.ChoDuyet)</h4>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="d-flex align-items-center">
                    <div class="icon-box bg-success bg-opacity-10 text-success me-3"><i class="fas fa-user-check"></i></div>
                    <div>
                        <p class="text-muted mb-0 small fw-bold">ĐÃ XÁC NHẬN</p>
                        <h4 class="fw-bold mb-0">@Model.Count(x => x.TrangThai == TrangThaiLichHen.DaXacNhan)</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* === BỘ LỌC CŨ CỦA HUY - GIỮ NGUYÊN === *@
    <div class="row mb-3 px-3">
        <div class="col-md-4">
            <div class="dropdown">
                <button class="btn btn-outline-info dropdown-toggle w-100" type="button" data-bs-toggle="dropdown">
                    <i class="bi bi-funnel"></i> Lọc theo
                </button>
                <ul class="dropdown-menu w-100">
                    <li><a class="dropdown-item filter-option" data-filter="trangthai"><i class="bi bi-toggle2-on"></i> Trạng thái</a></li>
                    <li><a class="dropdown-item filter-option" data-filter="bacsi"><i class="bi bi-person-badge"></i> Bác sĩ</a></li>
                    <li><a class="dropdown-item filter-option" data-filter="ngayhen"><i class="bi bi-calendar-date"></i> Ngày hẹn</a></li>
                </ul>
            </div>
        </div>
        <div class="col-md-2">
            <button id="resetFilter" class="btn btn-outline-secondary w-100">
                <i class="bi bi-x-circle"></i> Đặt lại
            </button>
        </div>
    </div>

    <div id="filterTrangThai" class="mb-3 px-3 d-none">
        <label class="form-label small fw-bold">Lọc theo Trạng thái:</label>
        <select id="trangThaiFilter" class="form-select">
            <option value="">-- Tất cả --</option>
            <option value="Chờ Duyệt">Chờ Duyệt</option>
            <option value="Đã Xác Nhận">Đã Xác Nhận</option>
            <option value="Đã Hủy">Đã Hủy</option>
            <option value="Hoàn Thành">Hoàn Thành</option>
        </select>
    </div>

    <div id="filterBacSi" class="mb-3 px-3 d-none">
        <label class="form-label small fw-bold">Lọc theo Bác sĩ:</label>
        <select id="bacSiFilter" class="form-select select2-dropdown">
            <option value="">-- Tất cả --</option>
            @if (bacSiList != null)
            {
                @foreach (var item in bacSiList)
                {
                    <option value="@item.Text">@item.Text</option>
                }
            }
        </select>
    </div>

    <div id="filterNgayHen" class="mb-3 px-3 d-none">
        <label class="form-label small fw-bold">Lọc theo Ngày hẹn:</label>
        <input type="date" id="ngayHenFilter" class="form-control" />
    </div>

    @* === BẢNG DỮ LIỆU === *@
    <div class="px-3">
        <table id="tblData" class="table table-striped table-hover shadow-sm border" style="width:100%">
            <thead class="table-light">
                <tr>
                    <th style="text-align: left;">Khách hàng</th>
                    <th class="text-center">Điện thoại</th>
                    <th class="text-center">Khung giờ hẹn</th>
                    <th class="text-center">Bác sĩ</th>
                    <th class="text-center">Dịch vụ</th>
                    <th class="text-center">Ngày đặt</th>
                    <th class="hidden-column">Trạng thái (Text)</th>
                    <th class="text-center">Trạng thái</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var obj in Model)
                {
                    TimeSpan endTimeSlot = obj.KhungGioBatDau.Add(TimeSpan.FromMinutes(obj.LichLamViec.ThoiLuongKhungGioPhut));

                    // CHUYỂN ĐỔI TIẾNG VIỆT CHO TRẠNG THÁI
                    string statusText = obj.TrangThai switch
                    {
                        TrangThaiLichHen.ChoDuyet => "Chờ Duyệt",
                        TrangThaiLichHen.DaXacNhan => "Đã Xác Nhận",
                        TrangThaiLichHen.DaHuy => "Đã Hủy",
                        TrangThaiLichHen.HoanThanh => "Hoàn Thành",
                        _ => obj.TrangThai.ToString()
                    };

                    string statusClass = obj.TrangThai switch
                    {
                        TrangThaiLichHen.ChoDuyet => "bg-cho-duyet",
                        TrangThaiLichHen.DaXacNhan => "bg-da-xac-nhan",
                        TrangThaiLichHen.DaHuy => "bg-da-huy",
                        TrangThaiLichHen.HoanThanh => "bg-hoan-thanh",
                        _ => "bg-light"
                    };

                    bool canDuyet = obj.TrangThai == TrangThaiLichHen.ChoDuyet;

                    <tr>
                        <td class="text-start fw-bold text-dark">@obj.TenKhachHang</td>
                        <td>@obj.SoDienThoai</td>
                        <td>@obj.LichLamViec.NgayLamViec.ToString("dd/MM/yyyy") (@obj.KhungGioBatDau.ToString(@"hh\:mm") - @endTimeSlot.ToString(@"hh\:mm"))</td>
                        <td><i class="fas fa-user-md me-1 text-primary"></i> <b>@obj.BacSi.HoTen</b></td>
                        <td>@obj.DichVu.TenDichVu</td>
                        <td>@obj.ThoiGianDat.ToString("dd/MM/yyyy HH:mm")</td>

                        <td class="hidden-column">@statusText</td>

                        <td>
                            @* HIỂN THỊ CỐ ĐỊNH DẠNG BADGE - KHÔNG CHO SỬA TẠI ĐÂY *@
                            <span class="badge-status @statusClass">
                                @statusText
                            </span>
                        </td>
                        <td>
                            <div class="btn-group gap-1">
                                @if (canDuyet)
                                {
                                    <button type="button" class="btn-duyet-modern" onclick="confirmDuyet('@obj.LichHenId', '@obj.TenKhachHang')">
                                        <i class="fas fa-check-circle me-1"></i> Duyệt
                                    </button>
                                    <form id="form-duyet-@obj.LichHenId" asp-action="DuyetLich" asp-route-id="@obj.LichHenId" method="post" class="d-none">
                                        @Html.AntiForgeryToken()
                                    </form>
                                }
                                <a asp-action="Edit" asp-route-id="@obj.LichHenId" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil-square"></i></a>
                                <a asp-action="Delete" asp-route-id="@obj.LichHenId" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash-fill"></i></a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.bootstrap5.min.js"></script>

    <script>
        // HÀM XÁC NHẬN DUYỆT - NỘI DUNG HUY YÊU CẦU
        function confirmDuyet(id, name) {
            Swal.fire({
                title: 'Xác nhận Duyệt?',
                text: "Xác nhận duyệt lịch hẹn cho bệnh nhân " + name + "? Hệ thống sẽ tự động đồng bộ thông tin vào danh sách chờ khám.",
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#3b82f6',
                cancelButtonColor: '#94a3b8',
                confirmButtonText: 'Đồng ý Duyệt',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({ title: 'Đang xử lý...', allowOutsideClick: false, didOpen: () => { Swal.showLoading() } });
                    document.getElementById('form-duyet-' + id).submit();
                }
            })
        }

        $(document).ready(function () {
            // FILTER NGÀY HẸN CỦA HUY - GIỮ NGUYÊN
            $.fn.dataTable.ext.search.push(function(settings, data, dataIndex) {
                var selectedDate = $('#ngayHenFilter').val();
                if (selectedDate === '') return true;
                var appointmentCol = data[2];
                var datePartMatch = appointmentCol.match(/(\d{2}\/\d{2}\/\d{4})/);
                if (!datePartMatch) return true;
                var dateText = datePartMatch[1];
                var parts = dateText.split('/');
                var tableDate = parts[2] + '-' + parts[1] + '-' + parts[0];
                return selectedDate === tableDate;
            });

            var table = $('#tblData').DataTable({
                "language": { "url": "/js/i18n/vi.json" },
                "order": [[5, 'desc']],
                "columnDefs": [{ "targets": 6, "visible": false, "searchable": true }]
            });

            $('#bacSiFilter').select2({ theme: 'bootstrap-5', width: '100%' });

            // LOGIC LỌC CỦA HUY - GIỮ NGUYÊN
            function resetAllFilters() {
                table.columns().search('').draw();
                $('#bacSiFilter').val('').trigger('change.select2');
                $('#trangThaiFilter').val('');
                $('#ngayHenFilter').val('');
                $('#filterBacSi, #filterTrangThai, #filterNgayHen').addClass('d-none');
                table.draw();
            }

            function applyFilters() {
                table.columns().search('');
                var bacSi = $('#filterBacSi').is(':visible') ? $('#bacSiFilter').val() : '';
                var trangThai = $('#filterTrangThai').is(':visible') ? $('#trangThaiFilter').val() : '';
                table.column(3).search(bacSi ? '^' + bacSi + '$' : '', true, false);
                table.column(6).search(trangThai ? '^' + trangThai + '$' : '', true, false);
                table.draw();
            }

            $('#bacSiFilter, #trangThaiFilter, #ngayHenFilter').on('change', applyFilters);
            $('.filter-option').on('click', function () {
                var filter = $(this).data('filter');
                resetAllFilters();
                if (filter === 'bacsi') $('#filterBacSi').removeClass('d-none');
                else if (filter === 'trangthai') $('#filterTrangThai').removeClass('d-none');
                else if (filter === 'ngayhen') $('#filterNgayHen').removeClass('d-none');
            });
            $('#resetFilter').on('click', resetAllFilters);
        });
    </script>
}