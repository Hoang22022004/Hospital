@model IEnumerable<Hospital.Models.LichHen>
@using Microsoft.AspNetCore.Mvc.Rendering
@using Hospital.Models
@{
    ViewData["Title"] = "Quản lý Lịch hẹn";
    var bacSiList = ViewData["BacSiId"] as SelectList;
    var dichVuList = ViewData["DichVuId"] as SelectList;
    var trangThaiList = ViewData["TrangThaiList"] as List<SelectListItem>;
}

@* Thêm link cho Select2 theme Bootstrap 5 nếu bạn đang dùng *@
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />

<style>
    /* CSS Giữ nguyên */
    .text-choDuyet {
        color: #ffc107 !important;
        font-weight: bold !important;
    }

    .text-daXacNhan {
        color: #198754 !important;
        font-weight: bold !important;
    }

    .text-daHuy {
        color: #dc3545 !important;
        font-weight: bold !important;
    }

    .text-hoanThanh {
        color: #0dcaf0 !important;
        font-weight: bold !important;
    }

    .status-changer {
        background-color: #f8f9fa;
    }

    #tblData tbody td {
        vertical-align: middle;
        text-align: center;
    }

        #tblData tbody td.text-start {
            text-align: left !important;
        }

    .status-changer-container {
        min-width: 140px;
        margin: auto;
    }

    .hidden-column {
        display: none !important;
    }

    /* Thêm CSS cho Tooltip trên nút disabled */
    .btn-group span.d-inline-block {
        cursor: not-allowed;
    }
</style>

<div class="container-fluid p-0">
    <div class="row pt-4 align-items-center">
        <div class="col-6">
            <h2 class="text-primary mb-0">Danh sách Lịch hẹn</h2>
        </div>
        <div class="col-6 text-end">
            <a asp-controller="LichHen" asp-action="Create" class="btn btn-primary shadow-sm">
                <i class="bi bi-calendar-plus"></i> &nbsp; Đặt Lịch hẹn mới
            </a>
        </div>
    </div>
    <hr class="mt-2 mb-4" />


    <div class="row mb-3">
        <div class="col-md-4">
            <div class="dropdown">
                <button class="btn btn-outline-info dropdown-toggle w-100"
                        type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-funnel"></i> Lọc theo
                </button>
                <ul class="dropdown-menu w-100">
                    <li><a class="dropdown-item filter-option" data-filter="trangthai"><i class="bi bi-toggle2-on"></i> Trạng thái</a></li>
                    <li><a class="dropdown-item filter-option" data-filter="bacsi"><i class="bi bi-person-badge"></i> Bác sĩ</a></li>
                    <li><a class="dropdown-item filter-option" data-filter="ngayhen"><i class="bi bi-calendar-date"></i> Ngày hẹn</a></li> @* ĐÃ THAY DỊCH VỤ BẰNG NGÀY HẸN *@
                    @* <li><a class="dropdown-item filter-option" data-filter="dichvu"><i class="bi bi-card-checklist"></i> Dịch vụ</a></li> -- BỎ DỊCH VỤ -- *@
                </ul>
            </div>
        </div>
        <div class="col-md-2">
            <button id="resetFilter" class="btn btn-outline-secondary w-100">
                <i class="bi bi-x-circle"></i> Đặt lại
            </button>
        </div>
    </div>


    <div id="filterTrangThai" class="mb-3 d-none">
        <label class="form-label">Lọc theo Trạng thái:</label>
        <select id="trangThaiFilter" class="form-select">
            <option value="">-- Tất cả --</option>
            @if (trangThaiList != null)
            {
                @foreach (var item in trangThaiList)
                {
                    string filterText = item.Value switch
                    {
                        nameof(TrangThaiLichHen.DaHuy) => "Đã Hủy",
                        nameof(TrangThaiLichHen.DaXacNhan) => "Đã Xác Nhận",
                        nameof(TrangThaiLichHen.ChoDuyet) => "Chờ Duyệt",
                        nameof(TrangThaiLichHen.HoanThanh) => "Hoàn Thành",
                        _ => item.Text
                    };
                    <option value="@filterText">
                        @filterText
                    </option>
                }
            }
        </select>
    </div>

    <div id="filterBacSi" class="mb-3 d-none">
        <label class="form-label">Lọc theo Bác sĩ:</label>
        <select id="bacSiFilter" class="form-select select2-dropdown">
            <option value="">-- Tất cả --</option>
            @if (bacSiList != null)
            {
                @foreach (var item in bacSiList)
                {
                    <option value="@item.Text">@item.Text</option>
                }
            }
        </select>
    </div>

    @* KHU VỰC LỌC THEO NGÀY HẸN MỚI *@
    <div id="filterNgayHen" class="mb-3 d-none">
        <label class="form-label">Lọc theo Ngày hẹn:</label>
        <input type="date" id="ngayHenFilter" class="form-control" />
    </div>

    @* KHU VỰC LỌC DỊCH VỤ CŨ (Giữ lại ẩn để tránh lỗi tham chiếu JS nếu có) *@
    <div id="filterDichVu" class="mb-3 d-none">
        <label class="form-label">Lọc theo Dịch vụ:</label>
        <select id="dichVuFilter" class="form-select select2-dropdown">
            <option value="">-- Tất cả --</option>
            @if (dichVuList != null)
            {
                @foreach (var item in dichVuList)
                {
                    <option value="@item.Text">@item.Text</option>
                }
            }
        </select>
    </div>


    <table id="tblData" class="table table-striped table-hover" style="width:100%">
        <thead>
            <tr>
                <th style="text-align: left;">Khách hàng</th>
                <th class="text-center">Điện thoại</th>
                <th class="text-center">Khung giờ hẹn</th> @* Cột 2: Chứa ngày (dd/MM/yyyy) để lọc theo ngày *@
                <th class="text-center">Bác sĩ</th>
                <th class="text-center">Dịch vụ</th>
                <th class="text-center">Ngày đặt</th>

                <th class="hidden-column">Trạng thái (Text)</th> @* Cột 6: Cột ẩn lọc trạng thái *@

                <th class="text-center">Trạng thái</th>

                <th class="text-center">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var obj in Model)
            {
                TimeSpan endTimeSlot = obj.KhungGioBatDau.Add(TimeSpan.FromMinutes(obj.LichLamViec.ThoiLuongKhungGioPhut));

                <tr>
                    <td class="text-start">@obj.TenKhachHang</td>
                    <td>@obj.SoDienThoai</td>

                    <td>
                        @obj.LichLamViec.NgayLamViec.ToString("dd/MM/yyyy")
                        (
                        @obj.KhungGioBatDau.ToString(@"hh\:mm") - @endTimeSlot.ToString(@"hh\:mm")
                        )
                    </td>

                    <td>@obj.BacSi.HoTen</td>
                    <td>@obj.DichVu.TenDichVu</td>
                    <td>@obj.ThoiGianDat.ToString("dd/MM/yyyy HH:mm")</td>


                    @{
                        string statusEnum = obj.TrangThai.ToString();
                        string statusText = statusEnum switch
                        {
                            nameof(TrangThaiLichHen.DaHuy) => "Đã Hủy",
                            nameof(TrangThaiLichHen.DaXacNhan) => "Đã Xác Nhận",
                            nameof(TrangThaiLichHen.ChoDuyet) => "Chờ Duyệt",
                            nameof(TrangThaiLichHen.HoanThanh) => "Hoàn Thành",
                            _ => statusEnum
                        };

                        // Logic mới (Giữ nguyên)
                        bool isFinalStatus = statusEnum == nameof(TrangThaiLichHen.HoanThanh) || statusEnum == nameof(TrangThaiLichHen.DaHuy);
                        bool canEdit = statusEnum == nameof(TrangThaiLichHen.ChoDuyet);
                        string disableEditMessage = "Không thể sửa. Lịch hẹn chỉ có thể được sửa khi ở trạng thái 'Chờ Duyệt'.";
                    }

                    <td class="hidden-column">@statusText</td>

                    @* Cột Trạng thái (Status Changer) - Vô hiệu hóa nếu là trạng thái cuối cùng *@
                    <td>
                        <div class="status-changer-container">
                            <select class="form-select form-select-sm status-changer"
                                    data-id="@obj.LichHenId"
                                    data-current-status="@statusEnum"
                            @(isFinalStatus ? "disabled" : "")>
                                @foreach (var statusItem in trangThaiList)
                                {
                                    string displayValue = statusItem.Value switch
                                    {
                                        nameof(TrangThaiLichHen.DaHuy) => "Đã Hủy",
                                        nameof(TrangThaiLichHen.DaXacNhan) => "Đã Xác Nhận",
                                        nameof(TrangThaiLichHen.ChoDuyet) => "Chờ Duyệt",
                                        nameof(TrangThaiLichHen.HoanThanh) => "Hoàn Thành",
                                        _ => statusItem.Value
                                    };

                                    <option value="@statusItem.Value"
                                            selected="@(obj.TrangThai.ToString() == statusItem.Value)">
                                        @displayValue
                                    </option>
                                }
                            </select>
                        </div>
                    </td>


                    @* Cột Thao tác (Action Buttons) - CHỈ ÁP DỤNG ĐIỀU KIỆN CHO NÚT SỬA *@
                    <td>
                        <div class="btn-group" role="group" style="justify-content: center;">
                            @* Nút SỬA (Edit) *@
                            @if (canEdit)
                            {
                                <a asp-controller="LichHen" asp-action="Edit" asp-route-id="@obj.LichHenId" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                            }
                            else
                            {
                                @* Nút SỬA bị VÔ HIỆU HÓA kèm Tooltip *@
                                <span data-bs-toggle="tooltip" data-bs-placement="top" title="@disableEditMessage" class="d-inline-block">
                                    <button class="btn btn-sm btn-outline-primary disabled" style="pointer-events: none;" type="button">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                </span>
                            }

                            @* Nút XÓA (Delete) - Luôn hiển thị *@
                            <a asp-controller="LichHen" asp-action="Delete" asp-route-id="@obj.LichHenId" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash-fill"></i>
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    @* Thêm Select2 JS *@
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.bootstrap5.min.js"></script>

    <script>
        // Hàm áp dụng màu chữ (text color) cho dropdown (Giữ nguyên)
        function applyStatusColor(selectElement) {
            var currentStatus = selectElement.val();
            selectElement.removeClass('text-choDuyet text-daXacNhan text-daHuy text-hoanThanh');
            switch (currentStatus) {
                case 'ChoDuyet': selectElement.addClass('text-choDuyet'); break;
                case 'DaXacNhan': selectElement.addClass('text-daXacNhan'); break;
                case 'DaHuy': selectElement.addClass('text-daHuy'); break;
                case 'HoanThanh': selectElement.addClass('text-hoanThanh'); break;
            }
        }

        $(document).ready(function () {

            // Khởi tạo Tooltip Bootstrap (rất quan trọng cho thông báo nút Disabled)
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl)
            })

            // === 1. THÊM CUSTOM FILTER CHO NGÀY HẸN (Cột 2) ===
            $.fn.dataTable.ext.search.push(
                function(settings, data, dataIndex) {
                    var selectedDate = $('#ngayHenFilter').val(); // Định dạng YYYY-MM-DD
                    if (selectedDate === '') {
                        return true; // Nếu không chọn ngày, không lọc
                    }

                    // Lấy giá trị ngày từ cột Khung giờ hẹn (index 2)
                    // Chuỗi ví dụ: "20/12/2025 (10:00 - 11:00)"
                    var appointmentCol = data[2];

                    // Trích xuất phần ngày (20/12/2025)
                    var datePartMatch = appointmentCol.match(/(\d{2}\/\d{2}\/\d{4})/);
                    if (!datePartMatch) return true;

                    var dateText = datePartMatch[1]; // Định dạng dd/MM/yyyy

                    // Chuyển dd/MM/yyyy sang YYYY-MM-DD để so sánh với input date
                    var parts = dateText.split('/');
                    var tableDate = parts[2] + '-' + parts[1] + '-' + parts[0];

                    return selectedDate === tableDate;
                }
            );

            // Khởi tạo DataTables
            var table = $('#tblData').DataTable({
                "language": { "url": "/js/i18n/vi.json" },
                "lengthMenu": [[10, 25, 50, -1], [10, 25, 50, "Tất cả"]],
                "pagingType": "full_numbers",
                "order": [[5, 'desc']],

                // ẨN CỘT DÙNG ĐỂ LỌC (Index 6)
                "columnDefs": [
                    { "targets": 6, "visible": false, "searchable": true }
                ]
            });

            // ÁP DỤNG MÀU SẮC VÀ IN ĐẬM KHI TẢI TRANG
            $('.status-changer').each(function() {
                applyStatusColor($(this));
            });

            // Khởi tạo Select2 cho các Dropdown Lọc (Bỏ Dịch vụ nếu không dùng)
            $('#bacSiFilter, #dichVuFilter').select2({
                placeholder: "-- Tất cả --",
                allowClear: true,
                theme: 'bootstrap-5',
                width: '100%'
            });

            // --- 2. HÀM LỌC ---
            function resetAllFilters() {
                // Xóa bộ lọc DataTables
                table.columns().search('');
                table.search('').draw();

                $('#bacSiFilter').val('').trigger('change.select2');
                $('#dichVuFilter').val('').trigger('change.select2'); // Reset Dịch vụ
                $('#trangThaiFilter').val('');
                $('#ngayHenFilter').val(''); // Reset Ngày hẹn

                // Ẩn tất cả các khu vực lọc
                $('#filterBacSi, #filterDichVu, #filterTrangThai, #filterNgayHen').addClass('d-none');

                // Cần gọi draw lần cuối để áp dụng reset filter ngày tùy chỉnh
                table.draw();
            }

            function applyFilters() {
                // Xóa tìm kiếm cột cũ trước khi áp dụng bộ lọc mới
                table.columns().search('');

                var bacSi = $('#filterBacSi').is(':visible') ? $('#bacSiFilter').val() : '';
                var trangThai = $('#filterTrangThai').is(':visible') ? $('#trangThaiFilter').val() : '';
                // var dichVu = $('#filterDichVu').is(':visible') ? $('#dichVuFilter').val() : ''; // Không sử dụng trong logic lọc mới

                // Cột 3: Bác sĩ (Lọc chính xác)
                table.column(3).search(bacSi ? '^' + bacSi + '$' : '', true, false);

                // Cột 6: Trạng thái (SỬ DỤNG CỘT ẨN VÀ LỌC CHÍNH XÁC)
                table.column(6).search(trangThai ? '^' + trangThai + '$' : '', true, false);

                // Không cần lọc cột Dịch vụ (cột 4) nếu không dùng

                // Kích hoạt DataTables vẽ lại (sẽ kích hoạt Custom Filter Ngày)
                table.draw();
            }

            // 1. Gắn sự kiện Change cho các Filter
            $('#bacSiFilter, #trangThaiFilter, #ngayHenFilter, #dichVuFilter').on('change', function() {
                applyFilters();
            });

            // 2. Hiển thị filter theo menu
            $('.filter-option').on('click', function () {
                var filter = $(this).data('filter');

                resetAllFilters();

                if (filter === 'bacsi') {
                    $('#filterBacSi').removeClass('d-none');
                } else if (filter === 'trangthai') {
                    $('#filterTrangThai').removeClass('d-none');
                } else if (filter === 'ngayhen') {
                    $('#filterNgayHen').removeClass('d-none');
                }
                // Không cần khối else if cho 'dichvu' vì đã loại bỏ khỏi menu
            });


            // 3. RESET
            $('#resetFilter').on('click', function () {
                resetAllFilters();
            });

            // 4. Logic Cập nhật Trạng thái Nhanh qua AJAX (Giữ nguyên)
            $(document).on('change', '.status-changer', function () {
                var selectElement = $(this);
                var lichHenId = selectElement.data('id');
                var oldStatus = selectElement.data('current-status');
                var newStatus = selectElement.val();

                if (newStatus !== oldStatus) {
                    toastr.info("Đang cập nhật trạng thái...", "Vui lòng chờ");

                    $.ajax({
                        url: '@Url.Action("UpdateTrangThaiAjax", "LichHen")',
                        type: 'POST',
                        data: {
                            id: lichHenId,
                            trangThaiMoi: newStatus
                        },
                        success: function (response) {
                            if (response.success) {
                                toastr.clear();
                                toastr.success(response.message, "Thành công!");

                                // Cần reload vì DataTables cần tải lại nội dung cột Ẩn (index 6) để lọc chính xác
                                setTimeout(function() {
                                    window.location.reload();
                                }, 1000);

                            } else {
                                toastr.clear();
                                toastr.error(response.message, "Lỗi!");
                                selectElement.val(oldStatus);
                            }
                        },
                        error: function () {
                            toastr.clear();
                            toastr.error("Lỗi kết nối máy chủ.", "Thất bại");
                            selectElement.val(oldStatus);
                        }
                    });
                }
            });
        });
    </script>
}