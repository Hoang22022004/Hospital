@model Hospital.Models.LichHen
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Đặt Lịch hẹn mới";
    var bacSiList = ViewData["BacSiId"] as SelectList;
    var dichVuList = ViewData["DichVuId"] as SelectList;
}

<form method="post">
    <div class="border p-4 mt-4 bg-white shadow-sm rounded">
        <div class="row pb-2">
            <h2 class="text-primary">Đặt Lịch hẹn mới</h2>
            <hr />
        </div>
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="row">
            <div class="col-md-6">

                <h3>Thông tin Khách hàng</h3>
                <hr class="mb-3 mt-0" />

                <div class="mb-3">
                    <label asp-for="TenKhachHang" class="form-label"></label>
                    <input asp-for="TenKhachHang" class="form-control" placeholder="Ví dụ: Nguyễn Văn A" />
                    <span asp-validation-for="TenKhachHang" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="SoDienThoai" class="form-label"></label>
                    <input asp-for="SoDienThoai" class="form-control" placeholder="Ví dụ: 0901234567" />
                    <span asp-validation-for="SoDienThoai" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" placeholder="Ví dụ: email@khachhang.com (Nếu có)" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="TrieuChung" class="form-label">Triệu chứng/Yêu cầu</label>
                    <textarea asp-for="TrieuChung" rows="3" class="form-control" placeholder="Mô tả sơ lược triệu chứng hoặc yêu cầu đặc biệt"></textarea>
                </div>

            </div>

            <div class="col-md-6">

                <h3>Thông tin Lịch hẹn</h3>
                <hr class="mb-3 mt-0" />

                <div class="mb-3">
                    <label asp-for="BacSiId" class="form-label">Chọn Bác sĩ</label>
                    <select id="BacSiDropdown" asp-for="BacSiId" asp-items="@bacSiList" class="form-select select2-dropdown-full">
                        <option value="">-- Chọn Bác sĩ --</option>
                    </select>
                    <span asp-validation-for="BacSiId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="LichLamViecId" class="form-label">Chọn Ngày và Ca làm việc</label>
                    <select id="LichLamViecId" asp-for="LichLamViecId" class="form-select select2-dropdown-full" disabled>
                        <option value="">-- Chọn Bác sĩ trước --</option>
                    </select>
                    <span asp-validation-for="LichLamViecId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="KhungGioBatDau" class="form-label">Chọn Khung giờ</label>
                    <select id="KhungGioBatDau" asp-for="KhungGioBatDau" class="form-select" disabled>
                        <option value="">-- Chọn Ca làm việc trước --</option>
                    </select>
                    <span asp-validation-for="KhungGioBatDau" class="text-danger"></span>
                </div>

                <span id="LichLamViecGuide" class="text-muted small">Khung giờ hiển thị dựa trên thời lượng khám của bác sĩ và các slot còn trống.</span>
                <span id="LichLamViecError" class="text-danger" style="display: none;"></span>

                <div class="mb-3">
                    <label asp-for="DichVuId" class="form-label">Chọn Dịch vụ</label>
                    <select asp-for="DichVuId" asp-items="@dichVuList" class="form-select select2-dropdown-full">
                        <option value="">-- Tìm kiếm Dịch vụ --</option>
                    </select>
                    <span asp-validation-for="DichVuId" class="text-danger"></span>
                </div>

            </div>
        </div>

        <div class="mt-4 pt-3 border-top text-end">
            <button type="submit" class="btn btn-primary btn-lg shadow-lg" style="width:200px">
                <i class="bi bi-calendar-plus"></i> Hoàn tất Đặt lịch
            </button>
            <a asp-controller="LichHen" asp-action="Index" class="btn btn-secondary btn-lg" style="width:180px">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
        </div>
    </div>
</form>

@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }

    <script>
        // Hàm chuyển đổi HH:mm thành số phút từ nửa đêm
        function timeToMinutes(timeStr) {
            if (!timeStr) return 0;
            var parts = timeStr.split(':');
            return parseInt(parts[0]) * 60 + parseInt(parts[1]);
        }

        // Hàm phân chia khung giờ (Time Slot Generator)
        function generateTimeSlots(gioBatDauStr, gioKetThucStr, thoiLuongPhut, bookedSlots) {
            var slots = [];
            var startMinutes = timeToMinutes(gioBatDauStr);
            var endMinutes = timeToMinutes(gioKetThucStr);

            for (var currentMinutes = startMinutes; currentMinutes < endMinutes; currentMinutes += thoiLuongPhut) {

                var hour = Math.floor(currentMinutes / 60);
                var minute = currentMinutes % 60;

                var nextMinutes = currentMinutes + thoiLuongPhut;
                if (nextMinutes > endMinutes) continue;

                var endHour = Math.floor(nextMinutes / 60);
                var endMinute = nextMinutes % 60;

                var startTimeValue = ('0' + hour).slice(-2) + ':' + ('0' + minute).slice(-2); // VD: "09:00"
                var endTimeText = ('0' + endHour).slice(-2) + ':' + ('0' + endMinute).slice(-2);
                var slotDisplayText = startTimeValue + ' - ' + endTimeText;

                // Kiểm tra xem khung giờ này đã bị đặt chưa (bookedSlots là list chuỗi "HH:mm")
                var isBooked = bookedSlots.includes(startTimeValue);

                slots.push({
                    // Giá trị gửi về Server phải là HH:mm:ss để Model Binder chuyển thành TimeSpan
                    value: startTimeValue + ':00',
                    text: slotDisplayText,
                    disabled: isBooked
                });
            }
            return slots;
        }

        $(document).ready(function () {

            var bacSiDropdown = $('#BacSiDropdown');
            var caLamViecDropdown = $('#LichLamViecId');
            var khungGioDropdown = $('#KhungGioBatDau');
            var errorSpan = $('#LichLamViecError');
            var guideSpan = $('#LichLamViecGuide');
            var caLamViecData = []; // Biến tạm để lưu dữ liệu ca làm việc chi tiết (từ Server)


            // Kích hoạt Select2
            $('.select2-dropdown-full').select2({
                placeholder: "-- Tìm kiếm...",
                allowClear: true,
                theme: 'bootstrap-5',
                width: '100%'
            });


            // --- BƯỚC 1: Tải Ca làm việc (Ngày và Giờ lớn) khi chọn Bác sĩ ---
            bacSiDropdown.on('change', function () {
                var selectedBacSiId = $(this).val();

                errorSpan.text('').hide();
                guideSpan.show();

                caLamViecDropdown.attr('disabled', true);
                caLamViecDropdown.empty().append('<option value="">Đang tải ca làm việc...</option>');
                khungGioDropdown.attr('disabled', true).empty().append('<option value="">-- Chọn Ca làm việc trước --</option>');

                if (selectedBacSiId) {
                    // Gọi AJAX để lấy danh sách ca làm việc lớn (LLV) và các slot đã đặt
                    $.ajax({
                        url: '@Url.Action("GetLichLamViecByBacSi", "LichHen")',
                        type: 'GET',
                        data: { bacSiId: selectedBacSiId },
                        success: function (data) {
                            caLamViecData = data; // Lưu dữ liệu ca làm việc chi tiết
                            caLamViecDropdown.empty();

                            if (data && data.length > 0) {
                                caLamViecDropdown.append('<option value="">-- Chọn Ngày và Ca làm việc --</option>');
                                $.each(data, function (i, item) {
                                    caLamViecDropdown.append($('<option>', {
                                        value: item.id, // ID của LLV lớn
                                        text: item.text // Ngày (HH:mm - HH:mm)
                                    }));
                                });
                                caLamViecDropdown.attr('disabled', false);
                                guideSpan.show();
                            } else {
                                caLamViecDropdown.append('<option value="">Không có ca trống</option>').val('');
                                errorSpan.text('⚠️ Bác sĩ này hiện không có ca làm việc trống.').show();
                                guideSpan.hide();
                            }
                            caLamViecDropdown.trigger('change.select2');
                        },
                        error: function () {
                            errorSpan.text('⚠️ Lỗi hệ thống khi tải ca làm việc.').show();
                            guideSpan.hide();
                            caLamViecDropdown.empty().append('<option value="">Lỗi tải dữ liệu</option>').val('');
                            caLamViecDropdown.attr('disabled', true);
                            caLamViecDropdown.trigger('change.select2');
                        }
                    });
                } else {
                    caLamViecDropdown.empty().append('<option value="">-- Chọn Bác sĩ trước --</option>');
                    caLamViecDropdown.attr('disabled', true);
                    khungGioDropdown.empty().append('<option value="">-- Chọn Ca làm việc trước --</option>').attr('disabled', true);
                    guideSpan.show();
                    caLamViecDropdown.trigger('change.select2');
                }
            });


            // --- BƯỚC 2: Tải Khung giờ nhỏ khi chọn Ca làm việc (Ngày) ---
            caLamViecDropdown.on('change', function() {
                var selectedLichLamViecId = $(this).val();
                khungGioDropdown.attr('disabled', true).empty().append('<option value="">-- Chọn Khung giờ --</option>');
                errorSpan.hide();
                guideSpan.show();

                if (selectedLichLamViecId) {
                    // Tìm dữ liệu Ca làm việc lớn đã chọn
                    var selectedCa = caLamViecData.find(item => item.id.toString() === selectedLichLamViecId);

                    if (selectedCa && selectedCa.thoiLuongPhut > 0) {
                        var slots = generateTimeSlots(
                            selectedCa.gioBatDau,
                            selectedCa.gioKetThuc,
                            selectedCa.thoiLuongPhut,
                            selectedCa.bookedSlots || []
                        );

                        khungGioDropdown.empty().append('<option value="">-- Chọn Khung giờ --</option>');

                        var availableSlotsCount = 0;

                        $.each(slots, function (i, slot) {
                            khungGioDropdown.append($('<option>', {
                                value: slot.value,
                                text: slot.text,
                                disabled: slot.disabled
                            }));
                            if (!slot.disabled) {
                                availableSlotsCount++;
                            }
                        });

                        if (availableSlotsCount > 0) {
                            khungGioDropdown.attr('disabled', false);
                        } else {
                            errorSpan.text('⚠️ Tất cả khung giờ trong ca này đã được đặt hết.').show();
                            guideSpan.hide();
                        }
                    } else {
                        // Trường hợp ca không có thời lượng phân chia (lỗi dữ liệu)
                        errorSpan.text('⚠️ Dữ liệu ca làm việc không đầy đủ hoặc thời lượng khám không xác định.').show();
                        guideSpan.hide();
                    }
                }
            });
        });
    </script>
}