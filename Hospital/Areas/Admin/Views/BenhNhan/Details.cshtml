@model Hospital.Models.BenhNhan

@{
    ViewData["Title"] = "Hồ sơ Bệnh nhân";
}

@* pt-0 giúp đẩy nội dung sát lên trên *@
<div class="container pt-0 pb-4">
    <nav aria-label="breadcrumb" class="mb-2">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none text-muted small">Danh sách</a></li>
            <li class="breadcrumb-item active small fw-bold text-dark" aria-current="page">Hồ sơ chi tiết</li>
        </ol>
    </nav>

    <div class="row g-4">
        @* --- CỘT TRÁI: THÔNG TIN ĐỊNH DANH VÀ TÁC VỤ --- *@
        <div class="col-md-4 col-lg-3">
            <div class="card border-0 shadow rounded-4 text-center h-100">
                <div class="card-body p-4 d-flex flex-column align-items-center">

                    @* 1. Avatar *@
                    <div class="avatar-initial rounded-circle bg-primary bg-gradient text-white fw-bold d-flex justify-content-center align-items-center mb-3 shadow-sm"
                         style="width: 100px; height: 100px; font-size: 2.5rem;">
                        @Model.HoTen.Substring(0, 1).ToUpper()
                    </div>

                    @* 2. Tên và Mã BN *@
                    <h4 class="fw-bold text-dark mb-1">@Model.HoTen</h4>
                    <span class="badge bg-light text-primary border border-primary border-opacity-25 rounded-pill mb-3">
                        Mã BN: #@Model.BenhNhanId
                    </span>

                    @* 3. ĐƯA SỐ ĐIỆN THOẠI LÊN TRÊN *@
                    <div class="w-100 py-2 mb-3 bg-light rounded-3 border">
                        <small class="text-muted d-block text-uppercase" style="font-size: 0.7rem; letter-spacing: 1px;">Số điện thoại</small>
                        <span class="fw-bold fs-5 text-primary">@Model.SoDienThoai</span>
                    </div>

                    @* 4. ĐƯA CÁC NÚT HÀNH ĐỘNG LÊN TRÊN *@
                    <div class="d-grid gap-2 w-100">
                        <a asp-action="Edit" asp-route-id="@Model.BenhNhanId" class="btn btn-primary rounded-pill shadow-sm py-2">
                            <i class="bi bi-pencil-square me-2"></i>Chỉnh sửa
                        </a>

                        <button class="btn btn-outline-secondary rounded-pill py-2" disabled title="Tính năng đang phát triển">
                            <i class="bi bi-clock-history me-2"></i>Lịch sử khám
                        </button>
                    </div>

                    @* (Tùy chọn) Thêm một dòng nhỏ dưới cùng để cân đối Card *@
                    <div class="mt-4 pt-3 border-top w-100 text-muted" style="font-size: 0.8rem;">
                        <i class="bi bi-info-circle me-1"></i> Thông tin cơ bản
                    </div>
                </div>
            </div>
        </div>

        @* --- CỘT PHẢI: THÔNG TIN CHI TIẾT --- *@
        <div class="col-md-8 col-lg-9">
            <div class="card border-0 shadow rounded-4">
                <div class="card-header bg-white border-bottom p-4 rounded-top-4">
                    <h5 class="fw-bold mb-0 text-primary"><i class="bi bi-person-lines-fill me-2"></i>Thông tin chi tiết</h5>
                </div>
                <div class="card-body p-4">

                    @* NHÓM 1: THÔNG TIN CÁ NHÂN *@
                    <h6 class="text-uppercase text-muted small fw-bold mb-3">Thông tin cá nhân</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-sm-6 col-md-4">
                            <div class="p-3 bg-light rounded-3 h-100">
                                <small class="text-muted d-block mb-1"><i class="bi bi-calendar3 me-1"></i>Ngày sinh</small>
                                <span class="fw-semibold">@(Model.NgaySinh.HasValue ? Model.NgaySinh.Value.ToString("dd/MM/yyyy") : "---")</span>
                            </div>
                        </div>
                        <div class="col-sm-6 col-md-4">
                            <div class="p-3 bg-light rounded-3 h-100">
                                <small class="text-muted d-block mb-1"><i class="bi bi-gender-ambiguous me-1"></i>Giới tính</small>
                                <span class="fw-semibold">@(Model.GioiTinh ?? "---")</span>
                            </div>
                        </div>
                        <div class="col-sm-12 col-md-4">
                            <div class="p-3 bg-light rounded-3 h-100">
                                <small class="text-muted d-block mb-1"><i class="bi bi-envelope me-1"></i>Email</small>
                                <span class="fw-semibold text-break">@(Model.Email ?? "Chưa cập nhật")</span>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="p-3 bg-light rounded-3">
                                <small class="text-muted d-block mb-1"><i class="bi bi-geo-alt-fill me-1"></i>Địa chỉ</small>
                                <span class="fw-semibold">@(Model.DiaChi ?? "Chưa cập nhật")</span>
                            </div>
                        </div>
                    </div>

                    <hr class="text-muted opacity-25 my-4">

                    @* NHÓM 2: Y TẾ & GHI CHÚ *@
                    <h6 class="text-uppercase text-danger small fw-bold mb-3"><i class="bi bi-heart-pulse me-1"></i>Thông tin Y tế (Da liễu)</h6>

                    <div class="row g-3">
                        <div class="col-12">
                            @if (!string.IsNullOrEmpty(Model.TienSuBenh))
                            {
                                <div class="alert alert-warning border-warning border-opacity-50 rounded-3 mb-0 py-2">
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-exclamation-triangle-fill fs-4 me-3 text-warning"></i>
                                        <div>
                                            <strong class="d-block text-dark small text-uppercase">Tiền sử bệnh / Dị ứng:</strong>
                                            <span class="fw-bold">@Model.TienSuBenh</span>
                                        </div>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="p-3 border border-dashed rounded-3 text-muted fst-italic small text-center">
                                    <i class="bi bi-check2-circle me-1"></i> Không có ghi nhận tiền sử bệnh lý đặc biệt.
                                </div>
                            }
                        </div>

                        <div class="col-12">
                            <div class="p-3 bg-light rounded-3 border-start border-4 border-secondary">
                                <small class="text-muted fw-bold d-block mb-1 text-uppercase" style="font-size: 0.7rem;">Ghi chú nội bộ</small>
                                @if (!string.IsNullOrEmpty(Model.GhiChu))
                                {
                                    <span class="text-dark">@Model.GhiChu</span>
                                }
                                else
                                {
                                    <span class="text-muted small">Không có ghi chú.</span>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 text-end">
                        <small class="text-muted fst-italic" style="font-size: 0.75rem;">
                            Hồ sơ được tạo ngày: @Model.NgayTao.ToString("dd/MM/yyyy HH:mm")
                        </small>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>