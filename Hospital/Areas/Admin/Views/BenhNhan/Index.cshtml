@model IEnumerable<Hospital.Models.BenhNhan>

@{
    ViewData["Title"] = "Danh sách Bệnh nhân";
    int currentPage = ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages;
}

@* --- CSS ĐỒNG BỘ VỚI TRANG BÁC SĨ --- *@
<style>
    /* Màu trắng ngà xám cho tiêu đề bảng */
    .table thead {
        background-color: #f4f3f0 !important;
        border-bottom: 2px solid #e9ecef;
    }

        .table thead th {
            color: #495057 !important;
            font-size: 0.8rem;
            letter-spacing: 0.5px;
            font-weight: 700 !important;
            text-transform: uppercase;
        }

    /* ĐỒNG BỘ PHÂN TRANG HÌNH TRÒN */
    .pagination .page-item .page-link {
        border-radius: 50% !important;
        margin: 0 4px;
        border: none;
        width: 38px;
        height: 38px;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: #f8f9fa;
        color: #6c757d;
        font-weight: 600;
        transition: all 0.3s;
    }

    .pagination .page-item.active .page-link {
        background-color: #1e3a8a !important; /* Màu xanh Navy đồng bộ Layout */
        color: white !important;
        box-shadow: 0 4px 10px rgba(30, 58, 138, 0.2);
    }

    .pagination .page-item:not(.active):hover .page-link {
        background-color: #e9ecef;
        color: #1e3a8a;
    }

    .pagination .page-item.disabled .page-link {
        background-color: transparent;
        opacity: 0.5;
    }

    /* Avatar & Badge */
    .patient-avatar {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background-color: #e7f5ff;
        color: #1971c2;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        border: 2px solid #fff;
        shadow-sm;
    }

    .custom-total-badge {
        background-color: #f8f9fa;
        color: #495057;
        padding: 6px 16px;
        border-radius: 30px;
        font-weight: 700;
        font-size: 0.85rem;
        border: 1px solid #dee2e6;
    }
</style>

<div class="container-fluid p-0">
    @* --- HEADER --- *@
    <div class="d-flex justify-content-between align-items-center pt-2 pb-3">
        <div>
            <h3 class="text-primary fw-bold mb-0">Hồ sơ Bệnh nhân</h3>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item small"><a href="#" class="text-decoration-none text-muted">Lâm sàng</a></li>
                    <li class="breadcrumb-item active small text-dark fw-bold" aria-current="page">Bệnh nhân</li>
                </ol>
            </nav>
        </div>
        <div class="d-flex align-items-center gap-3">
            <span class="custom-total-badge shadow-sm d-none d-md-inline-block">
                <i class="bi bi-people-fill me-2 text-primary"></i>Tổng: @Model.Count() hồ sơ
            </span>
            <a asp-action="Create" class="btn btn-primary shadow rounded-pill px-4 py-2 fw-bold">
                <i class="bi bi-person-plus-fill me-1"></i> Tiếp nhận mới
            </a>
        </div>
    </div>

    @* --- THANH TÌM KIẾM --- *@
    <div class="card border-0 shadow-sm rounded-4 mb-4 bg-light">
        <div class="card-body p-3">
            <form asp-action="Index" method="get" id="searchForm">
                <div class="input-group">
                    <span class="input-group-text bg-white border-0 ps-3"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" name="searchString" id="searchInput" class="form-control border-0 py-2"
                           placeholder="Gõ Số điện thoại hoặc Tên để lọc nhanh..."
                           value="@ViewBag.SearchString" autocomplete="off">
                    @if (!string.IsNullOrEmpty(ViewBag.SearchString))
                    {
                        <a href="@Url.Action("Index")" class="btn btn-white border-0 text-muted shadow-none"><i class="bi bi-x-lg"></i></a>
                    }
                </div>
            </form>
        </div>
    </div>

  

    @* --- BẢNG DỮ LIỆU --- *@
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4 py-3">Thông tin bệnh nhân</th>
                        <th>Liên hệ</th>
                        <th>Tiền sử / Ghi chú</th>
                        <th class="text-center" style="width: 180px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="patient-avatar me-3 shadow-sm">
                                            @item.HoTen.Substring(0, 1).ToUpper()
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark fs-6">@item.HoTen</div>
                                            <div class="small text-muted mt-1">
                                                <span class="badge bg-light text-dark fw-normal border">@(item.GioiTinh ?? "N/A")</span>
                                                <span class="ms-2">Năm sinh: @(item.NgaySinh.HasValue ? item.NgaySinh.Value.Year.ToString() : "---")</span>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="fw-bold text-primary mb-1"><i class="bi bi-telephone me-1"></i>@item.SoDienThoai</div>
                                    <small class="text-muted d-block text-truncate" style="max-width: 220px;" title="@item.DiaChi">
                                        <i class="bi bi-geo-alt me-1"></i>@(item.DiaChi ?? "Chưa cập nhật địa chỉ")
                                    </small>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.TienSuBenh))
                                    {
                                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 rounded-pill mb-1">
                                            <i class="bi bi-exclamation-triangle me-1"></i>@item.TienSuBenh
                                        </span>

                                        <br>
                                    }
                                    @if (!string.IsNullOrEmpty(item.GhiChu))
                                    {
                                        <small class="text-muted fst-italic"><i class="bi bi-sticky me-1"></i>@item.GhiChu</small>
                                    }
                                </td>
                                <td class="text-center pe-4">
                                    <div class="btn-group shadow-sm rounded-3">
                                        <a asp-area="Admin" asp-controller="HoSoBenhAn" asp-action="Create" asp-route-idBN="@item.BenhNhanId"
                                           class="btn btn-sm btn-white text-success border" title="Tái khám">
                                            <i class="bi bi-file-medical-fill"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.BenhNhanId"
                                           class="btn btn-sm btn-white text-primary border" title="Chỉnh sửa">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.BenhNhanId"
                                           class="btn btn-sm btn-white text-info border" title="Chi tiết">
                                            <i class="bi bi-eye-fill"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.BenhNhanId"
                                           class="btn btn-sm btn-white text-danger border" title="Xóa">
                                            <i class="bi bi-trash-fill"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted fst-italic">
                                <i class="bi bi-search fs-2 d-block mb-2"></i>
                                Không tìm thấy bệnh nhân nào khớp với dữ liệu...
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @* --- PHÂN TRANG (Trang trước / Trang sau) --- *@
        @if (totalPages > 1)
        {
            <div class="card-footer bg-white py-4">
                <nav>
                    <ul class="pagination justify-content-center mb-0">

                        @* Trang trước *@
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <a class="page-link" href="@Url.Action("Index", new { page = currentPage - 1, searchString = ViewBag.SearchString })">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>

                        @* Các số trang *@
                        @for (int i = 1; i <= totalPages; i++)
                        {
                            <li class="page-item @(i == currentPage ? "active" : "")">
                                <a class="page-link shadow-none" href="@Url.Action("Index", new { page = i, searchString = ViewBag.SearchString })">@i</a>
                            </li>
                        }

                        @* Trang sau *@
                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                            <a class="page-link" href="@Url.Action("Index", new { page = currentPage + 1, searchString = ViewBag.SearchString })">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>

                    </ul>
                </nav>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Tự động tắt thông báo
            var alertNode = document.getElementById('successAlert');
            if (alertNode) {
                setTimeout(function () {
                    var alert = new bootstrap.Alert(alertNode);
                    alert.close();
                }, 3000);
            }

            // Tìm kiếm tức thì
            var searchInput = document.getElementById('searchInput');
            var searchForm = document.getElementById('searchForm');
            var typingTimer;
            var doneTypingInterval = 500;

            if(searchInput.value.length > 0){
                 searchInput.focus();
                 var val = searchInput.value;
                 searchInput.value = '';
                 searchInput.value = val;
            }

            searchInput.addEventListener('input', function () {
                clearTimeout(typingTimer);
                typingTimer = setTimeout(function() {
                    searchForm.submit();
                }, doneTypingInterval);
            });
        });
    </script>
}