@model IEnumerable<Hospital.Models.HoSoBenhAn>

@{
    ViewData["Title"] = "Lịch sử khám bệnh";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="text-primary fw-bold mb-0">Lịch sử khám bệnh</h3>
            <p class="text-muted">Bệnh nhân: <span class="text-dark fw-bold">@ViewBag.TenBenhNhan</span></p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill">
            <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Ngày khám</th>
                        <th>Bác sĩ phụ trách</th>
                        <th>Chẩn đoán</th>
                        <th>Trạng thái</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold">@item.NgayKham.ToString("dd/MM/yyyy")</div>
                                    <small class="text-muted">@item.NgayKham.ToString("HH:mm")</small>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-person-badge me-2 text-primary"></i>
                                        <span>@item.BacSi?.HoTen</span>
                                    </div>
                                </td>
                                <td>
                                    <div class="text-truncate" style="max-width: 300px;" title="@item.ChanDoan">
                                        @item.ChanDoan
                                    </div>
                                </td>
                                <td>
                                    @if (item.TrangThai == TrangThaiHoSo.HoanThanh)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-3">Hoàn thành</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning-subtle text-warning border border-warning-subtle rounded-pill px-3">@item.TrangThai</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @* Nút xem chi tiết hồ sơ bệnh án *@
                                    <a asp-controller="HoSoBenhAn" asp-action="Details" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-primary rounded-pill px-3 shadow-sm">
                                        <i class="bi bi-file-earmark-medical me-1"></i> Xem chi tiết
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted fst-italic">
                                <i class="bi bi-folder2-open fs-1 d-block mb-2"></i>
                                Bệnh nhân này chưa có lịch sử khám bệnh nào.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>