@model Hospital.Models.BenhNhan

@{
    ViewData["Title"] = "Xóa Bệnh nhân";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg rounded-4">
                @* --- HEADER CẢNH BÁO --- *@
                <div class="card-header bg-danger bg-gradient text-white p-4 rounded-top-4 text-center">
                    <div class="mb-3">
                        <i class="bi bi-exclamation-triangle-fill" style="font-size: 3rem;"></i>
                    </div>
                    <h4 class="fw-bold text-uppercase mb-1">Xác nhận xóa</h4>
                    <p class="mb-0 opacity-75">Hành động này không thể hoàn tác!</p>
                </div>

                <div class="card-body p-4 p-md-5 text-center">

                    <p class="text-muted mb-4">Bạn có chắc chắn muốn xóa hồ sơ bệnh nhân này khỏi hệ thống?</p>

                    @* --- THÔNG TIN NGƯỜI BỊ XÓA --- *@
                    <div class="bg-light rounded-4 p-4 mb-4 border border-danger border-opacity-25">
                        <div class="avatar-initial rounded-circle bg-danger bg-opacity-10 text-danger fw-bold d-flex justify-content-center align-items-center mx-auto mb-3" style="width: 80px; height: 80px; font-size: 2rem;">
                            @Model.HoTen.Substring(0, 1).ToUpper()
                        </div>

                        <h3 class="fw-bold text-dark mb-1">@Model.HoTen</h3>
                        <div class="badge bg-primary rounded-pill px-3 py-2 fs-6 mb-3">
                            <i class="bi bi-telephone-fill me-1"></i> @Model.SoDienThoai
                        </div>

                        <div class="row text-start mt-3 g-2">
                            <div class="col-6">
                                <small class="text-muted d-block">Ngày sinh</small>
                                <strong>@(Model.NgaySinh.HasValue ? Model.NgaySinh.Value.ToString("dd/MM/yyyy") : "---")</strong>
                            </div>
                            <div class="col-6">
                                <small class="text-muted d-block">Giới tính</small>
                                <strong>@(Model.GioiTinh ?? "---")</strong>
                            </div>
                            <div class="col-12 mt-2">
                                <small class="text-muted d-block">Địa chỉ</small>
                                <span class="text-dark"><i class="bi bi-geo-alt-fill me-1 text-secondary"></i>@(Model.DiaChi ?? "Chưa cập nhật")</span>
                            </div>
                            @if (!string.IsNullOrEmpty(Model.TienSuBenh))
                            {
                                <div class="col-12 mt-3">
                                    <div class="alert alert-warning mb-0 py-2 small">
                                        <i class="bi bi-clipboard-pulse me-1"></i> <strong>Tiền sử:</strong> @Model.TienSuBenh
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    @* --- FORM XÁC NHẬN --- *@
                    <form asp-action="Delete">
                        <input type="hidden" asp-for="BenhNhanId" />

                        <div class="d-flex justify-content-center gap-3">
                            <a asp-action="Index" class="btn btn-light btn-lg rounded-pill px-4 shadow-sm">
                                <i class="bi bi-x-lg me-2"></i>Hủy bỏ
                            </a>
                            <button type="submit" class="btn btn-danger btn-lg rounded-pill px-4 shadow">
                                <i class="bi bi-trash-fill me-2"></i>Xóa ngay
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>