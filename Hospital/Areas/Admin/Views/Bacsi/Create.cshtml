@model Hospital.Models.BacSi
@using Microsoft.AspNetCore.Mvc.Rendering
@inject IHtmlHelper<dynamic> Html

@{
    ViewData["Title"] = "Thêm Bác sĩ mới";
    var userList = (SelectList)ViewData["IdentityUserId"];
    var chuyenKhoaList = (SelectList)ViewData["ChuyenKhoaId"];
}

<form method="post" enctype="multipart/form-data" asp-action="Create">
    <div class="border p-4 mt-4 bg-white shadow-sm rounded">
        <div class="row pb-2">
            <h2 class="text-primary">Thêm Bác sĩ</h2>
            <hr />
        </div>
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="row">
            <div class="col-md-8">
                @* TRƯỜNG 1: IdentityUserId (Tài khoản liên kết) *@
                <div class="mb-3">
                    <label asp-for="IdentityUserId" class="form-label fw-bold">Tài khoản liên kết (Email)</label>
                    @if (userList != null && userList.Any())
                    {
                        <select asp-for="IdentityUserId" asp-items="@userList" class="form-select select2-dropdown">
                            <option value="">-- Nhập Email để tìm kiếm tài khoản --</option>
                        </select>
                        <span asp-validation-for="IdentityUserId" class="text-danger"></span>
                    }
                    else
                    {
                        <p class="text-danger">Không có tài khoản người dùng nào chưa có hồ sơ Bác sĩ để liên kết.</p>
                    }
                </div>

                @* TRƯỜNG 2: ChuyenKhoaId *@
                <div class="mb-3">
                    <label asp-for="ChuyenKhoaId" class="form-label fw-bold">Chuyên khoa</label>
                    <select asp-for="ChuyenKhoaId" asp-items="@chuyenKhoaList" class="form-select select2-dropdown-full">
                        <option value="">-- Chọn Chuyên khoa --</option>
                    </select>
                    <span asp-validation-for="ChuyenKhoaId" class="text-danger"></span>
                </div>

                @* TRƯỜNG 3: HoTen *@
                <div class="mb-3">
                    <label asp-for="HoTen" class="form-label fw-bold">Họ và Tên</label>
                    <input asp-for="HoTen" class="form-control" placeholder="VD: BS. Nguyễn Văn A" />
                    <span asp-validation-for="HoTen" class="text-danger"></span>
                </div>

                @* TRƯỜNG 4: ChuyenMon *@
                <div class="mb-3">
                    <label asp-for="ChuyenMon" class="form-label fw-bold">Chuyên môn</label>
                    <input asp-for="ChuyenMon" class="form-control" placeholder="VD: Da liễu, Nội khoa..." />
                    <span asp-validation-for="ChuyenMon" class="text-danger"></span>
                </div>

                @* TRƯỜNG 5: BangCap *@
                <div class="mb-3">
                    <label asp-for="BangCap" class="form-label fw-bold">Bằng cấp/Chức vụ</label>
                    <input asp-for="BangCap" class="form-control" placeholder="VD: Thạc sĩ, Bác sĩ chuyên khoa I..." />
                    <span asp-validation-for="BangCap" class="text-danger"></span>
                </div>

                @* TRƯỜNG 6: MoTaChiTiet (TinyMCE Editor) *@
                <div class="mb-3">
                    <label asp-for="MoTaChiTiet" class="form-label fw-bold">Mô tả chi tiết và Kinh nghiệm</label>
                    <textarea asp-for="MoTaChiTiet" id="MoTaChiTiet" rows="10" class="form-control"></textarea>
                    <span asp-validation-for="MoTaChiTiet" class="text-danger"></span>
                </div>
            </div>

            <div class="col-md-4">
                @* TRƯỜNG 7: HinhAnhUrl (File Upload) *@
                <div class="card p-3 mb-4 shadow-sm border-0 bg-light">
                    <label class="form-label fw-bold">Ảnh Đại diện</label>
                    <input type="file" name="file" class="form-control" accept="image/*" onchange="previewImage(this)" />
                    <div class="text-center">
                        <img id="preview" src="/images/no-image.png"
                             class="img-thumbnail mt-3 rounded-circle shadow-sm"
                             style="width:180px; height:180px; object-fit:cover;" />
                    </div>
                    <small class="text-muted mt-2 text-center">Nên chọn ảnh vuông, tỉ lệ 1:1</small>
                </div>

                @* TRƯỜNG 8: IsActive (Switch) *@
                <div class="form-check form-switch mb-3 p-3 border rounded shadow-sm d-flex justify-content-between align-items-center bg-white">
                    <label class="form-check-label fw-bold" for="IsActiveSwitch">Trạng thái hoạt động</label>
                    <input class="form-check-input" type="checkbox" role="switch" asp-for="IsActive" id="IsActiveSwitch" checked>
                </div>
            </div>
        </div>

        <div class="mt-4 pt-3 border-top text-end">
            <button type="submit" class="btn btn-primary btn-lg px-5 shadow">
                <i class="bi bi-check-lg me-1"></i> Lưu thông tin
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4 ms-2">
                Hủy bỏ
            </a>
        </div>
    </div>
</form>

@section Scripts {
@* 1. Thư viện Validation cơ bản *@
    <partial name="_ValidationScriptsPartial" />

@* 2. BỔ SUNG: Thư viện Select2 (CSS & JS) - Vì Layout chưa có *@
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

@* 3. Thư viện TinyMCE *@
    <script src="https://cdn.tiny.cloud/1/vy399c75h6gyw1xkemhoj245q01aqnsusy14yaiket9jmz1h/tinymce/6/tinymce.min.js" referrerpolicy="origin"></script>

    <script>
        // Khởi tạo TinyMCE độc lập để tránh bị lỗi bởi các script khác
        tinymce.init({
            selector: 'textarea#MoTaChiTiet',
            height: 450,
            plugins: 'advlist autolink lists link image charmap preview anchor searchreplace visualblocks code fullscreen insertdatetime media table help wordcount',
            toolbar: 'undo redo | blocks | bold italic backcolor | alignleft aligncenter alignright alignjustify | bullist numlist outdent indent | image media table | removeformat | help',

            // Cấu hình upload ảnh trực tiếp
            images_upload_url: '/Admin/BacSi/UploadImageTiny',
            automatic_uploads: true,
            file_picker_types: 'image',

            language: 'vi',
            branding: false,
            placeholder: 'Nhập tiểu sử, quá trình đào tạo và kinh nghiệm làm việc...',

            setup: function (editor) {
                editor.on('change', function () {
                    tinymce.triggerSave(); // Đồng bộ dữ liệu sang textarea để Submit form
                });
            }
        });

        $(document).ready(function () {
            // Khởi tạo Select2 an toàn (chỉ chạy khi thư viện đã load)
            if ($.fn.select2) {
                $('.select2-dropdown, .select2-dropdown-full').select2({
                    theme: 'bootstrap-5',
                    width: '100%',
                    allowClear: true
                });
            }
        });

        // Hàm xử lý xem trước ảnh (Preview)
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById('preview').src = e.target.result;
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}