@model Hospital.Models.BacSi

@{
    ViewData["Title"] = "Chỉnh sửa Thông tin Bác sĩ";
    var userList = (SelectList)ViewData["IdentityUserId"];
}

<form method="post" enctype="multipart/form-data">

    <input asp-for="BacSiId" hidden />
    <input asp-for="HinhAnhUrl" hidden />

    <div class="border p-3 mt-4">
        <div class="row pb-2">
            <h2 class="text-primary">Chỉnh sửa Bác sĩ</h2>
            <hr />
        </div>
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="row">
      
            <div class="col-8">

                <div class="mb-3">
                    <label asp-for="IdentityUserId" class="form-label">Tài khoản liên kết (Email)</label>
                    <select asp-for="IdentityUserId" asp-items="@userList" class="form-select">
                        <option disabled selected>-- Chọn tài khoản --</option>
                    </select>
                    <span asp-validation-for="IdentityUserId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="HoTen"></label>
                    <input asp-for="HoTen" class="form-control" />
                    <span asp-validation-for="HoTen" class="text-danger"></span>
                </div>

           
                <div class="mb-3">
                    <label asp-for="ChuyenMon"></label>
                    <input asp-for="ChuyenMon" class="form-control" />
                    <span asp-validation-for="ChuyenMon" class="text-danger"></span>
                </div>

          
                <div class="mb-3">
                    <label asp-for="BangCap"></label>
                    <input asp-for="BangCap" class="form-control" />
                </div>

            
                <div class="mb-3">
                    <label asp-for="MoTaChiTiet"></label>
                    <textarea asp-for="MoTaChiTiet" rows="5" class="form-control"></textarea>
                </div>

               
                <div class="mb-3">
                    <label for="file" class="form-label">Thay đổi Ảnh Đại diện</label>
                    <input type="file" name="file" id="file" class="form-control" />
                    <small class="text-muted">Để trống nếu không muốn thay đổi ảnh.</small>
                </div>

       
                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" asp-for="IsActive">
                    <label class="form-check-label" asp-for="IsActive"></label>
                </div>

                <button type="submit" class="btn btn-primary" style="width:150px">Cập nhật</button>
                <a asp-controller="BacSi" asp-action="Index" class="btn btn-secondary" style="width:150px">
                    Quay lại Danh sách
                </a>

            </div>


            <div class="col-4">
                @if (Model.HinhAnhUrl != null)
                {
                    <img src="@Model.HinhAnhUrl" style="width: 100%; border-radius: 5px; border: 1px solid #ccc" />
                }
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }
}