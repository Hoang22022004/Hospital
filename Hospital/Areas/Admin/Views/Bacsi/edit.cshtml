@model Hospital.Models.BacSi
@using Microsoft.AspNetCore.Mvc.Rendering
@inject IHtmlHelper<dynamic> Html

@{
    ViewData["Title"] = "Chỉnh sửa Thông tin Bác sĩ";
    var userList = (SelectList)ViewData["IdentityUserId"];
}

<form method="post" enctype="multipart/form-data">

   
    <input asp-for="BacSiId" hidden />
    <input asp-for="HinhAnhUrl" hidden />

    <div class="border p-4 mt-4 bg-white shadow-sm rounded">
        <div class="row pb-2">
            <h2 class="text-primary">Chỉnh sửa Bác sĩ</h2>
            <hr />
        </div>
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="row">

            
            <div class="col-md-8">

                @* TRƯỜNG 1: IdentityUserId (Sử dụng Select2) *@
                <div class="mb-3">
                    <label asp-for="IdentityUserId" class="form-label">Tài khoản liên kết (Email)</label>
                    <select asp-for="IdentityUserId" asp-items="@userList" class="form-select select2-dropdown">
                        <option value="">-- Nhập Email để tìm kiếm tài khoản --</option>
                    </select>
                    <span asp-validation-for="IdentityUserId" class="text-danger"></span>
                </div>

                @* TRƯỜNG 2: HoTen (Sử dụng cấu trúc mb-3 cơ bản) *@
                <div class="mb-3">
                    <label asp-for="HoTen" class="form-label"></label>
                    <input asp-for="HoTen" class="form-control" />
                    <span asp-validation-for="HoTen" class="text-danger"></span>
                </div>

                @* TRƯỜNG 3: ChuyenMon (Sử dụng cấu trúc mb-3 cơ bản) *@
                <div class="mb-3">
                    <label asp-for="ChuyenMon" class="form-label"></label>
                    <input asp-for="ChuyenMon" class="form-control" />
                    <span asp-validation-for="ChuyenMon" class="text-danger"></span>
                </div>

                @* TRƯỜNG 4: BangCap (Sử dụng cấu trúc mb-3 cơ bản) *@
                <div class="mb-3">
                    <label asp-for="BangCap" class="form-label"></label>
                    <input asp-for="BangCap" class="form-control" />
                    <span asp-validation-for="BangCap" class="text-danger"></span>
                </div>

                @* TRƯỜNG 5: MoTaChiTiet (TinyMCE Editor) *@
                <div class="mb-3">
                    <label asp-for="MoTaChiTiet" class="form-label">Mô tả chi tiết và Kinh nghiệm</label>
                    <textarea asp-for="MoTaChiTiet" id="MoTaChiTiet" rows="10" class="form-control"></textarea>
                </div>

            </div>

        
            <div class="col-md-4">

                @* TRƯỜNG 6: Thay đổi HinhAnhUrl (File Upload) *@
                <div class="card p-3 mb-4 shadow-sm">
                    <label for="file" class="form-label">Thay đổi Ảnh Đại diện</label>
                    <input type="file" name="file" id="file" class="form-control" />
                    <small class="text-muted">Để trống nếu không muốn thay đổi ảnh.</small>

                   
                    @if (!string.IsNullOrEmpty(Model.HinhAnhUrl))
                    {
                        <p class="mt-3 mb-0 text-muted">Ảnh hiện tại:</p>
                        <img src="@Model.HinhAnhUrl" class="img-thumbnail mt-2 rounded-circle shadow-sm" style="width:100%; height:auto; object-fit:cover; max-height:250px;" />
                    }
                </div>

                @* TRƯỜNG 7: IsActive (Switch - Bố cục đã sửa) *@
                <div class="form-check form-switch mb-3 p-3 border rounded shadow-sm d-flex justify-content-between align-items-center">
                    <label class="form-check-label" for="IsActiveSwitch">Kích hoạt hồ sơ</label>
                    <input class="form-check-input" type="checkbox" role="switch" asp-for="IsActive" id="IsActiveSwitch">
                </div>

            </div>
        </div>

        @* Nút Submit và Quay lại -- ĐÃ ĐỔI TỪ THÊM SANG CẬP NHẬT --*@
        <div class="mt-4 pt-3 border-top text-end">
            <button type="submit" class="btn btn-primary btn-lg shadow-lg" style="width:180px">
                <i class="bi bi-arrow-up-circle"></i> Cập nhật
            </button>
            <a asp-controller="BacSi" asp-action="Index" class="btn btn-secondary btn-lg" style="width:180px">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
        </div>
    </div>
</form>

@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }

    <script>
        $(document).ready(function () {

            // 1. Kích hoạt Select2 (Sử dụng theme Bootstrap 5 mới)
            $('.select2-dropdown').select2({
                placeholder: "Nhập Email để tìm kiếm tài khoản",
                allowClear: true,
                theme: 'bootstrap-5'
            });

            // 2. Kích hoạt TinyMCE (Trình soạn thảo nâng cao)
            tinymce.init({
                selector: 'textarea#MoTaChiTiet',
                plugins: 'lists link image code help wordcount table',
                toolbar: 'undo redo | formatselect | bold italic underline | alignleft aligncenter alignright alignjustify | bullist numlist outdent indent | link image table | code',
                height: 300
                // Không truyền apiKey vì đã dùng link CDN 'no-api-key' trong Layout
            });
        });
    </script>
}