@model Hospital.Models.BacSi

@{
    ViewData["Title"] = "Xác nhận Xóa Bác sĩ";
}

<div class="border p-3 mt-4 bg-white shadow-sm rounded">
    <div class="row pb-2">
        <h2 class="text-danger">Xác nhận Xóa Bác sĩ</h2>
        <hr />
    </div>

    <div class="alert alert-warning" role="alert">
        <i class="bi bi-exclamation-triangle-fill"></i>
        **CẢNH BÁO:** Bạn sắp xóa hồ sơ bác sĩ **@Model.HoTen** (Chuyên khoa: **@Model.ChuyenKhoa.TenChuyenKhoa**) liên kết với tài khoản **@Model.User.Email**. Thao tác này **không thể hoàn tác** và ảnh đại diện sẽ bị xóa khỏi hệ thống.
    </div>

    <form method="post" asp-action="Delete">

        <input asp-for="BacSiId" hidden />

        <div class="row">

            <div class="col-8">

                <div class="mb-3">
                    <label asp-for="HoTen" class="form-label"></label>
                    <input asp-for="HoTen" class="form-control" disabled />
                </div>

                {{-- ĐÃ THÊM: Chuyên khoa --}}
                <div class="mb-3">
                    <label>Chuyên khoa</label>
                    <input value="@(Model.ChuyenKhoa?.TenChuyenKhoa ?? "Không xác định")" class="form-control" disabled />
                </div>

                {{-- ĐÃ THÊM: Bằng cấp --}}
                <div class="mb-3">
                    <label asp-for="BangCap" class="form-label"></label>
                    <input asp-for="BangCap" class="form-control" disabled />
                </div>

                <div class="mb-3">
                    <label asp-for="ChuyenMon" class="form-label"></label>
                    <input asp-for="ChuyenMon" class="form-control" disabled />
                </div>

                <div class="mb-3">
                    <label>Tài khoản liên kết</label>
                    <input value="@(Model.User?.Email ?? "Không có")" class="form-control" disabled />
                </div>

                <div class="mb-3">
                    <label asp-for="MoTaChiTiet" class="form-label"></label>
                    <textarea asp-for="MoTaChiTiet" rows="5" class="form-control" disabled></textarea>
                </div>

                <div class="mt-4 pt-3 border-top text-end">
                    <button type="submit" class="btn btn-danger btn-lg shadow-lg" style="width:180px">
                        <i class="bi bi-trash-fill"></i> Xóa vĩnh viễn
                    </button>
                    <a asp-controller="BacSi" asp-action="Index" class="btn btn-secondary btn-lg" style="width:180px">
                        <i class="bi bi-arrow-left"></i> Quay lại
                    </a>
                </div>
            </div>


            <div class="col-4 text-center">
                @if (Model.HinhAnhUrl != null)
                {
                    <label class="d-block mb-3">Ảnh Đại diện</label>
                    <img src="@Model.HinhAnhUrl" style="width: 100%; max-width: 250px; border-radius: 5px; border: 1px solid #ccc" class="shadow-sm" alt="Ảnh Bác sĩ" />
                }
            </div>
        </div>
    </form>
</div>