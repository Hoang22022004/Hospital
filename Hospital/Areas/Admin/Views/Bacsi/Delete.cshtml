@model Hospital.Models.BacSi

@{
    ViewData["Title"] = "Xác nhận Xóa Bác sĩ";
}

<div class="border p-3 mt-4">
    <div class="row pb-2">
        <h2 class="text-danger">Xác nhận Xóa Bác sĩ</h2>
        <hr />
    </div>

    <div class="alert alert-warning" role="alert">
        <i class="bi bi-exclamation-triangle-fill"></i>
        **CẢNH BÁO:** Bạn sắp xóa hồ sơ bác sĩ **@Model.HoTen** liên kết với tài khoản **@Model.User.Email**. Thao tác này **không thể hoàn tác** và ảnh đại diện sẽ bị xóa khỏi hệ thống.
    </div>

    <form method="post" asp-action="Delete">
        {{-- Gửi ID Bác sĩ lên Controller để xóa --}}
        <input asp-for="BacSiId" hidden />

        <div class="row">
            {{-- Cột 1: Hiển thị thông tin chi tiết --}}
            <div class="col-8">

                <div class="mb-3">
                    <label asp-for="HoTen" class="form-label"></label>
                    <input asp-for="HoTen" class="form-control" disabled />
                </div>

                <div class="mb-3">
                    <label asp-for="ChuyenMon" class="form-label"></label>
                    <input asp-for="ChuyenMon" class="form-control" disabled />
                </div>

                <div class="mb-3">
                    <label>Tài khoản liên kết</label>
                    <input value="@(Model.User?.Email ?? "Không có")" class="form-control" disabled />
                </div>

                <div class="mb-3">
                    <label asp-for="MoTaChiTiet" class="form-label"></label>
                    <textarea asp-for="MoTaChiTiet" rows="5" class="form-control" disabled></textarea>
                </div>

                <button type="submit" class="btn btn-danger" style="width:150px">
                    <i class="bi bi-trash-fill"></i> Xóa vĩnh viễn
                </button>
                <a asp-controller="BacSi" asp-action="Index" class="btn btn-secondary" style="width:150px">
                    <i class="bi bi-arrow-left"></i> Quay lại
                </a>
            </div>

            {{-- Cột 2: Hiển thị ảnh hiện tại --}}
            <div class="col-4">
                @if (Model.HinhAnhUrl != null)
                {
                    <label>Ảnh Đại diện</label>
                    <img src="@Model.HinhAnhUrl" style="width: 100%; border-radius: 5px; border: 1px solid #ccc" />
                }
            </div>
        </div>
    </form>
</div>