@model IEnumerable<Hospital.Models.BacSi>

@{
    ViewData["Title"] = "Quản lý Bác sĩ";
}


<div class="row mb-2">
    <div class="col-md-4">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-auto">
                        <i class="bi bi-people-fill text-primary display-6"></i>
                    </div>
                    <div class="col">
                        <h6 class="text-uppercase text-muted mb-0">Tổng số Bác sĩ</h6>
                        <span class="h4 mb-0">@Model.Count()</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid p-0">
    <div class="row pt-2 align-items-center">
        
        <div class="col-6">
            <h2 class="text-primary mb-0">Danh sách bác sĩ</h2>
        </div>
        <div class="col-6 text-end">
            <a asp-controller="BacSi" asp-action="Create" class="btn btn-primary shadow-sm">
                <i class="bi bi-plus-circle"></i> &nbsp; Thêm Bác sĩ mới
            </a>
        </div>
    </div>
    <hr class="mt-2 mb-4" />

    <table id="tblData" class="table table-striped table-hover" style="width:100%">
        <thead>
            <tr>
                <th style="width: 100px;">Ảnh</th>
                <th>Tên Bác sĩ & Bằng cấp</th>
                <th>Chuyên môn</th>
                <th>Email Liên kết</th>
                <th>Trạng thái</th>
                <th style="width: 150px;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var obj in Model)
            {
                <tr>
                    <td>
                        @if (!string.IsNullOrEmpty(obj.HinhAnhUrl))
                        {
                            <img src="@obj.HinhAnhUrl" class="rounded-circle shadow-sm" style="width: 80px; height: 80px; object-fit: cover;" alt="Ảnh Bác sĩ" />
                        }
                    </td>
                    <td style="vertical-align: middle;">
                        <strong class="text-dark">@obj.HoTen</strong>
                        <br />
                        <span class="text-muted small">(@obj.BangCap)</span>
                    </td>
                    <td style="vertical-align: middle;">@obj.ChuyenMon</td>
                    <td style="vertical-align: middle;">
                        @if (obj.User != null)
                        {
                            <span class="text-info">@obj.User.Email</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Thiếu User</span>
                        }
                    </td>
                    <td style="vertical-align: middle;">
                        @if (obj.IsActive)
                        {
                            <span class="badge rounded-pill bg-success">Hoạt động</span>
                        }
                        else
                        {
                            <span class="badge rounded-pill bg-secondary">Tạm ẩn</span>
                        }
                    </td>
                    <td style="vertical-align: middle;">
                        <div class="btn-group" role="group">
                            <a asp-controller="BacSi" asp-action="Edit" asp-route-id="@obj.BacSiId" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil-square"></i> Sửa
                            </a>
                            <a asp-controller="BacSi" asp-action="Delete" asp-route-id="@obj.BacSiId" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash-fill"></i> Xóa
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
     
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.bootstrap5.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#tblData').DataTable({
                "language": {
                    "url": "/js/i18n/vi.json"
                },
                "lengthMenu": [[10, 25, 50, -1], [10, 25, 50, "Tất cả"]],
                "pagingType": "full_numbers",

                // 🛑 THÊM OPTION NÀY ĐỂ BỎ THÔNG TIN ĐẾM DÒNG
                "info": false
            });
        });
    </script>
}