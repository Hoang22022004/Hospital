@model Hospital.Models.Thuoc

@{
    ViewData["Title"] = "Xóa Thuốc";
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-center pt-5">
        <div class="col-md-8">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                @* HEADER CẢNH BÁO *@
                <div class="card-header bg-danger text-white py-3 text-center">
                    <h4 class="fw-bold mb-0"><i class="bi bi-exclamation-triangle-fill me-2"></i>Xác nhận xóa sản phẩm</h4>
                </div>

                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <p class="fs-5 text-muted">Bạn có chắc chắn muốn xóa thuốc này khỏi hệ thống?</p>
                        <p class="text-danger fw-bold small">Hành động này không thể hoàn tác!</p>
                    </div>

                    <div class="row align-items-center mb-4">
                        @* ẢNH *@
                        <div class="col-md-4 text-center">
                            @if (!string.IsNullOrEmpty(Model.HinhAnhUrl))
                            {
                                <img src="@Model.HinhAnhUrl" class="img-fluid rounded-3 shadow-sm border" style="max-height: 180px;" />
                            }
                            else
                            {
                                <div class="bg-light rounded-3 d-flex align-items-center justify-content-center border" style="height: 150px;">
                                    <span class="text-muted">Không có ảnh</span>
                                </div>
                            }
                        </div>

                        @* THÔNG TIN (READONLY) *@
                        <div class="col-md-8">
                            <div class="mb-3">
                                <label class="fw-bold text-secondary small">Tên thuốc</label>
                                <input asp-for="TenThuoc" class="form-control bg-white fw-bold text-dark" disabled />
                            </div>
                            <div class="row">
                                <div class="col-6 mb-3">
                                    <label class="fw-bold text-secondary small">Hoạt chất</label>
                                    <input asp-for="HoatChat" class="form-control bg-white" disabled />
                                </div>
                                <div class="col-6 mb-3">
                                    <label class="fw-bold text-secondary small">Tồn kho</label>
                                    <input asp-for="SoLuongTon" class="form-control bg-white" disabled />
                                </div>
                            </div>
                        </div>
                    </div>

                    @* BUTTONS *@
                    <form method="post" asp-action="Delete">
                        <input type="hidden" asp-for="ThuocId" />
                        <div class="row">
                            <div class="col-6">
                                <a asp-action="Index" class="btn btn-light btn-lg w-100 rounded-pill border">
                                    Hủy bỏ
                                </a>
                            </div>
                            <div class="col-6">
                                <button type="submit" class="btn btn-danger btn-lg w-100 rounded-pill shadow-sm">
                                    <i class="bi bi-trash-fill me-2"></i>Xóa ngay
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>