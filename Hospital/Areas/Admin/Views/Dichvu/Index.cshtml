@model IEnumerable<Hospital.Models.DichVu>

@{
    ViewData["Title"] = "Quản lý Dịch vụ";
}

<style>
    /* CSS để giới hạn số dòng và hiện dấu ... */
    .text-ellipsis-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2; /* Số dòng muốn hiển thị */
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
        word-break: break-word;
        max-width: 250px; /* Độ rộng tối đa của cột mô tả */
    }

    .no-wrap-header {
        white-space: nowrap;
    }
</style>

<div class="container p-3">
    <div class="row pt-4 align-items-center">
        <div class="col-6">
            <h2 class="text-primary mb-0">Danh sách Dịch vụ</h2>
        </div>
        <div class="col-6 text-end">
            <a asp-controller="DichVu" asp-action="Create" class="btn btn-primary shadow-sm">
                <i class="bi bi-plus-circle"></i> &nbsp; Thêm Dịch vụ mới
            </a>
        </div>
    </div>
    <hr class="mt-2 mb-4" />

    @if (Model.Any())
    {
        <table id="tblData" class="table table-bordered table-striped" style="width:100%">
            <thead>
                <tr>
                    <th width="15%" class="no-wrap-header">@Html.DisplayNameFor(model => model.TenDichVu)</th>
                    <th width="10%" class="no-wrap-header text-center">@Html.DisplayNameFor(model => model.AnhDichVuUrl)</th>
                    <th width="15%" class="no-wrap-header">Chuyên khoa</th>
                    <th width="20%" class="no-wrap-header">@Html.DisplayNameFor(model => model.MoTaNgan)</th>
                    <th width="10%" class="no-wrap-header">@Html.DisplayNameFor(model => model.Gia)</th>
                    <th width="10%" class="no-wrap-header">@Html.DisplayNameFor(model => model.IsActive)</th>
                    <th width="20%" class="no-wrap-header">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var obj in Model)
                {
                    <tr>
                        <td style="vertical-align: middle;">@obj.TenDichVu</td>
                        <td class="text-center" style="vertical-align: middle;">
                            @if (!string.IsNullOrEmpty(obj.AnhDichVuUrl))
                            {
                                <img src="@obj.AnhDichVuUrl" style="width: 60px; height: 60px; object-fit: cover; border-radius: 5px;" />
                            }
                        </td>
                        <td style="vertical-align: middle;">
                            @if (obj.ChuyenKhoaDichVus != null && obj.ChuyenKhoaDichVus.Any())
                            {
                                @foreach (var link in obj.ChuyenKhoaDichVus)
                                {
                                    <span class="badge bg-primary me-1 mb-1" style="font-size: 0.75rem;">@link.ChuyenKhoa.TenChuyenKhoa</span>
                                }
                            }
                            else
                            {
                                <span class="badge bg-secondary">Chưa gán</span>
                            }
                        </td>
                        <td style="vertical-align: middle;">
                            <div class="text-ellipsis-2" title="@obj.MoTaNgan">
                                @obj.MoTaNgan
                            </div>
                        </td>
                        <td style="vertical-align: middle; white-space: nowrap;">@obj.Gia.ToString("N0") VNĐ</td>
                        <td class="text-center" style="vertical-align: middle;">
                            @if (obj.IsActive)
                            {
                                <span class="badge bg-success"><i class="bi bi-check-circle"></i></span>
                            }
                            else
                            {
                                <span class="badge bg-danger"><i class="bi bi-x-circle"></i></span>
                            }
                        </td>
                        <td style="vertical-align: middle;">
                            <div class="btn-group" role="group">
                                <a asp-controller="DichVu" asp-action="Edit" asp-route-id="@obj.DichVuId" class="btn btn-primary btn-sm mx-1 shadow-sm">
                                    <i class="bi bi-pencil-square"></i> Sửa
                                </a>
                                <a asp-controller="DichVu" asp-action="Delete" asp-route-id="@obj.DichVuId" class="btn btn-danger btn-sm mx-1 shadow-sm">
                                    <i class="bi bi-trash-fill"></i> Xóa
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-warning text-center">Không có dịch vụ nào tồn tại.</div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            initializeDataTable('tblData', {
                "order": [[0, 'asc']]
            });
        });
    </script>
}