@model Hospital.Models.DichVu
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Chỉnh sửa Dịch vụ";
    var anhDichVuUrl = Model.AnhDichVuUrl;
    // Lấy danh sách Chuyên khoa đã được Controller chuẩn bị
    var chuyenKhoaList = (List<SelectListItem>)ViewData["ChuyenKhoaList"];
}

<form method="post" enctype="multipart/form-data" asp-action="Edit">

    <input asp-for="DichVuId" hidden />
    <input asp-for="AnhDichVuUrl" hidden />

    <div class="border p-3 mt-4 bg-white shadow-sm rounded">
        <div class="row pb-2">
            <h2 class="text-primary">Chỉnh sửa Dịch vụ</h2>
            <hr />
        </div>
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="row">
            <div class="col-md-8">
                <div class="mb-3">
                    <label asp-for="TenDichVu" class="form-label fw-bold"></label>
                    <input asp-for="TenDichVu" class="form-control" />
                    <span asp-validation-for="TenDichVu" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Gia" class="form-label fw-bold"></label>
                    <input asp-for="Gia" class="form-control" />
                    <span asp-validation-for="Gia" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="MoTaNgan" class="form-label fw-bold"></label>
                    <textarea asp-for="MoTaNgan" rows="3" class="form-control"></textarea>
                </div>

                <div class="mb-3">
                    <label asp-for="MoTaChiTiet" class="form-label fw-bold"></label>
                    <textarea asp-for="MoTaChiTiet" id="MoTaChiTiet" rows="5" class="form-control"></textarea>
                </div>

                <div class="mb-3">
                    <label for="file" class="form-label fw-bold">Tải lên ảnh đại diện mới (Để trống nếu giữ nguyên)</label>
                    <input type="file" name="file" id="file" class="form-control" accept="image/*" />
                </div>

                <div class="form-check form-switch mb-3 p-3 border rounded d-flex justify-content-between align-items-center">
                    <label class="form-check-label fw-bold" asp-for="IsHot">@Html.DisplayNameFor(m => m.IsHot)</label>
                    <input class="form-check-input" type="checkbox" role="switch" asp-for="IsHot">
                </div>

                <div class="form-check form-switch mb-3 p-3 border rounded d-flex justify-content-between align-items-center">
                    <label class="form-check-label fw-bold" asp-for="IsActive">@Html.DisplayNameFor(m => m.IsActive)</label>
                    <input class="form-check-input" type="checkbox" role="switch" asp-for="IsActive">
                </div>
            </div>

            <div class="col-md-4">
                <div class="card p-3 mb-4 shadow-sm border-info">
                    <h5 class="card-title text-info mb-3"><i class="bi bi-tags"></i> Liên kết Chuyên khoa</h5>
                    @if (chuyenKhoaList != null && chuyenKhoaList.Any())
                    {
                        <div class="d-flex flex-column" style="max-height: 250px; overflow-y: auto;">
                            @foreach (var item in chuyenKhoaList)
                            {
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="selectedChuyenKhoaIds" value="@item.Value" id="ck_@item.Value" @(item.Selected ? "checked" : "")>
                                    <label class="form-check-label" for="ck_@item.Value">@item.Text</label>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-danger">Vui lòng tạo chuyên khoa trước khi liên kết dịch vụ.</p>
                    }
                </div>

                @if (!string.IsNullOrEmpty(anhDichVuUrl))
                {
                    <div class="card p-2 shadow-sm">
                        <p class="text-muted fw-bold mb-2">Ảnh hiện tại:</p>
                        <img src="@anhDichVuUrl" width="100%" class="img-thumbnail" style="border-radius:5px; object-fit: cover;" />
                    </div>
                }
            </div>
        </div>

        <div class="mt-4 pt-3 border-top text-end">
            <button type="submit" class="btn btn-primary btn-lg shadow-lg" style="width:200px">
                <i class="bi bi-arrow-up-circle"></i> Cập nhật
            </button>
            <a asp-controller="DichVu" asp-action="Index" class="btn btn-secondary btn-lg" style="width:200px">
                <i class="bi bi-arrow-left"></i> Quay lại Danh sách
            </a>
        </div>
    </div>
</form>

@section Scripts {
    <script src="https://cdn.tiny.cloud/1/vy399c75h6gyw1xkemhoj245q01aqnsusy14yaiket9jmz1h/tinymce/6/tinymce.min.js" referrerpolicy="origin"></script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        tinymce.init({
            selector: 'textarea#MoTaChiTiet',
            height: 500,
            plugins: 'advlist autolink lists link image charmap preview anchor searchreplace visualblocks code fullscreen insertdatetime media table help wordcount',
            toolbar: 'undo redo | blocks | bold italic backcolor | alignleft aligncenter alignright alignjustify | bullist numlist outdent indent | image media table | removeformat | help',

            // Cấu hình upload ảnh trực tiếp vào nội dung
            images_upload_url: '/Admin/DichVu/UploadImageTiny',
            automatic_uploads: true,
            file_picker_types: 'image',

            language: 'vi',
            branding: false,
            placeholder: 'Chỉnh sửa nội dung chi tiết dịch vụ tại đây...'
        });
    </script>
}