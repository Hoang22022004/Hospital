@model Hospital.Models.DichVu

@{
    ViewData["Title"] = "Chỉnh sửa Dịch vụ";
    // Tách form thành 2 cột để hiển thị ảnh cũ
    var anhDichVuUrl = Model.AnhDichVuUrl;
}

@* QUAN TRỌNG: Thêm enctype="multipart/form-data" cho phép upload file *@
<form method="post" enctype="multipart/form-data">
    @* Quan trọng: Thêm trường ẩn để gửi ID của đối tượng *@
    <input asp-for="DichVuId" hidden />
    @* LƯU Ý: Lưu URL ảnh cũ vào trường ẩn để Controller biết mà xóa/giữ lại *@
    <input asp-for="AnhDichVuUrl" hidden />

    <div class="border p-3 mt-4">
        <div class="row pb-2">
            <h2 class="text-primary">Chỉnh sửa Dịch vụ</h2>
            <hr />
        </div>
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="row">
            <div class="col-8">
                @* CỘT FORM CHÍNH *@

                <div class="mb-3">
                    <label asp-for="TenDichVu"></label>
                    <input asp-for="TenDichVu" class="form-control" />
                    <span asp-validation-for="TenDichVu" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Gia"></label>
                    <input asp-for="Gia" class="form-control" />
                    <span asp-validation-for="Gia" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="MoTaNgan"></label>
                    <textarea asp-for="MoTaNgan" rows="3" class="form-control"></textarea>
                </div>

                <div class="mb-3">
                    <label asp-for="MoTaChiTiet"></label>
                    <textarea asp-for="MoTaChiTiet" rows="5" class="form-control"></textarea>
                </div>

                @* TRƯỜNG FILE UPLOAD MỚI *@
                <div class="mb-3">
                    <label for="file" class="form-label">Tải lên ảnh mới (Để trống nếu không thay đổi)</label>
                    <input type="file" name="file" id="file" class="form-control" />
                </div>

                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" asp-for="IsHot">
                    <label class="form-check-label" asp-for="IsHot"></label>
                </div>

                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" asp-for="IsActive">
                    <label class="form-check-label" asp-for="IsActive"></label>
                </div>

            </div> @* Hết col-8 *@

            <div class="col-4">
                @* CỘT HIỂN THỊ ẢNH CŨ *@
                @if (!string.IsNullOrEmpty(anhDichVuUrl))
                {
                    <p class="text-muted">Ảnh đang dùng:</p>
                    <img src="@anhDichVuUrl" width="100%" style="border-radius:5px; border:1px solid #bbb9b9" />
                }
            </div> @* Hết col-4 *@
        </div> @* Hết row *@

        <div class="mt-3">
            <button type="submit" class="btn btn-primary" style="width:150px">Cập nhật</button>
            <a asp-controller="DichVu" asp-action="Index" class="btn btn-secondary" style="width:150px">
                Quay lại Danh sách
            </a>
        </div>
    </div>
</form>

@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }
}