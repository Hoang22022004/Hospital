@model Hospital.Models.ChuyenKhoa
@{
    ViewData["Title"] = "Xóa Chuyên khoa";
}

<form method="post" asp-action="Delete">

    {{-- Trường ẩn để gửi ID đến Action DeletePOST --}}
    <input asp-for="ChuyenKhoaId" hidden />

    <div class="border p-4 mt-4 bg-white shadow-sm rounded">
        <div class="row pb-2">
            <h2 class="text-danger">Xóa Chuyên khoa</h2>
            <hr />
        </div>

        <div class="alert alert-warning" role="alert">
            <h4 class="alert-heading"><i class="bi bi-exclamation-triangle-fill"></i> Cảnh báo!</h4>
            <p>Bạn có chắc chắn muốn xóa chuyên khoa này không? Thao tác này không thể hoàn tác.</p>
            <p class="mb-0">Nếu chuyên khoa đang được Bác sĩ sử dụng, hệ thống sẽ **ngăn chặn** việc xóa này.</p>
        </div>

      
        <div class="mb-3">
            <label asp-for="TenChuyenKhoa" class="form-label"></label>
            <input asp-for="TenChuyenKhoa" disabled class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="MoTa" class="form-label"></label>
            <textarea asp-for="MoTa" rows="3" disabled class="form-control"></textarea>
        </div>

        <div class="mt-4 pt-3 border-top text-end">
            <button type="submit" class="btn btn-danger btn-lg shadow-lg" style="width:200px">
                <i class="bi bi-trash-fill"></i> Xóa Chuyên khoa
            </button>
            <a asp-controller="ChuyenKhoa" asp-action="Index" class="btn btn-secondary btn-lg" style="width:180px">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
        </div>
    </div>
</form>