@model IEnumerable<Hospital.Models.ChuyenKhoa>

@{
    ViewData["Title"] = "Quản lý Chuyên khoa";
}

<div class="container-fluid p-0">
    <div class="row pt-4 align-items-center">
        <div class="col-6">
            <h2 class="text-primary mb-0">Danh sách Chuyên khoa</h2>
        </div>
        <div class="col-6 text-end">
            <a asp-controller="ChuyenKhoa" asp-action="Create" class="btn btn-primary shadow-sm">
                <i class="bi bi-plus-circle"></i> &nbsp; Tạo Chuyên khoa mới
            </a>
        </div>
    </div>
    <hr class="mt-2 mb-4" />

    <table id="tblData" class="table table-striped table-hover" style="width:100%">
        <thead>
            <tr>
                <th>@Html.DisplayNameFor(model => model.TenChuyenKhoa)</th>
                <th>@Html.DisplayNameFor(model => model.MoTa)</th>
                <th style="width: 150px;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var obj in Model)
            {
                <tr>
                    <td>@Html.DisplayFor(modelItem => obj.TenChuyenKhoa)</td>
                    <td>@Html.DisplayFor(modelItem => obj.MoTa)</td>
                    <td>
                        <div class="btn-group" role="group">
                            <a asp-controller="ChuyenKhoa" asp-action="Edit" asp-route-id="@obj.ChuyenKhoaId" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil-square"></i> Sửa
                            </a>
                            <a asp-controller="ChuyenKhoa" asp-action="Delete" asp-route-id="@obj.ChuyenKhoaId" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash-fill"></i> Xóa
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {
            // Khởi tạo DataTables
            $('#tblData').DataTable({
                "language": { "url": "/js/i18n/vi.json" },
                "lengthMenu": [[10, 25, 50, -1], [10, 25, 50, "Tất cả"]],
                "pagingType": "full_numbers",
                "order": [[0, 'asc']] // Sắp xếp theo Tên Chuyên khoa mặc định
            });
        });
    </script>
}