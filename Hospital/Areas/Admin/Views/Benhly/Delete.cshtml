@model Hospital.Models.BenhLy
@{
    ViewData["Title"] = "Xóa bệnh lý";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm border-0">
            <div class="card-body p-5 text-center">
                <div class="text-danger mb-4">
                    <i class="bi bi-exclamation-triangle-fill" style="font-size: 4rem;"></i>
                </div>
                <h4 class="fw-bold text-navy">XÁC NHẬN XÓA BỆNH LÝ?</h4>
                <p class="text-muted">Bạn có chắc chắn muốn xóa bệnh lý <strong>@Model.TenBenhLy</strong> (Mã: @Model.BenhLyId) không? Hành động này không thể hoàn tác.</p>

                <div class="bg-light p-3 rounded mb-4">
                    <img src="@(string.IsNullOrEmpty(Model.HinhAnhUrl) ? "/images/no-image.png" : Model.HinhAnhUrl)" class="img-thumbnail" style="max-height: 150px;" />
                </div>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="BenhLyId" />
                    <button type="submit" class="btn btn-danger px-4 me-2">XÁC NHẬN XÓA</button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">HUỶ BỎ</a>
                </form>
            </div>
        </div>
    </div>
</div>