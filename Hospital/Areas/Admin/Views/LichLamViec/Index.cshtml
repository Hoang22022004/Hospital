@model IEnumerable<Hospital.Models.LichLamViec>
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Quản lý Lịch làm việc";
    var bacSis = ViewBag.BacSis as SelectList;
}

@* Thêm link cho Select2 theme Bootstrap 5 nếu bạn đang dùng *@
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />

<style>
    /* CSS Giữ nguyên */
    .status-changer {
        background-color: #f8f9fa;
    }

    #tblData tbody td {
        vertical-align: middle;
        text-align: center;
    }

    .hidden-column {
        display: none !important;
    }

    /* Thêm CSS cho Tooltip trên nút disabled (Dù không dùng ở đây, giữ lại cho cấu trúc) */
    .btn-group span.d-inline-block {
        cursor: not-allowed;
    }
</style>

<div class="container-fluid p-0">

    <div class="row pt-4 align-items-center">
        <div class="col-6">
            <h2 class="text-primary mb-0">Lịch làm việc của Bác sĩ</h2>
        </div>
        <div class="col-6 text-end">
            <a asp-controller="LichLamViec" asp-action="Create" class="btn btn-primary shadow-sm">
                <i class="bi bi-calendar-plus"></i> &nbsp; Thêm Ca làm việc
            </a>
        </div>
    </div>

    <hr class="mt-2 mb-4" />


    <div class="row mb-3">
        <div class="col-md-4">
            <div class="dropdown">
                <button class="btn btn-outline-info dropdown-toggle w-100"
                        type="button" data-bs-toggle="dropdown">
                    <i class="bi bi-funnel"></i> Lọc theo
                </button>

                <ul class="dropdown-menu w-100">
                    <li>
                        <a class="dropdown-item filter-option" data-filter="bacsi">
                            <i class="bi bi-person-badge"></i> Bác sĩ
                        </a>
                    </li>

                    <li>
                        <a class="dropdown-item filter-option" data-filter="ngay">
                            <i class="bi bi-calendar-event"></i> Ngày làm việc
                        </a>
                    </li>

                    <li>
                        <a class="dropdown-item filter-option" data-filter="trangthai">
                            <i class="bi bi-toggle2-on"></i> Trạng thái
                        </a>
                    </li>
                </ul>
            </div>
        </div>

        <div class="col-md-2">
            <button id="resetFilter" class="btn btn-outline-secondary w-100">
                <i class="bi bi-x-circle"></i> Đặt lại
            </button>
        </div>
    </div>


    <div id="filterBacSi" class="mb-3 d-none">
        <label class="form-label">Lọc theo Bác sĩ:</label>
        <select id="bacSiFilter" class="form-select select2-dropdown">
            <option value="">-- Tất cả --</option>
            @if (bacSis != null)
            {
                @foreach (var item in bacSis)
                {
                    <option value="@item.Text">@item.Text</option>
                }
            }
        </select>
    </div>

    @* KHU VỰC LỌC THEO NGÀY *@
    <div id="filterNgay" class="mb-3 d-none">
        <label class="form-label">Chọn Ngày:</label>
        <input type="date" id="ngayFilter" class="form-control" />
    </div>

    <div id="filterTrangThai" class="mb-3 d-none">
        <label class="form-label">Trạng thái:</label>
        <select id="trangThaiFilter" class="form-select">
            <option value="">-- Tất cả --</option>
            <option value="Hoạt động">Hoạt động</option>
            <option value="Tạm dừng">Tạm dừng</option>
        </select>
    </div>


    <table id="tblData" class="table table-striped table-hover" style="width:100%">
        <thead>
            <tr>
                <th class="no-wrap-header">Bác sĩ</th>           @* Index 0 - Cột lọc Bác sĩ *@
                <th class="no-wrap-header">Ngày làm việc</th>     @* Index 1 - Cột lọc Ngày *@
                <th class="no-wrap-header">Giờ bắt đầu</th>       @* Index 2 *@
                <th class="no-wrap-header">Giờ kết thúc</th>      @* Index 3 *@
                <th class="no-wrap-header text-center">Thời lượng (Phút)</th> @* Index 4 *@
                <th class="no-wrap-header">Trạng thái</th>       @* Index 5 *@
                <th class="no-wrap-header hidden-column">Trạng thái (Text)</th> @* Index 6 - Cột lọc Trạng thái ẩn *@
                <th class="no-wrap-header">Thao tác</th>         @* Index 7 *@
            </tr>
        </thead>
        <tbody>
            @foreach (var obj in Model)
            {
                <tr>
                    <td style="vertical-align: middle;">@obj.BacSi.HoTen</td>
                    <td style="vertical-align: middle;">@obj.NgayLamViec.ToString("dd/MM/yyyy")</td> @* Cột 1 *@

                    <td style="vertical-align: middle;">@obj.GioBatDau.ToString(@"hh\:mm")</td>
                    <td style="vertical-align: middle;">@obj.GioKetThuc.ToString(@"hh\:mm")</td>

                    <td class="text-center" style="vertical-align: middle;">@obj.ThoiLuongKhungGioPhut</td>

                    <td style="vertical-align: middle;">
                        @{
                            string statusText = obj.IsActive ? "Hoạt động" : "Tạm dừng";
                            string statusClass = obj.IsActive ? "bg-success" : "bg-secondary";
                        }
                        <span class="badge rounded-pill @statusClass">
                            @statusText
                        </span>
                    </td>
                    <td class="hidden-column">@(obj.IsActive ? "Hoạt động" : "Tạm dừng")</td> @* Cột 6: Nội dung ẩn *@

                    <td style="vertical-align: middle;">
                        <div class="btn-group" role="group">
                            <a asp-controller="LichLamViec" asp-action="Edit" asp-route-id="@obj.LichLamViecId" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil-square"></i>
                            </a>
                            <a asp-controller="LichLamViec" asp-action="Delete" asp-route-id="@obj.LichLamViecId" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash-fill"></i>
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>


@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.bootstrap5.min.js"></script>

    <script>

        // Khởi tạo hàm DataTables (Để DataTables.js hoạt động)
        function initializeDataTable(tableId, options) {
            return $(`#${tableId}`).DataTable($.extend(true, {
                "language": { "url": "/js/i18n/vi.json" },
                "lengthMenu": [[10, 25, 50, -1], [10, 25, 50, "Tất cả"]],
                "pagingType": "full_numbers",
                "responsive": true,
                "order": [[1, 'asc']],
            }, options));
        }

        $(document).ready(function () {

            // Khởi tạo Tooltip Bootstrap (Nếu cần dùng tooltip cho bất kỳ nút disabled nào)
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl)
            })

            // --- 1. THÊM CUSTOM FILTER CHO NGÀY (Cột 1) ---
            $.fn.dataTable.ext.search.push(
                function(settings, data, dataIndex) {
                    var ngayFilter = $('#ngayFilter').val(); // Định dạng YYYY-MM-DD

                    if (!ngayFilter || $('#filterNgay').hasClass('d-none')) {
                        return true; // Bỏ qua lọc nếu không chọn ngày hoặc filter đang ẩn
                    }

                    var ngayHienThi = data[1]; // Lấy giá trị ngày tháng từ cột 1 (dd/MM/yyyy)

                    // Chuyển đổi định dạng ngày: dd/MM/yyyy -> yyyy-MM-dd để so sánh với input type="date"
                    var parts = ngayHienThi.split('/');
                    if (parts.length === 3) {
                         var ngaySoSanh = parts[2] + '-' + parts[1] + '-' + parts[0];
                         return ngaySoSanh === ngayFilter;
                    }

                    return false;
                }
            );

            // Khởi tạo DataTables
            var table = initializeDataTable('tblData', {
                "order": [[1, 'asc']],
                "columnDefs": [
                    // Cột 6 là cột ẩn Trạng thái
                    { "targets": 6, "visible": false, "searchable": true }
                ]
            });


            // Khởi tạo Select2
            $('#bacSiFilter').select2({
                placeholder: "-- Tất cả --",
                allowClear: true,
                theme: 'bootstrap-5',
                width: '100%'
            });

            // --- 2. HÀM LỌC TỔNG HỢP ---
            function applyFilters() {
                // Xóa tìm kiếm cột cũ
                // Cột 0: Bác sĩ, Cột 6: Trạng thái (Text ẩn)
                table.columns([0, 6]).search('');

                // 1. Lọc theo Bác sĩ (Cột 0)
                var bacSi = $('#bacSiFilter').val();
                if (bacSi && $('#filterBacSi').is(':visible')) {
                    // Lọc chính xác
                    table.column(0).search('^' + bacSi + '$', true, false);
                }

                // 2. Lọc theo Trạng thái (Cột 6 - Text ẩn)
                var trangThai = $('#trangThaiFilter').val();
                if (trangThai && $('#filterTrangThai').is(':visible')) {
                    // Lọc chính xác trên cột ẨN (Cột 6)
                    table.column(6).search('^' + trangThai + '$', true, false);
                }

                // Lọc theo Ngày (Kích hoạt bộ lọc tùy chỉnh đã được định nghĩa ở trên)
                table.draw();
            }


            // --- GẮN SỰ KIỆN LỌC MENU VÀ APPLY ---

            // 1. Gắn sự kiện Change cho các Filter để áp dụng lọc cộng dồn
            $('#bacSiFilter, #ngayFilter, #trangThaiFilter').on('change', applyFilters);

            // 2. Hiển thị filter theo menu
            $('.filter-option').on('click', function () {
                var filter = $(this).data('filter');
                var table = $('#tblData').DataTable();

                // Reset các giá trị lọc và ẩn khối filter khi chuyển đổi
                $('#bacSiFilter').val('').trigger('change.select2');
                $('#ngayFilter').val('');
                $('#trangThaiFilter').val('');
                table.search('').columns().search('').draw(); // Xóa tất cả lọc cũ

                // Ẩn tất cả các khối trước
                $('#filterBacSi, #filterNgay, #filterTrangThai').addClass('d-none');

                // Hiển thị khối được chọn
                if (filter === 'bacsi') {
                    $('#filterBacSi').removeClass('d-none');
                } else if (filter === 'ngay') {
                    $('#filterNgay').removeClass('d-none');
                } else if (filter === 'trangthai') {
                    $('#filterTrangThai').removeClass('d-none');
                }
            });


            // 3. RESET
            $('#resetFilter').on('click', function () {
                var table = $('#tblData').DataTable();
                // Reset giá trị
                $('#bacSiFilter').val('').trigger('change.select2');
                $('#ngayFilter').val('');
                $('#trangThaiFilter').val('');

                // Ẩn tất cả các khối filter
                $('#filterBacSi, #filterNgay, #filterTrangThai').addClass('d-none');

                // Xóa tất cả các bộ lọc trên DataTables
                table.search('').columns().search('').draw();
            });
        });
    </script>
}