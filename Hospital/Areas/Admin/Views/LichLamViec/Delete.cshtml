@model Hospital.Models.LichLamViec
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Xóa Ca làm việc";
}

<form method="post" asp-action="Delete">

  
    <input asp-for="LichLamViecId" hidden />

    <div class="border p-4 mt-4 bg-white shadow-sm rounded">
        <div class="row pb-2">
            <h2 class="text-danger">Xác nhận Xóa Ca làm việc</h2>
            <hr />
        </div>

        <div class="alert alert-warning" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> **Cảnh báo:** Thao tác này sẽ xóa vĩnh viễn Ca làm việc. Chỉ xóa nếu chắc chắn rằng ca làm việc này không còn được sử dụng.
        </div>

        <div class="row">
            <div class="col-8">

       
                <div class="mb-3">
                    <label asp-for="BacSi.HoTen" class="form-label text-primary">Bác sĩ phụ trách</label>
                    <input value="@Model.BacSi.HoTen" class="form-control" disabled />
                </div>

                <div class="mb-3">
                    <label asp-for="NgayLamViec" class="form-label text-primary">Ngày làm việc</label>
                    <input value="@Model.NgayLamViec.ToString("dd/MM/yyyy")" class="form-control" disabled />
                </div>

                <div class="row">
                    <div class="col-6">
                        <div class="mb-3">
                            <label asp-for="GioBatDau" class="form-label text-primary">Giờ Bắt đầu</label>
                            <input value="@Model.GioBatDau.ToString("HH:mm")" class="form-control" disabled />
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="mb-3">
                            <label asp-for="GioKetThuc" class="form-label text-primary">Giờ Kết thúc</label>
                            <input value="@Model.GioKetThuc.ToString("HH:mm")" class="form-control" disabled />
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="IsActive" class="form-label text-primary">Trạng thái hiện tại</label>
                    @{
                        string statusText = Model.IsActive ? "Hoạt động" : "Tạm dừng";
                        string statusClass = Model.IsActive ? "text-success" : "text-secondary";
                    }
                    <input value="@statusText" class="form-control @statusClass" disabled style="font-weight: bold;" />
                </div>

            </div>
        </div>

        <div class="mt-4 pt-3 border-top text-end">
            <button type="submit" class="btn btn-danger btn-lg shadow-lg" style="width:200px">
                <i class="bi bi-trash-fill"></i> Xóa ca làm 
            </button>
            <a asp-controller="LichLamViec" asp-action="Index" class="btn btn-secondary btn-lg" style="width:180px">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
        </div>
    </div>
</form>

@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }
}