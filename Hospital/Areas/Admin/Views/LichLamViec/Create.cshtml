@model Hospital.Models.LichLamViec
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Thêm Ca làm việc mới";
    var bacSiList = ViewData["BacSiId"] as SelectList;
}

<form method="post">
    <div class="border p-4 mt-4 bg-white shadow-sm rounded">
        <div class="row pb-2">
            <h2 class="text-primary">Thiết lập ca làm việc</h2>
            <hr />
        </div>
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="row">
            <div class="col-8">

                @* TRƯỜNG 1: Bác sĩ (Select2) *@
                <div class="mb-3">
                    <label asp-for="BacSiId" class="form-label">Bác sĩ</label>
                    <select asp-for="BacSiId" asp-items="@bacSiList" class="form-select select2-dropdown">
                        <option value="">-- Tìm kiếm Bác sĩ --</option>
                    </select>
                    <span asp-validation-for="BacSiId" class="text-danger"></span>
                </div>

                @* TRƯỜNG 2: Ngày làm việc (JQUERY UI DATEPICKER) *@
                <div class="mb-3">
                    <label asp-for="NgayLamViec" class="form-label">Ngày làm việc</label>
                    <input asp-for="NgayLamViec" type="text" id="datepickerNgayLamViec" class="form-control" />
                    <span class="text-muted small">Định dạng hiển thị: Ngày/Tháng/Năm (dd/MM/yyyy)</span>
                    <span asp-validation-for="NgayLamViec" class="text-danger"></span>
                </div>

                @* TRƯỜNG 3 & 4: Giờ Bắt đầu và Giờ Kết thúc (FLATPICKR TIME PICKER) *@
                <div class="row">
                    <div class="col-6">
                        <div class="mb-3">
                            <label asp-for="GioBatDau" class="form-label">Giờ Bắt đầu</label>
                            <input asp-for="GioBatDau" type="text" id="gioBatDau" class="form-control time-picker" placeholder="Chọn giờ" />
                            <span asp-validation-for="GioBatDau" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="mb-3">
                            <label asp-for="GioKetThuc" class="form-label">Giờ Kết thúc</label>
                            <input asp-for="GioKetThuc" type="text" id="gioKetThuc" class="form-control time-picker" placeholder="Chọn giờ" />
                            <span asp-validation-for="GioKetThuc" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                @* TRƯỜNG 5: IsActive (Switch) *@
                <div class="form-check form-switch mb-3 p-3 border rounded shadow-sm d-flex justify-content-between align-items-center">
                    <label class="form-check-label" for="IsActiveSwitch">Kích hoạt ca làm việc</label>
                    <input class="form-check-input" type="checkbox" role="switch" asp-for="IsActive" id="IsActiveSwitch">
                </div>

            </div>
        </div>

        <div class="mt-4 pt-3 border-top text-end">
            <button type="submit" class="btn btn-primary btn-lg shadow-lg" style="width:200px">
                <i class="bi bi-calendar-plus"></i> Thêm ca làm
            </button>
            <a asp-controller="LichLamViec" asp-action="Index" class="btn btn-secondary btn-lg" style="width:180px">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
        </div>
    </div>
</form>

@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }

    <script>
        $(document).ready(function () {
            // 1. Kích hoạt Select2
            $('.select2-dropdown').select2({
                placeholder: "-- Tìm kiếm Bác sĩ...",
                allowClear: true,
                theme: 'bootstrap-5'
            });

            // 2. Kích hoạt JQUERY UI DATEPICKER (dd/mm/yyyy)
            $('#datepickerNgayLamViec').datepicker({
                dateFormat: 'dd/mm/yy',
                changeMonth: true,
                changeYear: true,
                yearRange: '2025:2030'
            });

            // 3. KHỞI TẠO FLATPCIKR TIME PICKER (Giờ:Phút)
            flatpickr(".time-picker", {
                enableTime: true,
                noCalendar: true, // Chỉ chọn giờ
                dateFormat: "H:i", // Định dạng 24h: Giờ:Phút
                time_24hr: true,
                minuteIncrement: 5, // Chọn phút theo bước 5 phút
                locale: "vn" // Sử dụng ngôn ngữ Việt Nam
            });
        });
    </script>
}