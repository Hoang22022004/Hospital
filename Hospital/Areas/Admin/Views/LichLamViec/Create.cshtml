@model Hospital.Models.LichLamViec
@{
    ViewData["Title"] = "Thiết lập lịch làm việc";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<link rel="stylesheet" type="text/css" href="https://npmcdn.com/flatpickr/dist/themes/material_blue.css">

<form method="post">
    <div class="container mt-4">
        <div class="card shadow-lg border-0 rounded-3">
            <div class="card-header bg-primary text-white p-3">
                <h4 class="mb-0"><i class="bi bi-calendar2-plus me-2"></i>Thiết lập ca làm việc</h4>
            </div>
            <div class="card-body p-4">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="row g-4">
                    <div class="col-12">
                        <label asp-for="BacSiId" class="form-label fw-bold">Bác sĩ phụ trách</label>
                        @if (User.IsInRole("Doctor"))
                        {
                            <input type="hidden" asp-for="BacSiId" value="@ViewBag.CurrentBacSiId" />
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-person-badge"></i></span>
                                <input class="form-control bg-light fw-bold" value="@ViewBag.CurrentBacSiName" readonly />
                            </div>
                        }
                        else
                        {
                            <select asp-for="BacSiId" asp-items="@(ViewData["BacSiId"] as SelectList)" class="form-select select2-dropdown">
                                <option value="">-- Chọn bác sĩ --</option>
                            </select>
                        }
                        <span asp-validation-for="BacSiId" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="NgayLamViec" class="form-label fw-bold">Ngày làm việc</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white"><i class="bi bi-calendar-event text-primary"></i></span>
                            <input asp-for="NgayLamViec" id="flatpickr-date" type="text"
                                   class="form-control bg-white" placeholder="Chọn ngày trực..." readonly />
                        </div>
                        <span asp-validation-for="NgayLamViec" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="ThoiLuongKhungGioPhut" class="form-label fw-bold">Thời lượng (Phút)</label>
                        <input asp-for="ThoiLuongKhungGioPhut" type="number" class="form-control" placeholder="Ví dụ: 30" />
                        <span asp-validation-for="ThoiLuongKhungGioPhut" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="GioBatDau" class="form-label fw-bold">Giờ bắt đầu</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white"><i class="bi bi-clock text-success"></i></span>
                            <input asp-for="GioBatDau" id="flatpickr-start-time" type="text"
                                   class="form-control bg-white" placeholder="--:--" readonly />
                        </div>
                        <span asp-validation-for="GioBatDau" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="GioKetThuc" class="form-label fw-bold">Giờ kết thúc</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white"><i class="bi bi-clock-fill text-danger"></i></span>
                            <input asp-for="GioKetThuc" id="flatpickr-end-time" type="text"
                                   class="form-control bg-white" placeholder="--:--" readonly />
                        </div>
                        <span asp-validation-for="GioKetThuc" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <div class="form-check form-switch p-3 border rounded shadow-sm bg-light d-flex justify-content-between align-items-center">
                            <label class="form-check-label fw-bold" for="IsActive">Kích hoạt ca làm việc</label>
                            <input class="form-check-input" type="checkbox" role="switch" asp-for="IsActive" checked>
                        </div>
                    </div>
                </div>

                <div class="mt-4 pt-3 border-top text-end">
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4 me-2">
                        <i class="bi bi-arrow-left"></i> Quay lại
                    </a>
                    <button type="submit" class="btn btn-primary btn-lg px-5 shadow">
                        <i class="bi bi-check-circle"></i> Lưu ca làm
                    </button>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://npmcdn.com/flatpickr/dist/l10n/vn.js"></script>

    <script>
        $(document).ready(function () {
            // 1. Cấu hình Chọn Ngày (Date Picker)
            flatpickr("#flatpickr-date", {
                locale: "vn",
                dateFormat: "Y-m-d", // Định dạng gửi về Server
                altInput: true,      // Hiện một input đẹp cho người dùng
                altFormat: "d/m/Y",  // Định dạng người dùng thấy (VN)
                minDate: "today",    // Không cho chọn ngày quá khứ
                disableMobile: "true"
            });

            // 2. Cấu hình Chọn Giờ (Time Picker)
            const timeConfig = {
                enableTime: true,
                noCalendar: true,
                dateFormat: "H:i",
                time_24hr: true,
                minuteIncrement: 15, // Nhảy mỗi 15 phút cho chuyên nghiệp
                locale: "vn"
            };

            flatpickr("#flatpickr-start-time", timeConfig);
            flatpickr("#flatpickr-end-time", timeConfig);

            // 3. Select2 cho phần chọn bác sĩ
            if ($('.select2-dropdown').length > 0) {
                $('.select2-dropdown').select2({
                    theme: 'bootstrap-5',
                    width: '100%'
                });
            }
        });
    </script>
}