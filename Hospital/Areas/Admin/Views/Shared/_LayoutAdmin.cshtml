@using Microsoft.AspNetCore.Identity
@using Hospital.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản trị Hệ thống</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="//cdnjs.cloudflare.com/ajax/libs/toastr.js/2.1.1/toastr.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/2.0.8/css/dataTables.bootstrap5.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.2/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="//code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <link rel="stylesheet" href="https://npmcdn.com/flatpickr/dist/themes/material_blue.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin_sidebar.css" />

    <style>
        body {
            font-family: 'Nunito', sans-serif;
            background-color: #f3f4f6;
        }

        /* SIDEBAR STYLE */
        #sidebar-wrapper {
            background: linear-gradient(180deg, #1e3a8a 0%, #1e40af 100%);
            min-height: 100vh;
            box-shadow: 4px 0 10px rgba(0,0,0,0.1);
        }

        .sidebar-heading {
            font-size: 1.2rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            background-color: rgba(0,0,0,0.1);
        }

        .list-group-item {
            background-color: transparent !important;
            color: rgba(255,255,255,0.8) !important;
            border: none;
            padding: 12px 20px;
            font-weight: 600;
            transition: all 0.3s ease;
            border-left: 4px solid transparent;
        }

            .list-group-item:hover {
                background-color: rgba(255,255,255,0.1) !important;
                color: #fff !important;
                padding-left: 25px;
                border-left: 4px solid #60a5fa;
            }

            .list-group-item i {
                margin-right: 10px;
                font-size: 1.1rem;
                width: 20px;
                text-align: center;
            }

        .menu-label {
            color: rgba(255,255,255,0.4);
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            padding: 15px 20px 5px 20px;
            letter-spacing: 0.5px;
        }

        /* NAVBAR HEADER STYLE */
        .navbar {
            box-shadow: 0 2px 15px rgba(0,0,0,0.05);
            background-color: #fff !important;
            padding: 0.8rem 1rem;
        }

        .avatar {
            width: 38px;
            height: 38px;
            object-fit: cover;
            border-radius: 50%;
            font-size: 1.1rem;
        }

        .nav-link {
            color: #64748b !important;
            font-weight: 600;
            transition: color 0.2s;
        }

            .nav-link:hover {
                color: #1e3a8a !important;
            }

        /* DROPDOWN MENU */
        .dropdown-menu {
            border: none;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
            border-radius: 10px;
            padding: 0.5rem;
        }

        .dropdown-item {
            border-radius: 6px;
            padding: 8px 15px;
            font-size: 0.95rem;
        }

            .dropdown-item:hover {
                background-color: #f1f5f9;
                color: #1e3a8a;
            }

            .dropdown-item.text-danger:hover {
                background-color: #fef2f2;
                color: #dc2626;
            }

        #page-content-wrapper {
            background-color: #f3f4f6;
        }

        /* DATATABLES */
        .dataTables_wrapper .dataTables_length select {
            padding-right: 30px;
        }

        .page-item.active .page-link {
            background-color: #1e3a8a;
            border-color: #1e3a8a;
        }

        .no-wrap-header {
            white-space: nowrap;
        }

        div.dataTables_wrapper div.row {
            margin-bottom: 0.5rem !important;
        }

        .dataTables_wrapper .row:last-child .col-sm-12 {
            text-align: center;
        }
    </style>
</head>
<body>
    <div class="d-flex" id="wrapper">

        <div class="border-end" id="sidebar-wrapper">
            <div class="sidebar-heading text-white p-3 d-flex align-items-center">
                <i class="bi bi-hospital-fill me-2 fs-4"></i>
                <span>MEDIC ADMIN</span>
            </div>

            <div class="list-group list-group-flush">
                <a asp-area="Admin" asp-controller="Dashboard" asp-action="AdminDashboard" class="list-group-item list-group-item-action">
                    <i class="bi bi-grid-1x2-fill"></i> Dashboard Admin
                </a>

                <div class="menu-label">Lâm sàng & Điều trị</div>
                <a asp-area="Admin" asp-controller="BenhNhan" asp-action="Index" class="list-group-item list-group-item-action">
                    <i class="bi bi-people-fill"></i> Quản lý Bệnh nhân <span class="badge bg-danger ms-auto rounded-pill" style="font-size: 0.6rem;">Mới</span>
                </a>
                <a asp-area="Admin" asp-controller="LichHen" asp-action="Index" class="list-group-item list-group-item-action">
                    <i class="bi bi-calendar-check-fill"></i> Lịch hẹn Khám
                </a>

                <a asp-area="Admin" asp-controller="HoSoBenhAn" asp-action="Index" class="list-group-item list-group-item-action">
                    <i class="bi bi-clipboard2-pulse-fill"></i> Tiếp nhận và tiến độ
                </a>

                <div class="menu-label">Tài nguyên & Kho</div>
                <a asp-area="Admin" asp-controller="Thuoc" asp-action="Index" class="list-group-item list-group-item-action">
                    <i class="bi bi-capsule"></i> Kho Dược phẩm
                </a>
                <a asp-area="Admin" asp-controller="DichVu" asp-action="Index" class="list-group-item list-group-item-action">
                    <i class="bi bi-clipboard2-pulse-fill"></i> Dịch vụ
                </a>

                <div class="menu-label">Hệ thống & Nhân sự</div>
                <a asp-area="Admin" asp-controller="BacSi" asp-action="Index" class="list-group-item list-group-item-action">
                    <i class="bi bi-person-badge-fill"></i> Đội ngũ Bác sĩ
                </a>
                <a asp-area="Admin" asp-controller="LichLamViec" asp-action="Index" class="list-group-item list-group-item-action">
                    <i class="bi bi-calendar-week-fill"></i> Ca làm việc
                </a>
                <a asp-area="Admin" asp-controller="ChuyenKhoa" asp-action="Index" class="list-group-item list-group-item-action">
                    <i class="bi bi-tags-fill"></i> Chuyên khoa
                </a>
                <a asp-area="Admin" asp-controller="User" asp-action="Index" class="list-group-item list-group-item-action">
                    <i class="bi bi-shield-lock-fill"></i> Tài khoản & Quyền
                </a>
            </div>
        </div>

        <div id="page-content-wrapper">

            <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom sticky-top">
                <div class="container-fluid">

                    <div class="d-flex align-items-center">
                        <button class="btn btn-light text-primary border-0 shadow-sm me-3" id="menu-toggle">
                            <i class="bi bi-list fs-5"></i>
                        </button>
                        <a class="navbar-brand d-none d-md-flex align-items-center text-primary" href="#">
                            <span class="fw-bold" style="letter-spacing: 1px;">HOSPITAL ADMIN</span>
                        </a>
                    </div>

                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="collapse navbar-collapse" id="navbarSupportedContent">
                        <ul class="navbar-nav ms-auto mt-2 mt-lg-0 align-items-center">

                            <li class="nav-item me-3 d-none d-md-block">
                                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index" target="_blank" title="Xem trang chủ">
                                    <i class="bi bi-globe2 me-1"></i> Website
                                </a>
                            </li>

                            <li class="nav-item me-3">
                                <a class="nav-link position-relative" href="#">
                                    <i class="bi bi-bell fs-5"></i>
                                    <span class="position-absolute top-1 start-100 translate-middle p-1 bg-danger border border-light rounded-circle">
                                        <span class="visually-hidden">New alerts</span>
                                    </span>
                                </a>
                            </li>

                            @if (SignInManager.IsSignedIn(User))
                            {
                                var user = await UserManager.GetUserAsync(User);
                                var displayName = user?.FullName ?? user?.UserName ?? "Admin";
                                var initial = displayName.Length > 0 ? displayName.Substring(0, 1).ToUpper() : "A";

                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <div class="avatar bg-primary bg-opacity-10 text-primary fw-bold d-flex justify-content-center align-items-center me-2">
                                            @initial
                                        </div>
                                        <div class="d-none d-lg-block text-dark">
                                            <div class="fw-bold" style="font-size: 0.9rem; line-height: 1.2;">@displayName</div>
                                            <div class="text-muted" style="font-size: 0.75rem;">Quản trị viên</div>
                                        </div>
                                    </a>

                                    <ul class="dropdown-menu dropdown-menu-end mt-2" aria-labelledby="navbarDropdown">
                                        <li><h6 class="dropdown-header text-uppercase text-muted small">Tài khoản</h6></li>
                                        <li><a class="dropdown-item" href="#"><i class="bi bi-person me-2"></i>Hồ sơ cá nhân</a></li>
                                        <li><a class="dropdown-item" href="#"><i class="bi bi-gear me-2"></i>Cài đặt</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                                                <button type="submit" class="dropdown-item text-danger">
                                                    <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                                                </button>
                                            </form>
                                        </li>
                                    </ul>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </nav>

            <div class="container-fluid px-4 py-2">
                @RenderBody()
            </div>
        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/vn.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.tiny.cloud/1/vy399c75h6gyw1xkemhoj245q01aqnsusy14yaiket9jmz1h/tinymce/6/tinymce.min.js" referrerpolicy="origin"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // Toggle Sidebar
        document.getElementById("menu-toggle").addEventListener("click", function(e) {
            e.preventDefault();
            document.getElementById("wrapper").classList.toggle("toggled");
        });

        // Hàm khởi tạo DataTables chung
        function initializeDataTable(tableId, customOptions = {}) {
            var defaultOptions = {
                "language": { "url": "/js/i18n/vi.json" },
                "lengthMenu": [[10, 25, 50, -1], [10, 25, 50, "Tất cả"]],
                "pagingType": "full_numbers",
                "info": false,
                "dom": '<"row"<"col-sm-6"l><"col-sm-6"f>>rt<"row"<"col-sm-12"p>>',
                "order": [[0, 'asc']]
            };
            var options = $.extend(true, {}, defaultOptions, customOptions);
            $('#' + tableId).DataTable(options);
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)

    @* --- ĐOẠN SỬA THÔNG BÁO TỐI ƯU --- *@
    <script>
        $(document).ready(function () {
            // Chuyển dữ liệu C# sang JS an toàn tuyệt đối
            var successMsg = @Html.Raw(Json.Serialize(TempData["success"]));
            var errorMsg = @Html.Raw(Json.Serialize(TempData["error"]));

            if (successMsg) {
                Swal.fire({
                    icon: 'success',
                    title: 'Thành công',
                    text: successMsg,
                    timer: 3000,
                    showConfirmButton: false,
                    position: 'top-end',
                    toast: true
                });
            }

            if (errorMsg) {
                Swal.fire({
                    icon: 'error',
                    title: 'Lỗi hệ thống',
                    text: errorMsg,
                    confirmButtonColor: '#1e3a8a'
                });
            }
        });
    </script>
</body>
</html>