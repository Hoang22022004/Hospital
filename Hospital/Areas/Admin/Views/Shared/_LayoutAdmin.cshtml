@using Microsoft.AspNetCore.Identity
@using Hospital.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản trị Phòng khám</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">

    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" />

    <style>
        :root {
            --sidebar-bg: #1e293b;
            --sidebar-hover: #334155;
            --accent-color: #6366f1;
            --text-muted: #94a3b8;
            --bg-body: #f8fafc;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-body);
            color: #1e293b;
        }

        /* SIDEBAR STYLE */
        #sidebar-wrapper {
            background-color: var(--sidebar-bg);
            min-height: 100vh;
            width: 280px;
            transition: all 0.3s;
            z-index: 1000;
        }

        .sidebar-brand {
            padding: 2rem 1.5rem;
            display: flex;
            align-items: center;
            gap: 12px;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        .brand-logo {
            width: 45px;
            height: 45px;
            background: var(--accent-color);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
        }

        .brand-name {
            color: #fff;
            font-weight: 800;
            font-size: 1.1rem;
            letter-spacing: -0.5px;
            line-height: 1.2;
        }

        .menu-label {
            color: var(--text-muted);
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            padding: 1.5rem 1.5rem 0.5rem;
            letter-spacing: 1px;
        }

        .list-group-item {
            background-color: transparent !important;
            color: #cbd5e1 !important;
            border: none;
            padding: 10px 1.5rem;
            font-weight: 500;
            font-size: 0.92rem;
            display: flex;
            align-items: center;
            gap: 12px;
            transition: all 0.2s ease;
        }

            .list-group-item:hover, .list-group-item.active {
                color: #fff !important;
                background-color: var(--sidebar-hover) !important;
            }

        .sub-menu {
            background-color: rgba(15, 23, 42, 0.5);
        }

            .sub-menu .list-group-item {
                padding-left: 3.5rem;
                font-size: 0.88rem;
            }

        .menu-arrow {
            margin-left: auto;
            font-size: 0.8rem;
            transition: transform 0.3s;
        }

        .collapsed .menu-arrow {
            transform: rotate(-90deg);
        }

        .navbar {
            background: #fff !important;
            border-bottom: 1px solid #e2e8f0;
            padding: 0.75rem 1.5rem;
        }

        .btn-view-site {
            background-color: #f1f5f9;
            color: #475569;
            border: none;
            font-weight: 600;
            font-size: 0.85rem;
            padding: 8px 16px;
            border-radius: 8px;
            transition: 0.3s;
        }

            .btn-view-site:hover {
                background-color: var(--accent-color);
                color: #fff;
            }

        #wrapper.toggled #sidebar-wrapper {
            margin-left: -280px;
        }
    </style>
</head>
<body>
    <div class="d-flex" id="wrapper">
        <div id="sidebar-wrapper">
            <div class="sidebar-brand">
                <div class="brand-logo">
                    <i class="bi bi-heart-pulse-fill text-white fs-4"></i>
                </div>
                <div class="brand-name">
                    MEDICINE<br><span style="color: var(--accent-color); font-size: 0.8rem;">CLINIC MIS</span>
                </div>
            </div>

            <div class="list-group list-group-flush mt-2">
                <a asp-area="Admin" asp-controller="Dashboard" asp-action="AdminDashboard" class="list-group-item list-group-item-action">
                    <i class="bi bi-grid-fill"></i> Tổng quan hệ thống
                </a>

                @if (User.IsInRole("Admin") || User.IsInRole("Receptionist"))
                {
                    <div class="menu-label">Nghiệp vụ Vận hành</div>
                    <a class="list-group-item list-group-item-action" data-bs-toggle="collapse" href="#receptionMenu">
                        <i class="bi bi-person-badge"></i> Quầy Lễ tân
                        <i class="bi bi-chevron-down menu-arrow"></i>
                    </a>
                    <div class="collapse show sub-menu" id="receptionMenu">
                        <a asp-area="Admin" asp-controller="BenhNhan" asp-action="Index" class="list-group-item">Quản lý Bệnh nhân</a>
                        <a asp-area="Admin" asp-controller="LichHen" asp-action="Index" class="list-group-item">Lịch hẹn khám</a>
                        <a asp-area="Admin" asp-controller="HoSoBenhAn" asp-action="Index" class="list-group-item">Tiếp nhận & Thu phí</a>
                    </div>
                }

                @if (User.IsInRole("Admin") || User.IsInRole("Doctor"))
                {
                    <div class="menu-label">Khu vực Chuyên môn</div>
                    <a class="list-group-item list-group-item-action" data-bs-toggle="collapse" href="#doctorMenu">
                        <i class="bi bi-capsule-pill"></i> Khám & Điều trị
                        <i class="bi bi-chevron-down menu-arrow"></i>
                    </a>
                    <div class="collapse show sub-menu" id="doctorMenu">
                        <a asp-area="Admin" asp-controller="HoSoBenhAn" asp-action="Index" class="list-group-item">Danh sách khám hôm nay</a>
                        <a asp-area="Admin" asp-controller="BenhNhan" asp-action="Index" class="list-group-item">Tra cứu Bệnh nhân</a>
                        <a asp-area="Admin" asp-controller="LichLamViec" asp-action="Index" class="list-group-item">Lịch trực cá nhân</a>
                    </div>
                }

                @if (User.IsInRole("Admin") || User.IsInRole("Receptionist"))
                {
                    <div class="menu-label">Truyền thông & Nội dung</div>

                    @* Menu Tin tức *@
                    <a asp-area="Admin" asp-controller="TinTuc" asp-action="Index"
                       class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["Controller"]?.ToString() == "TinTuc" ? "active" : "")">
                        <i class="bi bi-newspaper"></i> Quản lý Tin tức
                    </a>

                    @* Menu Bệnh lý - Đặt ngay sau Tin tức *@
                    <a asp-area="Admin" asp-controller="BenhLy" asp-action="Index"
                       class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["Controller"]?.ToString() == "BenhLy" ? "active" : "")">
                        <i class="bi bi-clipboard2-pulse"></i> Danh mục Bệnh lý
                    </a>
                }

                <div class="menu-label">Dữ liệu chung</div>
                <a class="list-group-item list-group-item-action" data-bs-toggle="collapse" href="#dataMenu">
                    <i class="bi bi-collection-fill"></i> Kho & Dịch vụ
                    <i class="bi bi-chevron-down menu-arrow"></i>
                </a>
                <div class="collapse sub-menu" id="dataMenu">
                    <a asp-area="Admin" asp-controller="Thuoc" asp-action="Index" class="list-group-item">Danh mục Thuốc</a>
                    <a asp-area="Admin" asp-controller="DichVu" asp-action="Index" class="list-group-item">Gói Dịch vụ kỹ thuật</a>
                </div>

                @if (User.IsInRole("Admin"))
                {
                    <div class="menu-label">Cấu hình hệ thống</div>
                    <a class="list-group-item list-group-item-action" data-bs-toggle="collapse" href="#adminMenu">
                        <i class="bi bi-shield-lock-fill"></i> Quản trị tối cao
                        <i class="bi bi-chevron-down menu-arrow"></i>
                    </a>
                    <div class="collapse sub-menu" id="adminMenu">
                        <a asp-area="Admin" asp-controller="BacSi" asp-action="Index" class="list-group-item">Đội ngũ Bác sĩ</a>
                        <a asp-area="Admin" asp-controller="ChuyenKhoa" asp-action="Index" class="list-group-item">Quản lý Chuyên khoa</a>
                        <a asp-area="Admin" asp-controller="User" asp-action="Index" class="list-group-item">Tài khoản & Quyền hạn</a>
                    </div>
                }
            </div>
        </div>

        <div id="page-content-wrapper" class="w-100">
            <nav class="navbar navbar-expand-lg navbar-light sticky-top">
                <div class="container-fluid">
                    <button class="btn border-0 shadow-none" id="menu-toggle"><i class="bi bi-list fs-4"></i></button>

                    <div class="ms-auto d-flex align-items-center">
                        <a href="/" class="btn-view-site me-3 d-none d-md-block">
                            <i class="bi bi-globe me-1"></i> Xem Website
                        </a>

                        @if (SignInManager.IsSignedIn(User))
                        {
                            <div class="dropdown">
                                <a class="nav-link dropdown-toggle fw-bold" href="#" role="button" data-bs-toggle="dropdown">
                                    <span class="d-none d-sm-inline">Chào, </span> @UserManager.GetUserName(User)
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-3 p-2">
                                    <li><a class="dropdown-item rounded" href="#"><i class="bi bi-person me-2"></i>Hồ sơ</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                                            <button type="submit" class="dropdown-item text-danger rounded">
                                                <i class="bi bi-power me-2"></i>Đăng xuất
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                    </div>
                </div>
            </nav>

            <div class="container-fluid p-4">
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // Logic đóng mở menu sidebar của bạn
        $("#menu-toggle").click(function(e) {
            e.preventDefault();
            $("#wrapper").toggleClass("toggled");
        });

        $(document).ready(function() {
            // Logic Active Menu của bạn
            var currentPath = window.location.pathname;
            $(".list-group-item").each(function() {
                var href = $(this).attr("href");
                if (href && currentPath.includes(href) && href !== "/Admin/Dashboard/AdminDashboard") {
                    $(this).addClass("active");
                    $(this).closest(".collapse").addClass("show");
                }
            });

            // --- ĐOẠN MÃ HIỂN THỊ THÔNG BÁO CHO TOÀN BỘ ADMIN ---
            var successMessage = '@Html.Raw(TempData["success"])';
            var errorMessage = '@Html.Raw(TempData["error"])';

            if (successMessage && successMessage.trim() !== "") {
                Swal.fire({
                    title: 'Thành công!',
                    text: successMessage,
                    icon: 'success',
                    timer: 3000,
                    toast: true,
                    position: 'top-end',
                    showConfirmButton: false,
                    timerProgressBar: true
                });
            }

            if (errorMessage && errorMessage.trim() !== "") {
                Swal.fire({
                    title: 'Thông báo lỗi!',
                    text: errorMessage,
                    icon: 'error',
                    confirmButtonColor: '#6366f1', // Màu accent-color của bạn
                    confirmButtonText: 'Đóng'
                });
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>