@* File: Areas/Admin/Views/Shared/_LayoutAdmin.cshtml *@

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản trị Hệ thống</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/admin_sidebar.css" />


    <link rel="stylesheet" href="//cdnjs.cloudflare.com/ajax/libs/toastr.js/2.1.1/toastr.min.css" />

    <link rel="stylesheet" href="https://cdn.datatables.net/2.0.8/css/dataTables.bootstrap5.min.css" />

    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

    <link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.2/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />

    <link rel="stylesheet" href="//code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <link rel="stylesheet" href="https://npmcdn.com/flatpickr/dist/themes/material_blue.css">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="d-flex" id="wrapper">


        <div class="bg-dark border-right" id="sidebar-wrapper">
            <div class="sidebar-heading text-light p-3">
                <i class="bi bi-hospital"></i> HOSPITAL ADMIN
            </div>
            <div class="list-group list-group-flush">
                <a asp-area="Admin" asp-controller="Home" asp-action="Index"
                                  class="list-group-item list-group-item-action bg-dark text-light">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>

                <a asp-area="Admin" asp-controller="BacSi" asp-action="Index"
                                  class="list-group-item list-group-item-action bg-dark text-light">
                    <i class="bi bi-person-badge"></i> Quản lý Bác sĩ
                </a>

                <a asp-area="Admin" asp-controller="DichVu" asp-action="Index"
                                  class="list-group-item list-group-item-action bg-dark text-light">
                    <i class="bi bi-card-checklist"></i> Quản lý Dịch vụ
                </a>

                <a asp-area="Admin" asp-controller="ChuyenKhoa" asp-action="Index"
                                  class="list-group-item list-group-item-action bg-dark text-light">
                    <i class="bi bi-tags"></i> Quản lý Chuyên khoa
                </a>

                <a asp-area="Admin" asp-controller="LichHen" asp-action="Index"
                                  class="list-group-item list-group-item-action bg-dark text-light">
                    <i class="bi bi-calendar-check"></i> Lịch hẹn
                </a>

                <a asp-area="Admin" asp-controller="User" asp-action="Index"
                                  class="list-group-item list-group-item-action bg-dark text-light">
                    <i class="bi bi-people"></i> Quản lý Tài khoản
                </a>
            </div>
        </div>

        <div id="page-content-wrapper">

            <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm">
                <button class="btn btn-outline-secondary ms-2" id="menu-toggle">
                    <i class="bi bi-list"></i>
                </button>
                <div class="collapse navbar-collapse">
                    <ul class="navbar-nav ms-auto me-4 mt-2 mt-lg-0">
                        <partial name="_LoginPartial" />
                    </ul>
                </div>
            </nav>

            <div class="container-fluid p-4">
                <partial name="_Notification" />
                @RenderBody()
            </div>
        </div>

    </div>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/vn.js"></script>


    <script src="//cdnjs.cloudflare.com/ajax/libs/toastr.js/2.1.1/toastr.min.js"></script>


    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.bootstrap5.min.js"></script>

    <script src="https://cdn.tiny.cloud/1/vy399c75h6gyw1xkemhoj245q01aqnsusy14yaiket9jmz1h/tinymce/6/tinymce.min.js" referrerpolicy="origin"></script>


    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>


    <script>
        document.getElementById("menu-toggle").addEventListener("click", function(e) {
            e.preventDefault();
            document.getElementById("wrapper").classList.toggle("toggled");
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>