@model Hospital.Models.HoSoBenhAn

@{
    ViewData["Title"] = "Khám bệnh & So sánh lịch sử";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    :root {
        --clinic-primary: #3b82f6;
        --clinic-success: #10b981;
    }

    .card {
        border-radius: 15px;
        border: none;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
    }

    .form-label {
        font-weight: 700;
        color: #475569;
        font-size: 0.85rem;
    }

    /* Timeline Styles */
    .timeline-wrapper {
        max-height: 800px;
        overflow-y: auto;
        overflow-x: hidden;
        padding: 10px 10px 10px 20px;
    }

    .timeline-item {
        position: relative;
        padding-left: 30px;
        margin-bottom: 25px;
        border-left: 2px solid #e2e8f0;
    }

        .timeline-item::before {
            content: '';
            position: absolute;
            left: -9px;
            top: 0;
            width: 16px;
            height: 16px;
            border-radius: 50%;
            background: white;
            border: 3px solid var(--clinic-primary);
            z-index: 5;
        }

    .timeline-content {
        background: #f8fafc;
        border-radius: 12px;
        padding: 15px;
        transition: 0.3s;
        cursor: pointer;
    }

        .timeline-content:hover {
            background: #eff6ff;
            transform: translateX(5px);
        }

    /* Comparison Tools */
    .compare-container {
        display: flex;
        gap: 10px;
        align-items: center;
        justify-content: center;
    }

    .compare-box {
        flex: 1;
        border: 2px dashed #cbd5e1;
        border-radius: 15px;
        overflow: hidden;
        position: relative;
        aspect-ratio: 4/3;
        background: #f1f5f9;
    }

    .compare-label {
        position: absolute;
        top: 10px;
        left: 10px;
        background: rgba(0,0,0,0.6);
        color: white;
        padding: 2px 10px;
        border-radius: 20px;
        font-size: 10px;
        z-index: 5;
    }

    .preview-main-box {
        border: 2px dashed #cbd5e1;
        border-radius: 12px;
        background: #f8fafc;
        min-height: 200px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    #img-main-preview {
        transition: 0.3s;
        cursor: pointer;
    }

        #img-main-preview:hover {
            transform: scale(1.03);
            border: 2px solid var(--clinic-primary);
        }

    .preview-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
        margin-top: 10px;
    }

    .img-thumb-container {
        aspect-ratio: 1/1;
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid #e2e8f0;
        position: relative;
    }

    .img-thumb {
        width: 100%;
        height: 100%;
        object-fit: cover;
        cursor: pointer;
        transition: 0.3s;
    }

        .img-thumb:hover {
            transform: scale(1.1);
            border: 2px solid var(--clinic-primary);
        }

    .btn-delete-img {
        position: absolute;
        top: 2px;
        right: 2px;
        background: rgba(239, 68, 68, 0.9);
        color: white;
        border: none;
        border-radius: 50%;
        width: 22px;
        height: 22px;
        font-size: 12px;
        cursor: pointer;
        z-index: 10;
    }

    /* CSS mới cho phần Phác đồ */
    #box-phac-do {
        border-left: 4px solid var(--clinic-primary);
    }
</style>

<div class="container-fluid py-4">
    <div class="row g-4">
        <div class="col-xl-12" id="mainExamColumn">
            <form id="formKhamBenh" asp-action="HoanTatKham" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="BenhNhanId" />

                <div class="card mb-4 border-start border-primary border-4">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h5 class="fw-bold mb-0 text-primary"><i class="bi bi-person-badge me-2"></i>PHIÊN KHÁM HIỆN TẠI</h5>
                            <span class="badge bg-primary-subtle text-primary px-3 rounded-pill">Bệnh nhân: @Model.BenhNhan?.HoTen</span>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label">Loại da</label>
                                <select asp-for="TinhTrangDa" class="form-select shadow-sm">
                                    <option value="Da dầu">Da dầu</option>
                                    <option value="Da khô">Da khô</option>
                                    <option value="Da hỗn hợp">Da hỗn hợp</option>
                                    <option value="Da nhạy cảm">Da nhạy cảm</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Mức độ bệnh lý</label>
                                <select asp-for="MucDo" class="form-select shadow-sm">
                                    <option value="Nhẹ">Nhẹ</option>
                                    <option value="Trung bình">Trung bình</option>
                                    <option value="Nặng">Nặng</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Vị trí tổn thương</label>
                                <input asp-for="ViTriTonThuong" class="form-control shadow-sm" placeholder="VD: Trán, má..." />
                            </div>
                            <div class="col-md-12">
                                <label class="form-label">Triệu chứng lâm sàng</label>
                                <textarea asp-for="TrieuChung" class="form-control shadow-sm" rows="2"></textarea>
                            </div>

                            @* PHẦN NÂNG CẤP: CHẨN ĐOÁN ICD-10 GỢI Ý *@
                            <div class="col-md-12">
                                <label class="form-label text-danger">Chẩn đoán xác định (ICD-10) *</label>
                                <select id="select-benhly" name="ChanDoan" class="form-control" required>
                                    @if (!string.IsNullOrEmpty(Model.ChanDoan))
                                    {
                                        <option value="@Model.ChanDoan" selected>@Model.ChanDoan</option>
                                    }
                                </select>
                            </div>

                            @* PHẦN NÂNG CẤP: HIỂN THỊ PHÁC ĐỒ *@
                            <div class="col-md-12 mt-2">
                                <div id="box-phac-do" class="alert alert-light border shadow-sm d-none">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <h6 class="mb-0 fw-bold text-primary"><i class="bi bi-journal-check me-2"></i>Phác đồ điều trị gợi ý</h6>
                                        <button type="button" class="btn btn-sm btn-outline-primary rounded-pill" onclick="copyToLoiDan()">
                                            <i class="bi bi-clipboard-plus me-1"></i>Chép vào Lời dặn
                                        </button>
                                    </div>
                                    <div id="noidung-phacdo" class="small text-dark border-top pt-2"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-4 mb-4">
                    <div class="col-md-6">
                        <div class="card h-100">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h6 class="fw-bold mb-0 text-success">Chỉ định dịch vụ</h6>
                                    <button type="button" class="btn btn-sm btn-success rounded-pill px-3" onclick="addService()">+ Thêm</button>
                                </div>
                                <table class="table align-middle"><tbody id="service-body"></tbody></table>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card h-100">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h6 class="fw-bold mb-0 text-danger">Đơn thuốc điều trị</h6>
                                    <button type="button" class="btn btn-sm btn-danger rounded-pill px-3" onclick="addMedicine()">+ Thêm</button>
                                </div>
                                <table class="table table-sm align-middle"><tbody id="prescription-body"></tbody></table>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card mb-4">
                    <div class="card-body p-4">
                        <h6 class="fw-bold mb-4 text-dark"><i class="bi bi-camera-fill me-2 text-primary"></i> Hình ảnh buổi khám hôm nay</h6>
                        <div class="row">
                            <div class="col-md-4">
                                <label class="small fw-bold text-muted d-block mb-2">Ảnh tổng quan (Click ảnh để so sánh)</label>
                                <input type="file" name="anhChinh" class="form-control form-control-sm mb-2" accept="image/*" onchange="previewMainImage(this)" />
                                <div class="preview-main-box">
                                    <img id="img-main-preview" src="/images/no-image.png" class="img-fluid rounded"
                                         style="max-height: 200px;" onclick="setCompareImage(this.src, 'Hôm nay (Tổng quan)', 'after')" />
                                </div>
                            </div>
                            <div class="col-md-8">
                                <div class="d-flex justify-content-between mb-2">
                                    <label class="small fw-bold text-muted">Ảnh chi tiết (Click ảnh để so sánh)</label>
                                    <button type="button" class="btn btn-xs btn-primary py-0" onclick="$('#subFiles').click()">+ Thêm ảnh</button>
                                </div>
                                <input type="file" id="subFiles" name="anhPhu" class="d-none" accept="image/*" multiple />
                                <div id="sub-grid" class="preview-grid"></div>
                            </div>
                        </div>
                        <div class="mt-4">
                            <label class="form-label small fw-bold">Lời dặn bác sĩ</label>
                            <textarea asp-for="LoiDan" id="LoiDan" class="form-control" rows="4"></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 py-3 fw-bold rounded-pill shadow mt-4">
                            <i class="bi bi-check-circle-fill me-2"></i> HOÀN TẤT & LƯU HỒ SƠ KHÁM
                        </button>
                    </div>
                </div>
            </form>
        </div>

        <div class="col-xl-4" id="timelineColumn" style="display:none">
            <div class="card shadow-sm sticky-top" style="top: 85px; height: calc(100vh - 110px);">
                <div class="card-header bg-white py-3 border-0">
                    <h6 class="fw-bold mb-0 text-dark"><i class="bi bi-clock-history me-2 text-primary"></i> Lịch sử & So sánh Ảnh</h6>
                </div>
                <div class="card-body timeline-wrapper" id="timelineArea">
                    <div class="text-center py-5">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p class="mt-2 text-muted small">Đang nạp lịch sử bệnh án...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@* Modal So sánh ảnh *@
<div class="modal fade" id="compareModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold text-dark">PHÂN TÍCH TIẾN TRIỂN DA LIỄU</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div class="compare-container">
                    <div class="compare-box shadow-sm">
                        <span class="compare-label">TRƯỚC (BEFORE)</span>
                        <img id="before-img" src="" class="w-100 h-100" style="object-fit: cover;" />
                    </div>
                    <div class="text-primary fw-bold fs-3"> <i class="bi bi-chevron-right"></i> </div>
                    <div class="compare-box shadow-sm border-primary">
                        <span class="compare-label bg-primary">SAU (AFTER)</span>
                        <img id="after-img" src="" class="w-100 h-100" style="object-fit: cover;" />
                    </div>
                </div>
                <div class="row mt-4 text-center">
                    <div class="col-6"><p id="before-date" class="small fw-bold text-muted mb-0"></p></div>
                    <div class="col-6"><p id="after-date" class="small fw-bold text-primary mb-0"></p></div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let subFilesDataTransfer = new DataTransfer();

        $(document).ready(function() {
            addService();
            addMedicine();
            loadTimeline();

            // --- KHỞI TẠO SELECT2 GỢI Ý BỆNH LÝ ---
            $('#select-benhly').select2({
                theme: 'bootstrap-5',
                placeholder: 'Gõ mã bệnh hoặc tên bệnh để tìm...',
                ajax: {
                    url: '/Admin/HoSoBenhAn/GetBenhLySuggestions', // API bạn đã thêm
                    dataType: 'json',
                    delay: 250,
                    data: function (params) { return { term: params.term }; },
                    processResults: function (data) { return { results: data }; }
                },
                minimumInputLength: 1
            });

            // Sự kiện khi chọn bệnh -> Hiện phác đồ
            $('#select-benhly').on('select2:select', function (e) {
                var benhId = e.params.data.id;
                $.get('/Admin/HoSoBenhAn/GetPhacDoBenh', { id: benhId }, function (data) {
                    if (data && data.phacDo) {
                        $('#box-phac-do').removeClass('d-none');
                        $('#noidung-phacdo').html(data.phacDo);
                    } else {
                        $('#box-phac-do').addClass('d-none');
                    }
                });
            });

            $(document).on('change', 'select[name="selectedDichVu"]', function() {
                var price = $(this).find(':selected').data('price');
                $(this).closest('tr').find('.price-display').val(price ? price + 'đ' : '0đ');
            });

            $('#subFiles').change(function() {
                for (let file of this.files) { subFilesDataTransfer.items.add(file); }
                this.files = subFilesDataTransfer.files;
                renderSubPreviews();
            });
        });

        // Hàm copy phác đồ vào Lời dặn
        function copyToLoiDan() {
            var rawText = document.getElementById('noidung-phacdo').innerText;
            var currentVal = $('#LoiDan').val();
            $('#LoiDan').val(currentVal + "\n--- GỢI Ý ĐIỀU TRỊ ---\n" + rawText);

            Swal.fire({
                icon: 'success', title: 'Đã chép phác đồ!',
                toast: true, position: 'top-end', showConfirmButton: false, timer: 2000
            });
        }

        function loadTimeline() {
            var patientId = '@Model.BenhNhanId';
            var currentId = '@Model.Id';
            $.get('@Url.Action("GetPatientTimeline", "HoSoBenhAn")',
                { benhNhanId: patientId, currentHoSoId: currentId },
                function(data) {
                    if (data && data.trim() !== "") {
                        $('#timelineArea').html(data);
                        $('#timelineColumn').show();
                        $('#mainExamColumn').removeClass('col-xl-12').addClass('col-xl-8');
                    } else {
                        $('#timelineColumn').hide();
                        $('#mainExamColumn').removeClass('col-xl-8').addClass('col-xl-12');
                    }
                });
        }

        function setBeforeImage(url, date) {
            $('#before-img').attr('src', url);
            $('#before-date').text('Trước: ' + date);
            if ($('#after-img').attr('src')) {
                new bootstrap.Modal(document.getElementById('compareModal')).show();
            } else {
                alert("Đã chọn ảnh cũ. Hãy chọn ảnh hiện tại để so sánh.");
            }
        }

        function setCompareImage(url, date, type) {
            if (url.includes("no-image.png")) { alert("Vui lòng chọn file ảnh!"); return; }
            if (type === 'after') {
                $('#after-img').attr('src', url);
                $('#after-date').text('Sau: ' + date);
            }
            if ($('#before-img').attr('src') && $('#after-img').attr('src')) {
                new bootstrap.Modal(document.getElementById('compareModal')).show();
            }
        }

        function previewMainImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function(e) { $('#img-main-preview').attr('src', e.target.result); }
                reader.readAsDataURL(input.files[0]);
            }
        }

        function renderSubPreviews() {
            const container = $('#sub-grid'); container.empty();
            Array.from(subFilesDataTransfer.files).forEach((file, index) => {
                const reader = new FileReader();
                reader.onload = function(e) {
                    container.append(`
                        <div class="img-thumb-container shadow-sm">
                            <button type="button" class="btn-delete-img" onclick="removeSubFile(${index})">&times;</button>
                            <img src="${e.target.result}" class="img-thumb"
                                 onclick="setCompareImage('${e.target.result}', 'Hôm nay', 'after')" />
                        </div>`);
                }
                reader.readAsDataURL(file);
            });
        }

        function removeSubFile(index) {
            const dt = new DataTransfer(); const { files } = subFilesDataTransfer;
            for (let i = 0; i < files.length; i++) { if (i !== index) dt.items.add(files[i]); }
            subFilesDataTransfer = dt;
            document.getElementById('subFiles').files = subFilesDataTransfer.files;
            renderSubPreviews();
        }

        function addService() {
            var row = `<tr>
                <td><select name="selectedDichVu" class="form-select border-0 bg-light rounded-3">
                    <option value="">-- Dịch vụ --</option>
        @foreach (var dv in ViewBag.DichVuList)
        {
            <option value="@dv.DichVuId" data-price="@dv.Gia.ToString("N0")">@dv.TenDichVu</option>
        }
                </select></td>
                <td style="width:100px"><input class="form-control-plaintext small fw-bold price-display" readonly value="0đ" /></td>
                <td class="text-end"><button type="button" class="btn text-danger p-0" onclick="$(this).closest('tr').remove()"><i class="bi bi-trash"></i></button></td>
            </tr>`;
            $('#service-body').append(row);
        }

        function addMedicine() {
            var row = `<tr>
                <td><select name="selectedThuoc" class="form-select border-0 bg-light rounded-3">
                    <option value="">-- Thuốc --</option>
        @foreach (var t in ViewBag.ThuocList)
        {
            <option value="@t.ThuocId">@t.TenThuoc</option>
        }
                </select></td>
                <td style="width:70px"><input type="number" name="soLuong" class="form-control border-0 bg-light" value="1" /></td>
                <td><input name="lieuDung" class="form-control border-0 bg-light" placeholder="Liều dùng..." /></td>
                <td class="text-end"><button type="button" class="btn text-danger p-0" onclick="$(this).closest('tr').remove()"><i class="bi bi-trash"></i></button></td>
            </tr>`;
            $('#prescription-body').append(row);
        }
    </script>
}