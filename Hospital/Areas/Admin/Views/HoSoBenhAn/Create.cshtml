@model Hospital.Models.HoSoBenhAn
@{
    ViewData["Title"] = "Tiếp nhận & Điều phối";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    .clinic-gradient-header {
        background: linear-gradient(135deg, #004e92 0%, #000428 100%);
        color: white;
        padding: 1.5rem;
        border-radius: 15px 15px 0 0;
    }

    .modern-card {
        border: none;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

    .slot-container {
        background-color: #f8f9fa;
        border: 2px dashed #dee2e6;
        border-radius: 10px;
        min-height: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-wrap: wrap;
        gap: 6px;
        padding: 10px;
    }

    .booked-badge {
        font-size: 0.75rem;
        padding: 5px 10px;
        border-radius: 6px;
        background-color: #fee2e2;
        color: #b91c1c;
        border: 1px solid #fecaca;
        font-weight: 600;
    }

    .form-label-custom {
        font-weight: 600;
        font-size: 0.9rem;
        color: #2c3e50;
        margin-bottom: 0.5rem;
        display: block;
    }
</style>

<div class="container-fluid py-4 px-md-5">
    <div class="row justify-content-center">
        <div class="col-xl-10">
            <div class="card modern-card">
                <div class="card-header clinic-gradient-header text-center border-0">
                    <h3 class="fw-bold mb-0">PHIẾU TIẾP NHẬN BỆNH NHÂN</h3>
                    <p class="mb-0 opacity-75">Hệ thống đồng bộ Lịch hẹn & Hồ sơ bệnh án</p>
                </div>

                <div class="card-body p-4 p-md-5 bg-white">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="row g-5">
                            <div class="col-lg-6 border-end">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h6 class="text-uppercase text-muted fw-bold small mb-0">1. Thông tin bệnh nhân</h6>
                                    <a asp-controller="BenhNhan" asp-action="Create" class="btn btn-sm btn-outline-primary fw-bold">
                                        <i class="fas fa-user-plus me-1"></i>Thêm mới
                                    </a>
                                </div>

                                <div class="mb-4">
                                    <label class="form-label-custom">Tìm Bệnh nhân <span class="text-danger">*</span></label>
                                    <select asp-for="BenhNhanId" class="form-select select2" asp-items="ViewBag.BenhNhanId">
                                        <option value="">-- Tìm kiếm tên hoặc SĐT --</option>
                                    </select>
                                    <span asp-validation-for="BenhNhanId" class="text-danger"></span>
                                </div>

                                <div class="mb-4">
                                    <label class="form-label-custom">Triệu chứng/Yêu cầu khám</label>
                                    <textarea asp-for="TrieuChung" class="form-control" rows="5" placeholder="Ví dụ: Da mẩn đỏ, ngứa vùng mặt..."></textarea>
                                </div>
                            </div>

                            <div class="col-lg-6">
                                <h6 class="text-uppercase text-muted fw-bold small mb-4">2. Điều phối khung giờ</h6>

                                <div class="mb-4">
                                    <label class="form-label-custom">Bác sĩ phụ trách <span class="text-danger">*</span></label>
                                    <select asp-for="BacSiId" id="bacSiSelect" class="form-select border-primary" asp-items="ViewBag.BacSiId">
                                        <option value="">-- Chọn bác sĩ trực --</option>
                                    </select>
                                    <span asp-validation-for="BacSiId" class="text-danger"></span>
                                </div>

                                <div class="mb-4">
                                    <label class="form-label-custom text-danger fw-bold"><i class="fas fa-calendar-times me-1"></i> Giờ bác sĩ đã bận (Booked)</label>
                                    <div id="bookedSlotsContainer" class="slot-container shadow-sm">
                                        <span class="text-muted small italic">Vui lòng chọn bác sĩ...</span>
                                    </div>
                                </div>

                                <div class="mb-4">
                                    <label class="form-label-custom text-primary fw-bold">Chọn Khung giờ khám <span class="text-danger">*</span></label>
                                    <select asp-for="KhungGioBatDau" id="selectKhungGio" class="form-select border-primary shadow-sm" disabled>
                                        <option value="">-- Vui lòng chọn bác sĩ trước --</option>
                                    </select>
                                    <span asp-validation-for="KhungGioBatDau" class="text-danger"></span>
                                </div>

                                <div class="mb-4">
                                    <label class="form-label-custom text-success fw-bold">Dịch vụ chỉ định <span class="text-danger">*</span></label>
                                    <select id="dichVuSelect" name="DichVuId" class="form-select border-success" disabled required>
                                        <option value="">-- Chọn dịch vụ --</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <input type="hidden" name="LichLamViecId" id="hfLichLamViecId" />

                        <hr class="my-5">
                        <div class="d-flex gap-3 justify-content-center">
                            <button type="submit" class="btn btn-primary px-5 py-3 fw-bold shadow-lg" style="border-radius: 12px; min-width: 250px;">
                                <i class="fas fa-check-circle me-2"></i>HOÀN TẤT TIẾP NHẬN
                            </button>
                            <a asp-action="Index" class="btn btn-light px-5 py-3 fw-bold" style="border-radius: 12px;">HỦY BỎ</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Chuyển "08:30" thành 510 phút
        function timeToMinutes(timeStr) {
            if (!timeStr) return 0;
            var parts = timeStr.split(':');
            return parseInt(parts[0]) * 60 + parseInt(parts[1]);
        }

        // Chia nhỏ ca trực thành các slot giờ khám
        function generateSlots(start, end, duration, bookedSlots) {
            var slots = [];
            var current = timeToMinutes(start);
            var last = timeToMinutes(end);

            while (current + duration <= last) {
                var h = Math.floor(current / 60);
                var m = current % 60;
                var timeValue = ('0' + h).slice(-2) + ':' + ('0' + m).slice(-2);

                // Kiểm tra xem giờ này đã nằm trong mảng bookedSlots chưa
                var isBooked = bookedSlots.includes(timeValue);

                slots.push({
                    value: timeValue + ':00',
                    text: timeValue,
                    status: isBooked ? 'booked' : 'free'
                });
                current += duration;
            }
            return slots;
        }

        $(document).ready(function() {
            // Khởi tạo Select2 cho ô tìm kiếm bệnh nhân
            $('.select2').select2({ theme: 'bootstrap-5' });

            $('#bacSiSelect').change(function() {
                var doctorId = $(this).val();
                var $kgSelect = $('#selectKhungGio');
                var $dvSelect = $('#dichVuSelect');
                var $container = $('#bookedSlotsContainer');

                if (doctorId) {
                    $kgSelect.empty().append('<option>Đang tải dữ liệu...</option>');

                    $.ajax({
                        url: '@Url.Action("GetDoctorShiftData", "HoSoBenhAn")',
                        type: 'GET',
                        data: { bacSiId: doctorId },
                        success: function(data) {
                            // 1. Load Dịch vụ theo chuyên khoa bác sĩ
                            $dvSelect.empty().append('<option value="">-- Chọn dịch vụ --</option>').prop('disabled', false);
                            $.each(data.services, function(i, v) {
                                $dvSelect.append($('<option>', { value: v.value, text: v.text + " (" + v.gia + "đ)" }));
                            });

                            // 2. Load Khung giờ
                            $container.empty();
                            $kgSelect.empty().append('<option value="">-- Chọn khung giờ khám --</option>').prop('disabled', false);

                            if (data.shiftInfo) {
                                $('#hfLichLamViecId').val(data.shiftInfo.id);
                                var slots = generateSlots(data.shiftInfo.start, data.shiftInfo.end, data.shiftInfo.duration, data.bookedSlots);

                                if(data.bookedSlots.length === 0) {
                                    $container.append('<span class="text-success small">Bác sĩ hiện đang trống lịch cả ca trực.</span>');
                                }

                                $.each(slots, function(i, s) {
                                    if (s.status === 'booked') {
                                        // Badge hiển thị giờ bận
                                        $container.append('<span class="booked-badge">' + s.text + '</span>');
                                        // Option bị vô hiệu hóa trong select
                                        $kgSelect.append(`<option value="${s.value}" disabled style="color:#dc3545">${s.text} - ĐÃ BẬN</option>`);
                                    } else {
                                        $kgSelect.append(`<option value="${s.value}">${s.text}</option>`);
                                    }
                                });
                            } else {
                                $kgSelect.append('<option value="">Bác sĩ không có lịch trực hôm nay</option>').prop('disabled', true);
                                $container.append('<span class="text-danger small">Không tìm thấy ca trực.</span>');
                            }
                        }
                    });
                } else {
                    $kgSelect.prop('disabled', true).empty().append('<option>-- Vui lòng chọn bác sĩ trước --</option>');
                    $dvSelect.prop('disabled', true).empty().append('<option>-- Chọn dịch vụ --</option>');
                    $container.empty().append('<span class="text-muted small">Chọn bác sĩ để xem lịch bận...</span>');
                }
            });
        });
    </script>
}