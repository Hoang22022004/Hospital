@model Hospital.Models.HoSoBenhAn

@{
    ViewData["Title"] = "Chi tiết hồ sơ bệnh án";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    /* --- GIAO DIỆN WEB (Hiển thị đầy đủ ảnh, không bị cắt) --- */
    .img-main-web {
        width: 100%;
        height: auto; /* Hiển thị toàn bộ tỷ lệ ảnh trên web */
        border-radius: 8px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        border: 1px solid #eee;
    }

    .skin-gallery-web {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
        gap: 12px;
        margin-top: 10px;
    }

    .gallery-item-web img {
        width: 100%;
        height: auto; /* Không cắt ảnh phụ trên web */
        border-radius: 6px;
        border: 1px solid #ddd;
        transition: transform 0.2s;
        cursor: zoom-in;
    }

        .gallery-item-web img:hover {
            transform: scale(1.02);
        }

    /* --- GIAO DIỆN IN (Ép gọn 1 trang A4) --- */
    @@media print {
        @@page {
            size: A4;
            margin: 8mm;
        }
        /* Ẩn Menu/Sidebar Admin hoàn toàn */
        .no-print, nav, aside, .main-header, .navbar, .footer, .btn, .navbar-toggler {
            display: none !important;
        }

        body, .content-wrapper, .container-fluid {
            margin: 0 !important;
            padding: 0 !important;
            width: 100% !important;
            position: absolute !important;
            left: 0 !important;
            top: 0 !important;
            background: white !important;
        }
        /* Ép 2 cột luôn nằm ngang khi in */
        .row {
            display: flex !important;
            flex-wrap: nowrap !important;
            margin: 0 !important;
        }

        .col-lg-8 {
            width: 68% !important;
            flex: 0 0 68% !important;
            padding-right: 15px !important;
        }

        .col-lg-4 {
            width: 32% !important;
            flex: 0 0 32% !important;
            border-left: 1px solid #eee !important;
            padding-left: 10px !important;
        }
        /* Thu nhỏ ảnh khi in để không nhảy trang */
        .img-main-web {
            max-height: 130px !important;
            width: auto !important;
            object-fit: contain !important;
        }

        .gallery-item-web img {
            max-height: 50px !important;
            object-fit: contain !important;
        }

        body {
            font-size: 11px !important;
        }

        .card {
            border: none !important;
            box-shadow: none !important;
        }

        .table-sm td, .table-sm th {
            padding: 0.3rem !important;
        }
    }
</style>

<div class="container-fluid py-2">
    <div class="d-flex justify-content-between mb-2 no-print">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary rounded-pill px-3">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
        <button onclick="window.print()" class="btn btn-sm btn-primary rounded-pill px-4 shadow">
            <i class="bi bi-printer me-2"></i> In Phiếu Khám & Hóa Đơn
        </button>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <div class="row g-0">
                <div class="col-lg-8">
                    <div class="d-flex justify-content-between border-bottom pb-2 mb-2">
                        <div>
                            <h5 class="fw-bold text-primary mb-0 uppercase">PHÒNG KHÁM DA LIỄU ABC</h5>
                            <small class="text-muted">Mã HS: #@Model.Id | Ngày khám: @Model.NgayKham.ToString("dd/MM/yyyy")</small>
                        </div>
                        <div class="text-end">
                            <small class="italic">Bác sĩ khám:</small>
                            <h6 class="fw-bold text-primary mb-0">BS. @Model.BacSi?.HoTen</h6>
                        </div>
                    </div>

                    <div class="row mb-3 bg-light p-2 rounded mx-0">
                        <div class="col-7">
                            <small class="text-muted d-block">Bệnh nhân:</small>
                            <span class="fw-bold text-uppercase fs-6">@Model.BenhNhan?.HoTen</span>
                        </div>
                        <div class="col-5 text-end pt-2">
                            <span class="badge bg-info bg-opacity-10 text-info px-2">Da: @Model.TinhTrangDa</span>
                            <span class="badge bg-danger bg-opacity-10 text-danger px-2 ms-1">Mức độ: @Model.MucDo</span>
                        </div>
                    </div>

                    <div class="mb-3 border-start border-primary border-4 ps-2">
                        <p class="mb-1"><strong>Vị trí:</strong> @Model.ViTriTonThuong | <strong>Triệu chứng:</strong> @Model.TrieuChung</p>
                        <p class="mb-0 text-danger fw-bold text-uppercase">Chẩn đoán: @Model.ChanDoan</p>
                    </div>

                    <h6 class="fw-bold small mb-1 text-primary"><i class="bi bi-gear-fill"></i> DỊCH VỤ KỸ THUẬT</h6>
                    <table class="table table-sm table-bordered mb-2" style="font-size: 11px;">
                        <thead class="bg-light text-uppercase">
                            <tr>
                                <th>Tên dịch vụ đã thực hiện</th>
                                <th class="text-end" width="120">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.ChiTietDichVus != null && Model.ChiTietDichVus.Any())
                            {
                                foreach (var dv in Model.ChiTietDichVus)
                                {
                                    <tr>
                                        @* In đậm tên dịch vụ đồng bộ với thuốc *@
                                        <td><strong>@dv.DichVu.TenDichVu</strong></td>
                                        <td class="text-end fw-bold">@dv.DichVu.Gia.ToString("N0") đ</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="2" class="text-center text-muted italic small">Không có dịch vụ chỉ định</td></tr>
                            }
                        </tbody>
                    </table>

                    <h6 class="fw-bold small mb-1 text-success mt-3"><i class="bi bi-capsule"></i> ĐƠN THUỐC ĐIỀU TRỊ</h6>
                    <table class="table table-sm table-bordered mb-2" style="font-size: 11px;">
                        <thead class="bg-light text-uppercase">
                            <tr>
                                <th>Tên thuốc & Liều dùng</th>
                                <th class="text-center" width="60">SL</th>
                                <th class="text-end" width="100">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.ChiTietDonThuocs != null && Model.ChiTietDonThuocs.Any())
                            {
                                foreach (var t in Model.ChiTietDonThuocs)
                                {
                                    <tr>
                                        @* Tên thuốc in đậm *@
                                        <td><strong>@t.Thuoc.TenThuoc</strong> <br /> <small class="text-muted italic">@t.LieuDung</small></td>
                                        <td class="text-center">@t.SoLuong</td>
                                        <td class="text-end fw-bold">@((t.SoLuong * t.Thuoc.GiaBan).ToString("N0")) đ</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="3" class="text-center text-muted italic small">Không có thuốc chỉ định</td></tr>
                            }
                        </tbody>
                    </table>

                    <div class="row g-0 border-top pt-2">
                        <div class="col-7 p-2 border rounded bg-light" style="font-size: 11px; min-height: 60px;">
                            <strong class="text-dark">Lời dặn bác sĩ:</strong> <br />
                            <span class="italic">@Model.LoiDan</span>
                            @if (Model.NgayTaiKham.HasValue)
                            {
                                <div class="fw-bold text-danger mt-1">Hẹn tái khám: @Model.NgayTaiKham.Value.ToString("dd/MM/yyyy")</div>
                            }
                        </div>
                        <div class="col-5 ps-3 text-end">
                            <div class="small">Tạm tính dịch vụ: <strong>@ViewBag.TongDichVu.ToString("N0") đ</strong></div>
                            <div class="small">Tạm tính đơn thuốc: <strong>@ViewBag.TongThuoc.ToString("N0") đ</strong></div>
                            <div class="fw-bold text-primary mt-1" style="font-size: 16px; border-top: 1px dashed #ccc;">
                                TỔNG CỘNG: @ViewBag.TongTien.ToString("N0") đ
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4 d-flex flex-column border-start ps-3">
                    <h6 class="fw-bold small mb-2 text-uppercase text-secondary"><i class="bi bi-images"></i> Tư liệu hình ảnh</h6>

                    @{
                        var mainImg = Model.HinhAnhBenhAns?.FirstOrDefault(a => a.LaAnhChinh);
                    }
                    <div class="text-center mb-2">
                        @* Ảnh chính: Cao tự động trên web, giới hạn khi in *@
                        <img src="@(mainImg?.DuongDan ?? "/images/no-image.png")" class="img-main-web" />
                        <div class="small text-muted mt-1" style="font-size: 9px;">Ảnh tổng quát vùng tổn thương</div>
                    </div>

                    <div class="skin-gallery-web">
                        @if (Model.HinhAnhBenhAns != null)
                        {
                            foreach (var img in Model.HinhAnhBenhAns.Where(a => !a.LaAnhChinh).Take(4))
                            {
                                <div class="gallery-item-web">
                                    <img src="@img.DuongDan" />
                                </div>
                            }
                        }
                    </div>

                    <div class="mt-auto pt-4 border-top">
                        <div class="row text-center" style="font-size: 11px;">
                            <div class="col-6">
                                <p class="mb-5 small">Bệnh nhân</p>
                                <strong class="text-uppercase">@Model.BenhNhan?.HoTen</strong>
                            </div>
                            <div class="col-6">
                                <p class="mb-5 small">Bác sĩ khám</p>
                                <strong class="text-primary text-uppercase">BS. @Model.BacSi?.HoTen</strong>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>