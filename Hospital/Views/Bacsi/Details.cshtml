@model Hospital.Models.BacSi

@{
    ViewData["Title"] = "Bác sĩ " + Model.HoTen + " - Hello Paris";
}

<style>
    /* --- Khung Header Profile --- */
    .dr-details-header {
        background: #F0F7FF; /* Màu xanh nhạt đồng bộ hệ thống */
        padding: 80px 0 50px;
        border-radius: 0 0 80px 80px;
        margin-bottom: 50px;
    }

    /* --- Ảnh Bác sĩ Chuyên nghiệp --- */
    .dr-details-img-box {
        position: relative;
        border-radius: 30px;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(0, 45, 91, 0.1);
        background: #fff;
    }

        .dr-details-img-box img {
            width: 100%;
            height: 500px;
            object-fit: cover;
        }

    /* --- Badge Chuyên khoa --- */
    .badge-chuyen-khoa {
        background: rgba(69, 195, 210, 0.1);
        color: #45c3d2;
        padding: 8px 20px;
        border-radius: 50px;
        font-weight: 700;
        display: inline-block;
        margin-bottom: 15px;
    }

    /* --- Typography --- */
    .dr-name-big {
        font-family: 'Playfair Display', serif;
        font-size: 3rem;
        color: #002d5b;
        font-weight: 700;
        margin-bottom: 10px;
    }

    .dr-degree-sub {
        font-size: 1.25rem;
        color: #64748b;
        font-style: italic;
        margin-bottom: 30px;
    }

    /* --- Khối nội dung chi tiết (Dấu tích xanh) --- */
    .dr-content-card {
        background: #ffffff;
        border-radius: 25px;
        padding: 40px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        border: 1px solid #f1f5f9;
    }

        .dr-content-card h4 {
            color: #002d5b;
            font-weight: 700;
            margin-bottom: 25px;
            padding-bottom: 15px;
            border-bottom: 2px solid #f1f5f9;
            display: flex;
            align-items: center;
        }

            .dr-content-card h4 i {
                color: #45c3d2;
                margin-right: 15px;
            }

    /* CSS xử lý danh sách dấu tích xanh từ nội dung HTML */
    .dr-bio-text ul {
        list-style: none !important;
        padding-left: 0 !important;
    }

        .dr-bio-text ul li {
            position: relative;
            padding-left: 35px;
            margin-bottom: 15px;
            font-size: 1.1rem;
            color: #475569;
            line-height: 1.6;
        }

            .dr-bio-text ul li::before {
                content: "\F272";
                font-family: "bootstrap-icons" !important;
                position: absolute;
                left: 0;
                top: 2px;
                color: #45c3d2;
                font-size: 1.2rem;
            }

    /* --- Nút bấm hành động --- */
    .sticky-booking-card {
        position: sticky;
        top: 100px;
        background: #002d5b;
        border-radius: 25px;
        padding: 30px;
        color: #fff;
        text-align: center;
    }

    .btn-white-pill {
        background: #fff;
        color: #002d5b;
        border-radius: 50px;
        padding: 12px 30px;
        font-weight: 700;
        transition: 0.3s;
        display: block;
        width: 100%;
        text-decoration: none;
    }

        .btn-white-pill:hover {
            background: #45c3d2;
            color: #fff;
            transform: translateY(-3px);
        }
</style>

@* --- GIAO DIỆN CHI TIẾT --- *@

<section class="dr-details-header animate__animated animate__fadeIn">
    <div class="container">
        <div class="row align-items-center">
            @* Ảnh bác sĩ *@
            <div class="col-lg-5 mb-4 mb-lg-0">
                <div class="dr-details-img-box">
                    <img src="@(string.IsNullOrEmpty(Model.HinhAnhUrl) ? "/images/default-doctor.jpg" : Model.HinhAnhUrl)"
                         alt="@Model.HoTen">
                </div>
            </div>

            @* Thông tin cơ bản *@
            <div class="col-lg-7 ps-lg-5">
                <nav aria-label="breadcrumb" class="mb-4">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                        <li class="breadcrumb-item"><a asp-controller="BacSi" asp-action="Index">Đội ngũ bác sĩ</a></li>
                        <li class="breadcrumb-item active">@Model.HoTen</li>
                    </ol>
                </nav>

                <div class="badge-chuyen-khoa">
                    <i class="bi bi-shield-check me-2"></i> @(Model.ChuyenKhoa?.TenChuyenKhoa ?? "Chuyên gia Da liễu")
                </div>
                <h1 class="dr-name-big Montserrat">Bác sĩ @Model.HoTen</h1>
                <p class="dr-degree-sub">@Model.BangCap</p>

                <div class="d-flex gap-3 mt-4">
                    <div class="text-center px-4 border-end">
                        <h4 class="fw-bold text-navy mb-0">15+</h4>
                        <small class="text-muted">Năm kinh nghiệm</small>
                    </div>
                    <div class="text-center px-4">
                        <h4 class="fw-bold text-navy mb-0">10k+</h4>
                        <small class="text-muted">Khách hàng hài lòng</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="pb-5">
    <div class="container">
        <div class="row">
            @* Cột trái: Nội dung chi tiết *@
            <div class="col-lg-8">
                <div class="dr-content-card mb-4">
                    <h4><i class="bi bi-journal-text"></i> TIỂU SỬ & QUÁ TRÌNH CÔNG TÁC</h4>
                    <div class="dr-bio-text lh-lg text-muted">
                        @Html.Raw(Model.MoTaChiTiet)
                    </div>
                </div>

                @* Bạn có thể thêm các phần như: Chứng chỉ, Công trình nghiên cứu... *@
            </div>

            @* Cột phải: Card đặt lịch nhanh *@
            <div class="col-lg-4">
                <div class="sticky-booking-card shadow-lg">
                    <i class="bi bi-calendar2-check mb-3 d-block" style="font-size: 3rem; color: #45c3d2;"></i>
                    <h5 class="fw-bold mb-3">ĐẶT LỊCH HẸN VỚI BÁC SĨ</h5>
                    <p class="small opacity-75 mb-4">Hãy chọn khung giờ phù hợp để bác sĩ có thể tư vấn tốt nhất cho bạn.</p>

                    <a href="/DatLich?bacSiId=@Model.BacSiId" class="btn-white-pill mb-3">
                        ĐẶT LỊCH NGAY
                    </a>

                    <a href="https://zalo.me/0905280482" target="_blank" class="btn btn-outline-light rounded-pill w-100 fw-bold py-2">
                        <i class="bi bi-chat-dots me-2"></i>TƯ VẤN QUA ZALO
                    </a>

                    <div class="mt-4 pt-4 border-top border-light border-opacity-10">
                        <small class="d-block mb-2"><i class="bi bi-telephone-fill me-2"></i>Hotline hỗ trợ 24/7:</small>
                        <h5 class="fw-bold text-teal">090 528 04 82</h5>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>