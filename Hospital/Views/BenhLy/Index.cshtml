@model IEnumerable<Hospital.Models.BenhLy>

<section class="py-5 bg-light">
    <div class="container mt-5">
        <div class="text-center mb-5">
            <h2 class="fw-bold text-uppercase color-primary">Kiến thức Da liễu</h2>
            <p class="text-muted">Tra cứu thông tin và phác đồ điều trị chuẩn y khoa</p>
            <div class="mx-auto bg-primary" style="height: 3px; width: 60px;"></div>
        </div>

        @* Ô tìm kiếm nhanh *@
        <div class="row justify-content-center mb-5">
            <div class="col-md-6">
                <form asp-action="Index" method="get" class="d-flex shadow-sm rounded-pill overflow-hidden bg-white">
                    @* Thêm value để giữ lại từ khóa tìm kiếm khi chuyển trang *@
                    <input type="text" name="searchString" value="@ViewBag.CurrentSearch" class="form-control border-0 ps-4 py-3" placeholder="Tìm tên bệnh hoặc mã ICD-10...">
                    <button type="submit" class="btn btn-primary px-4"><i class="bi bi-search"></i></button>
                </form>
            </div>
        </div>

        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-lg-3 col-md-6">
                    <div class="card h-100 border-0 shadow-sm hover-top overflow-hidden">
                        <img src="@(string.IsNullOrEmpty(item.HinhAnhUrl) ? "/images/no-image.png" : item.HinhAnhUrl)"
                             class="card-img-top" style="height: 200px; object-fit: cover;">
                        <div class="card-body">
                            <h6 class="fw-bold text-dark mb-2">@item.TenBenhLy.ToUpper()</h6>
                            <span class="badge bg-light text-primary border mb-3">Mã: @item.BenhLyId</span>
                            <div class="d-grid">
                                <a asp-action="Details" asp-route-id="@item.BenhLyId" class="btn btn-outline-primary btn-sm rounded-pill">Xem chi tiết</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @* ================= PHẦN PHÂN TRANG (MỚI THÊM) ================= *@
        @if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
        {
            int currentPage = ViewBag.CurrentPage;
            int totalPages = ViewBag.TotalPages;
            string searchString = ViewBag.CurrentSearch;

            <div class="row mt-5">
                <div class="col-12 d-flex justify-content-center">
                    <nav aria-label="Page navigation">
                        <ul class="pagination pagination-lg shadow-sm rounded-pill overflow-hidden">

                            @* Nút Previous (Trang trước) *@
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <a class="page-link border-0" href="@Url.Action("Index", new { page = currentPage - 1, searchString = searchString })">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li>

                            @* Các số trang (1, 2, 3...) *@
                            @for (int i = 1; i <= totalPages; i++)
                            {
                                <li class="page-item @(currentPage == i ? "active" : "")">
                                    <a class="page-link border-0 @(currentPage == i ? "bg-primary text-white" : "text-dark")"
                                       href="@Url.Action("Index", new { page = i, searchString = searchString })">@i</a>
                                </li>
                            }

                            @* Nút Next (Trang tiếp) *@
                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <a class="page-link border-0" href="@Url.Action("Index", new { page = currentPage + 1, searchString = searchString })">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>

                        </ul>
                    </nav>
                </div>
            </div>
        }
        @* ================= KẾT THÚC PHẦN PHÂN TRANG ================= *@

    </div>
</section>