<section class="process-tree-section overflow-hidden">
    <div class="container">
        @* Tiêu đề Section *@
        <div class="text-center mb-5 animate__animated animate__fadeIn">
            <h2 class="fw-bold text-navy Montserrat uppercase">HÀNH TRÌNH NHAN SẮC</h2>
            <p class="text-muted small ls-2">QUY TRÌNH ĐIỀU TRỊ SO LE CHUẨN Y KHOA</p>
        </div>

        <div class="process-tree-container position-relative">
            @* Thân cây chính chạy dọc giữa *@
            <div class="tree-trunk"></div>

            @* BƯỚC 1 - NỘI DUNG BÊN PHẢI *@
            <div class="tree-item right animate__animated animate__fadeInRight">
                @* Node nằm trước để sát trục giữa *@
                <div class="tree-node"><i class="bi bi-calendar2-check"></i></div>
                <div class="tree-content shadow-sm">
                    <div class="step-tag">Bước 01</div>
                    <h5 class="fw-bold text-navy">Đăng ký & Hẹn lịch</h5>
                    <p class="small text-muted mb-0">Bắt đầu hành trình tại phía bên phải của cây quy trình bằng việc đặt lịch hẹn trên hệ thống.</p>
                </div>
            </div>

            @* BƯỚC 2 - NỘI DUNG BÊN TRÁI *@
            <div class="tree-item left animate__animated animate__fadeInLeft">
                @* Content nằm trước để đẩy Node vào sát trục giữa *@
                <div class="tree-content shadow-sm">
                    <div class="step-tag">Bước 02</div>
                    <h5 class="fw-bold text-navy">Soi da & Chẩn đoán</h5>
                    <p class="small text-muted mb-0">Di chuyển sang phía trái để bác sĩ soi da và phân tích chuyên sâu các chỉ số.</p>
                </div>
                <div class="tree-node"><i class="bi bi-person-video3"></i></div>
            </div>

            @* BƯỚC 3 - NỘI DUNG BÊN PHẢI *@
            <div class="tree-item right animate__animated animate__fadeInRight">
                <div class="tree-node"><i class="bi bi-clipboard2-pulse"></i></div>
                <div class="tree-content shadow-sm">
                    <div class="step-tag">Bước 03</div>
                    <h5 class="fw-bold text-navy">Phác đồ cá nhân</h5>
                    <p class="small text-muted mb-0">Quay lại phía bên phải để nhận phác đồ điều trị riêng biệt được cá nhân hóa.</p>
                </div>
            </div>

            @* BƯỚC 4 - NỘI DUNG BÊN TRÁI *@
            <div class="tree-item left animate__animated animate__fadeInLeft">
                <div class="tree-content shadow-sm">
                    <div class="step-tag">Bước 04</div>
                    <h5 class="fw-bold text-navy">Tiến hành trị liệu</h5>
                    <p class="small text-muted mb-0">Tiếp tục bên trái với các công nghệ điều trị hiện đại đạt chuẩn vô trùng.</p>
                </div>
                <div class="tree-node"><i class="bi bi-magic"></i></div>
            </div>

            @* BƯỚC 5 - KẾT THÚC Ở GIỮA *@
            <div class="tree-item center animate__animated animate__zoomIn">
                <div class="tree-node final" style="background: #28a745;"><i class="bi bi-stars"></i></div>
                <div class="tree-content shadow-sm text-center">
                    <div class="step-tag">Bước 05</div>
                    <h5 class="fw-bold text-navy">Hoàn tất & Chăm sóc</h5>
                    <p class="small text-muted mb-0">Kết thúc hành trình tại tâm điểm với kết quả làn da hoàn hảo nhất.</p>
                </div>
            </div>
        </div>
    </div>
</section>