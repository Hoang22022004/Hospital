@model IEnumerable<Hospital.Models.BacSi>
@using Hospital.Models
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@{
    ViewData["Title"] = "Trang chủ - Hello Paris Clinic";

    // Ép kiểu dữ liệu từ ViewBag để truyền vào các Partial View
    var listTinTuc = ViewBag.ListTinTuc as IEnumerable<Hospital.Models.TinTuc>;
    var listBenhLy = ViewBag.ListBenhLy as IEnumerable<Hospital.Models.BenhLy>;
}

@section Styles {
    @* Các tệp CSS đồng bộ cho hệ thống Hello Paris *@
    <link rel="stylesheet" href="~/css/home_hero.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/home_search.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/why-choose.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/home_doctors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/services.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/process-tree.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/news.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/disease.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/results.css" asp-append-version="true" />

    @* Thư viện Swiper CSS *@
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
}

@* --- CẤU TRÚC GIAO DIỆN TRANG CHỦ (ĐÃ SẮP XẾP LẠI) --- *@

@* 1. Banner chính *@
<partial name="_HeroPartial" />

@* 2. Thanh tìm kiếm thông minh *@
<partial name="_SearchPartial" />

@* 3. Section: Tại sao nên chọn Hello Paris *@
<partial name="_WhyChoosePartial" />

@* 4. Section: Đội ngũ chuyên gia *@
<partial name="~/Views/Bacsi/_DoctorsPartial.cshtml" model="Model" />

@* 5. Section: Gói Dịch vụ nổi bật *@
<partial name="~/Views/DichVu/_ServicePartial.cshtml" />

@* 6. Section: Quy trình thăm khám *@
<partial name="_ProcessTree" />

@* 7. Section: Danh mục Bệnh lý (Tra cứu ICD-10) *@
<partial name="~/Views/BenhLy/_BenhLyPartial.cshtml" model="listBenhLy" />

@* --- THAY ĐỔI VỊ TRÍ TẠI ĐÂY --- *@

@* 8. Section: Tin tức & Kiến thức y khoa (Đưa lên trên Kết quả) *@
<partial name="~/Views/TinTuc/_NewsPartial.cshtml" model="listTinTuc" />

@* 9. Section: Kết quả sau điều trị (Đưa xuống sau Tin tức) *@
<partial name="_KetQuaDieuTriPartial" />

@* ------------------------------ *@

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

    <script>
        $(document).ready(function () {
            // --- KHỞI TẠO CÁC SLIDER (GIỮ NGUYÊN) ---
            new Swiper(".whyChooseSwiper", {
                loop: true,
                autoplay: { delay: 4000 },
                pagination: { el: ".swiper-pagination", clickable: true },
                effect: "fade"
            });

            new Swiper(".leftImageSwiper", {
                loop: true,
                speed: 1000,
                navigation: { nextEl: ".srv-right-arrow", prevEl: ".srv-left-arrow" },
                pagination: { el: ".swiper-pagination", clickable: true },
            });

            new Swiper(".rightServiceSwiper", {
                slidesPerView: 1.5,
                spaceBetween: 25,
                grabCursor: true,
                autoplay: { delay: 3500, disableOnInteraction: false },
                pagination: { el: ".srv-pagination-pill", clickable: true },
                breakpoints: {
                    768: { slidesPerView: 2.5 },
                    1024: { slidesPerView: 3 }
                }
            });

            new Swiper(".diseaseSwiper", {
                slidesPerView: 1.2,
                spaceBetween: 20,
                grabCursor: true,
                autoplay: { delay: 4500, disableOnInteraction: false },
                pagination: { el: ".disease-pagination-pill", clickable: true },
                breakpoints: {
                    768: { slidesPerView: 2.5 },
                    1024: { slidesPerView: 4 }
                }
            });

            new Swiper(".newsSwiper", {
                slidesPerView: 1.2,
                spaceBetween: 25,
                grabCursor: true,
                autoplay: { delay: 5000, disableOnInteraction: false },
                pagination: { el: ".news-pagination-pill", clickable: true },
                breakpoints: {
                    768: { slidesPerView: 2.2 },
                    1024: { slidesPerView: 3.2 }
                }
            });

            new Swiper(".resultsSwiper", {
                slidesPerView: 1,
                spaceBetween: 30,
                loop: true,
                allowTouchMove: false,
                autoplay: { delay: 5000, disableOnInteraction: false },
                navigation: {
                    nextEl: ".result-next",
                    prevEl: ".result-prev"
                }
            });

            // --- LOGIC XỬ LÝ TÌM KIẾM GIỮ NGUYÊN ---
            const $searchInput = $('#mainSearchInput');
            const $liveResults = $('#liveResults');
            const $resultsList = $('#resultsList');

            $searchInput.on('input', function () {
                const term = $(this).val();
                if (term.length > 0) {
                    $.ajax({
                        url: '/Home/GetSearchSuggestions',
                        type: 'GET',
                        data: { term: term },
                        success: function (data) {
                            $resultsList.empty();
                            if (data.length > 0) {
                                $liveResults.show();
                                data.forEach(item => {
                                    let mediaHtml = item.img
                                        ? `<img src="${item.img}" class="search-result-img" style="width:40px; height:40px; object-fit:cover; border-radius:8px;">`
                                        : `<div class="search-result-icon-placeholder" style="width:40px; height:40px; display:flex; align-items:center; justify-content:center; background:#f1f5f9; border-radius:8px;"><i class="bi bi-search"></i></div>`;

                                    $resultsList.append(`
                                        <li>
                                            <a href="${item.url}" class="d-flex align-items-center p-3 text-decoration-none border-bottom hover-bg-light">
                                                <div class="me-3">${mediaHtml}</div>
                                                <div>
                                                    <span class="d-block fw-bold text-dark">${item.title}</span>
                                                    <small class="text-muted">${item.desc || 'Hello Paris Clinic'}</small>
                                                </div>
                                            </a>
                                        </li>`);
                                });
                            } else {
                                $resultsList.html('<li class="p-4 text-center text-muted small">Không tìm thấy kết quả phù hợp...</li>');
                                $liveResults.show();
                            }
                        }
                    });
                } else {
                    $liveResults.hide();
                }
            });

            $(document).on('click', function(e) {
                if (!$(e.target).closest('.search-container').length) {
                    $liveResults.hide();
                }
            });
        });
    </script>
}