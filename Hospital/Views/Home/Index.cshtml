@model IEnumerable<Hospital.Models.BacSi>

@{
    ViewData["Title"] = "Trang chủ";
}

@section Styles {
    @* Gọi các tệp CSS đã được tối ưu đồng bộ màu sắc và bố cục *@
    <link rel="stylesheet" href="~/css/home_hero.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/home_search.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/home_doctors.css" asp-append-version="true" />
}

@* 1. Phần Banner chính *@
<partial name="_HeroPartial" />

@* 2. Thanh tìm kiếm (Vị trí 50% Banner - 50% Bác sĩ) *@
<partial name="_SearchPartial" />

@* 3. Phần Đội ngũ chuyên gia (Nền màu #f8fafc đồng bộ) *@
<partial name="_DoctorsPartial" model="Model" />

@section Scripts {
    <script>
        $(document).ready(function () {
            const $searchInput = $('#mainSearchInput');
            const $liveResults = $('#liveResults');
            const $resultsList = $('#resultsList');

            // Logic xử lý tìm kiếm thời gian thực khi người dùng gõ chữ
            $searchInput.on('input', function () {
                const term = $(this).val();

                if (term.length > 0) {
                    // Gọi API lấy gợi ý từ Database
                    $.ajax({
                        url: '/Home/GetSearchSuggestions',
                        type: 'GET',
                        data: { term: term },
                        success: function (data) {
                            $resultsList.empty();

                            if (data.length > 0) {
                                $liveResults.show();
                                data.forEach(item => {
                                    let mediaHtml = '';

                                    // Xử lý hiển thị Ảnh hoặc Icon tùy loại dữ liệu
                                    if (item.img && item.img.trim() !== '') {
                                        mediaHtml = `<img src="${item.img}" class="search-result-img">`;
                                    } else {
                                        let iconClass = 'bi-search';
                                        if (item.type === 'doctor') iconClass = 'bi-person-circle';
                                        if (item.type === 'disease') iconClass = 'bi-capsule-pill';
                                        if (item.type === 'service') iconClass = 'bi-activity';
                                        if (item.type === 'news') iconClass = 'bi-journal-text';

                                        mediaHtml = `<div class="search-result-icon-placeholder"><i class="bi ${iconClass}"></i></div>`;
                                    }

                                    // Đổ dữ liệu vào danh sách hiển thị
                                    $resultsList.append(`
                                        <li>
                                            <a href="${item.url}" class="d-flex align-items-center p-3 text-decoration-none border-bottom">
                                                <div class="me-3">${mediaHtml}</div>
                                                <div>
                                                    <span class="d-block fw-bold text-dark">${item.title}</span>
                                                    <small class="text-muted">${item.desc || 'Hello Paris Clinic'}</small>
                                                </div>
                                            </a>
                                        </li>
                                    `);
                                });
                            } else {
                                // Hiển thị thông báo nếu không có kết quả
                                $resultsList.html('<li class="p-4 text-center text-muted small">Không tìm thấy kết quả phù hợp...</li>');
                                $liveResults.show();
                            }
                        }
                    });
                } else {
                    // Ẩn hộp kết quả nếu ô tìm kiếm trống
                    $liveResults.hide();
                }
            });

            // Tự động ẩn hộp kết quả khi người dùng click ra ngoài vùng tìm kiếm
            $(document).on('click', function (e) {
                if (!$(e.target).closest('.search-wrapper').length) {
                    $liveResults.hide();
                }
            });
        });
    </script>
}