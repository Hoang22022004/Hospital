@model Hospital.Models.TinTuc
@using System.Net
@{
    ViewData["Title"] = Model.TieuDe;
    var relatedPosts = ViewBag.RelatedPosts as IEnumerable<Hospital.Models.TinTuc>;
    var recentPosts = ViewBag.RecentPosts as IEnumerable<Hospital.Models.TinTuc>;
}

@section Styles {
    <link rel="stylesheet" href="~/css/news.css" asp-append-version="true" />
}

@* BREADCRUMB (THANH ĐIỀU HƯỚNG) *@
<div class="bg-light-blue py-3">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-muted">Trang chủ</a></li>
                <li class="breadcrumb-item"><a href="/TinTuc" class="text-decoration-none text-muted">Tin tức</a></li>
                <li class="breadcrumb-item active text-navy fw-bold" aria-current="page">@Model.DanhMuc</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container py-5">
    <div class="row g-5">
        @* CỘT NỘI DUNG CHÍNH (8 CỘT) *@
        <div class="col-lg-8">
            <article class="news-detail-wrapper shadow-sm">
                @* 1. Thông tin tiêu đề *@
                <div class="mb-4">
                    <span class="badge bg-teal-soft text-teal px-3 py-2 rounded-pill mb-2">@Model.DanhMuc</span>
                    <h1 class="display-6 fw-bold text-navy Montserrat mb-3">@Model.TieuDe</h1>

                    <div class="d-flex flex-wrap align-items-center text-muted small border-bottom pb-4">
                        <div class="me-4 mb-2"><i class="bi bi-person-circle me-2 text-teal"></i>Tác giả: <span class="text-dark fw-bold">@Model.TacGia</span></div>
                        <div class="me-4 mb-2"><i class="bi bi-calendar3 me-2 text-teal"></i>@Model.NgayDang.ToString("dd/MM/yyyy")</div>
                        <div class="mb-2"><i class="bi bi-eye me-2 text-teal"></i>1.234 lượt xem</div>
                    </div>
                </div>

                @* 2. Ảnh bài viết *@
                @if (!string.IsNullOrEmpty(Model.HinhAnhUrl))
                {
                    <div class="featured-image-container mb-5">
                        <img src="@Model.HinhAnhUrl" alt="@Model.TieuDe" class="img-fluid rounded-4 w-100 shadow-sm">
                    </div>
                }

                @* 3. Nội dung chi tiết (Rich Text) *@
                <div class="news-content-body rich-text lh-lg">
                    @Html.Raw(Model.NoiDung)
                </div>

                @* 4. Social Share *@
                <div class="d-flex justify-content-between align-items-center border-top border-bottom py-4 my-5">
                    <div class="share-buttons">
                        <span class="fw-bold text-navy me-3">Chia sẻ bài viết:</span>
                        <a href="#" class="btn btn-sm btn-outline-primary rounded-circle me-2"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="btn btn-sm btn-outline-info rounded-circle me-2"><i class="bi bi-twitter"></i></a>
                        <a href="#" class="btn btn-sm btn-outline-danger rounded-circle"><i class="bi bi-envelope"></i></a>
                    </div>
                </div>
            </article>

            @* 5. BÀI VIẾT LIÊN QUAN *@
            @if (relatedPosts != null && relatedPosts.Any())
            {
                <div class="related-posts-section mt-5">
                    <h4 class="fw-bold text-navy Montserrat mb-4 d-flex align-items-center">
                        <span class="bg-teal p-1 me-2 rounded"></span> BÀI VIẾT LIÊN QUAN
                    </h4>
                    <div class="row g-4">
                        @foreach (var post in relatedPosts)
                        {
                            <div class="col-md-4">
                                <div class="related-card border-0 shadow-sm rounded-4 overflow-hidden h-100 bg-white">
                                    <img src="@post.HinhAnhUrl" class="w-100 object-fit-cover" style="height: 160px;">
                                    <div class="p-3">
                                        <h6 class="fw-bold text-navy line-clamp-2 mb-2">@post.TieuDe</h6>
                                        <a href="/TinTuc/Details/@post.Id" class="small text-teal text-decoration-none fw-bold">Đọc tiếp <i class="bi bi-arrow-right"></i></a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        @* SIDEBAR (4 CỘT) - THEO MẪU ẢNH *@
        <div class="col-lg-4">
            <aside class="sticky-top" style="top: 100px;">

                @* KHỐI 1: GIỜ LÀM VIỆC *@
                <div class="sidebar-box bg-navy text-white p-4 rounded-4 mb-4 shadow-sm">
                    <div class="d-flex align-items-start">
                        <i class="bi bi-clock-history fs-1 me-3 text-teal"></i>
                        <div>
                            <h5 class="fw-bold mb-3 border-bottom border-white border-opacity-25 pb-2">Giờ làm việc</h5>
                            <div class="schedule-item mb-3">
                                <p class="mb-1 fw-bold text-teal">Thứ 2 - Thứ sáu:</p>
                                <p class="mb-0 small fst-italic">11h30 - 13h30</p>
                                <p class="mb-0 small fst-italic">17h00 - 20h00</p>
                            </div>
                            <div class="schedule-item">
                                <p class="mb-1 fw-bold text-teal">Thứ 7 - Chủ nhật:</p>
                                <p class="mb-0 small fst-italic">11h30 - 18h00</p>
                            </div>
                        </div>
                    </div>
                </div>

                @* KHỐI 2: TƯ VẤN MIỄN PHÍ *@
                <div class="sidebar-box bg-orange text-white p-4 rounded-4 mb-4 shadow-sm">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-telephone-outbound-fill fs-1 me-3"></i>
                        <div>
                            <h6 class="fw-bold mb-1 text-uppercase ls-1">TƯ VẤN MIỄN PHÍ</h6>
                            <h4 class="fw-bold mb-0">090 528 04 82</h4>
                        </div>
                    </div>
                </div>

                @* KHỐI 3: CAM KẾT *@
                <div class="sidebar-box bg-navy text-white p-4 rounded-4 mb-5 shadow-sm">
                    <ul class="list-unstyled mb-0 commitment-list">
                        <li><i class="bi bi-check-lg me-2 text-teal fw-bold"></i> 100% Bác sĩ thăm khám, trị liệu</li>
                        <li><i class="bi bi-check-lg me-2 text-teal fw-bold"></i> Quy trình điều trị Chuẩn Y Khoa</li>
                        <li><i class="bi bi-check-lg me-2 text-teal fw-bold"></i> Cơ sở vật chất hiện đại</li>
                        <li><i class="bi bi-check-lg me-2 text-teal fw-bold"></i> Sở hữu nhà thuốc da liễu đạt chuẩn GPP</li>
                        <li><i class="bi bi-check-lg me-2 text-teal fw-bold"></i> Sở Y tế cấp phép hoạt động</li>
                        <li><i class="bi bi-check-lg me-2 text-teal fw-bold"></i> Trung thực, uy tín lâu năm</li>
                    </ul>
                </div>

                @* KHỐI 4: BÀI VIẾT MỚI NHẤT *@
                <div class="sidebar-widget">
                    <h5 class="fw-bold text-navy border-start border-4 border-teal ps-3 mb-4">BÀI VIẾT MỚI NHẤT</h5>
                    @if (recentPosts != null)
                    {
                        foreach (var post in recentPosts)
                        {
                            <a href="/TinTuc/Details/@post.Id" class="d-flex align-items-center mb-3 text-decoration-none group">
                                <img src="@post.HinhAnhUrl" class="rounded-3 me-3 shadow-sm" style="width: 75px; height: 75px; object-fit: cover;" onerror="this.src='/images/no-image.png';">
                                <div>
                                    <h6 class="text-navy fw-bold small mb-1 group-hover-teal line-clamp-2">
                                        @post.TieuDe
                                    </h6>
                                    <span class="text-muted" style="font-size: 0.75rem;"><i class="bi bi-calendar-event me-1"></i>@post.NgayDang.ToString("dd/MM/yyyy")</span>
                                </div>
                            </a>
                        }
                    }
                </div>
            </aside>
        </div>
    </div>
</div>