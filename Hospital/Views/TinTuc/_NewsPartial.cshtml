@model IEnumerable<Hospital.Models.TinTuc>
@using System.Net

<section class="news-section py-5 overflow-hidden">
    <div class="container">
        @* 1. TIÊU ĐỀ SECTION - Giữ nguyên code của bạn *@
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end mb-5 text-center text-md-start">
            <div>
                <span class="text-teal fw-bold text-uppercase ls-2 small">Cẩm nang làm đẹp</span>
                <h2 class="fw-bold text-navy Montserrat mt-2 mb-0">TIN TỨC & KIẾN THỨC</h2>
                <div class="title-line-news mx-auto mx-md-0"></div>
            </div>
            <div class="mt-4 mt-md-0">
                <a asp-controller="TinTuc" asp-action="Index" class="btn btn-outline-navy rounded-pill px-4 shadow-sm">
                    XEM TẤT CẢ <i class="bi bi-arrow-right ms-2"></i>
                </a>
            </div>
        </div>

        @* 2. DANH SÁCH BÀI VIẾT - Chuyển sang cấu trúc Swiper để lướt *@
        <div class="swiper newsSwiper pb-5">
            <div class="swiper-wrapper">
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <div class="swiper-slide h-auto">
                            <div class="news-card h-100 shadow-sm border-0">

                                @* Khung ảnh - Giữ nguyên *@
                                <div class="news-img-wrapper">
                                    @if (!string.IsNullOrEmpty(item.DanhMuc))
                                    {
                                        <span class="news-badge">@item.DanhMuc</span>
                                    }

                                    <img src="@(string.IsNullOrEmpty(item.HinhAnhUrl) ? "/images/no-image.png" : item.HinhAnhUrl)"
                                         alt="@item.TieuDe"
                                         class="news-img"
                                         onerror="this.src='/images/no-image.png';">

                                    <div class="news-overlay">
                                        <a asp-controller="TinTuc" asp-action="Details" asp-route-id="@item.Id"
                                           class="btn btn-light btn-sm rounded-pill px-4 fw-bold shadow">
                                            ĐỌC BÀI VIẾT
                                        </a>
                                    </div>
                                </div>

                                @* Nội dung chữ *@
                                <div class="news-body p-4">
                                    <div class="news-meta mb-2 d-flex align-items-center">
                                        <small class="me-3 text-muted">
                                            <i class="bi bi-calendar3 me-1 text-teal"></i> @item.NgayDang.ToString("dd/MM/yyyy")
                                        </small>
                                        <small class="text-muted text-truncate">
                                            <i class="bi bi-person me-1 text-teal"></i> @item.TacGia
                                        </small>
                                    </div>

                                    <h5 class="news-title mb-3">
                                        <a asp-controller="TinTuc" asp-action="Details" asp-route-id="@item.Id"
                                           class="text-decoration-none text-navy hp-hover-teal">
                                            @item.TieuDe
                                        </a>
                                    </h5>

                                    <p class="news-excerpt text-muted mb-0 small">
                                        @{
                                            // Bước 1: Loại bỏ thẻ HTML thô
                                            var plainText = System.Text.RegularExpressions.Regex.Replace(item.NoiDung ?? "", "<.*?>", string.Empty);
                                            // Bước 2: GIẢI MÃ LỖI CHỮ (Biến &aacute;, &ograve;... thành chữ tiếng Việt chuẩn)
                                            var decodedText = WebUtility.HtmlDecode(plainText);
                                            // Bước 3: Cắt chuỗi
                                            var summary = decodedText.Length > 95 ? decodedText.Substring(0, 92) + "..." : decodedText;
                                        }
                                        @summary
                                    </p>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
            @* Dấu chấm phân trang *@
            <div class="swiper-pagination news-pagination-pill"></div>
        </div>
    </div>
</section>