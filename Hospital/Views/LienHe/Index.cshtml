@{
    ViewData["Title"] = "Liên hệ Hello Paris";
}

@section Styles {
    <style>
        .contact-section {
            background-color: #f8fafc;
            padding: 60px 0;
        }

        /* --- SỬA LỖI SỐ 2: Bổ sung màu nền cho nút bấm --- */
        .btn-teal {
            background-color: #45c3d2 !important;
            color: #ffffff !important;
            border: none;
            transition: all 0.3s ease;
        }

            .btn-teal:hover {
                background-color: #38a8b6 !important; /* Đậm hơn một chút khi di chuột */
                box-shadow: 0 5px 15px rgba(69, 195, 210, 0.4);
                transform: translateY(-2px);
            }

        /* Box thông tin bên phải */
        .info-box-navy {
            background-color: #002d5b;
            color: white;
            border-radius: 15px;
        }

        .info-box-orange {
            background-color: #e67e22;
            color: white;
            border-radius: 15px;
            transition: 0.3s;
        }

            .info-box-orange:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 20px rgba(230, 126, 34, 0.3);
            }

        /* Bản đồ */
        .map-container {
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        }

        /* Form hiện đại (Floating Labels) */
        .modern-form .form-control {
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            padding: 1rem 0.75rem;
            height: auto;
            background-color: #f8fafc;
        }

            .modern-form .form-control:focus {
                border-color: #45c3d2;
                box-shadow: 0 0 0 0.25rem rgba(69, 195, 210, 0.25);
                background-color: #fff;
            }

        .modern-form label {
            color: #64748b;
            font-weight: 500;
        }

        /* List cam kết */
        .commitment-list li {
            padding: 12px 0;
            border-bottom: 1px solid #e2e8f0;
            display: flex;
            align-items: center;
            font-weight: 600;
            color: #002d5b;
        }

            .commitment-list li:last-child {
                border-bottom: none;
            }

        .commitment-list i {
            color: #45c3d2;
            font-size: 1.2rem;
            margin-right: 12px;
        }
    </style>
}

<div class="contact-section">
    <div class="container">
        @* Breadcrumb *@
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Trang chủ</a></li>
                <li class="breadcrumb-item active">Liên hệ</li>
            </ol>
        </nav>

        <div class="row g-5">
            @* ================= CỘT TRÁI: THÔNG TIN, MAP & FORM ================= *@
            <div class="col-lg-8">
                <h2 class="fw-bold text-navy mb-4">PHÒNG KHÁM DA LIỄU HELLO PARIS</h2>

                <div class="d-flex flex-column gap-2 mb-4 text-muted">
                    <span><i class="bi bi-geo-alt-fill text-teal me-2"></i> <strong>Cơ sở:</strong> 52 Chế Lan Viên - Trường An - Thành phố Huế</span>
                    <span><i class="bi bi-telephone-fill text-teal me-2"></i> <strong>Hotline:</strong> 090.528.04.82</span>
                    <span><i class="bi bi-facebook text-teal me-2"></i> <strong>Facebook:</strong> fb.com/dalieuhelloparis</span>
                </div>

                @* Bản đồ Google Maps *@
                <div class="map-container mb-5">
                    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3826.41725515259!2d107.57688531536098!3d16.45439778864455!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3141a147d33309a1%3A0x6b77227d81232873!2zNTIgQ2jhur8gTGFuIFZpw6puLCBUcsaw4budbmcgQW4sIFRow6BuaCBwaOG7kSBIdeG6vywgVGjhu6thIFRoacOqbiBIdeG6vywgVmnhu4d0IE5hbQ!5e0!3m2!1svi!2s!4v1700000000000!5m2!1svi!2s"
                            width="100%" height="350" style="border:0;" allowfullscreen="" loading="lazy"></iframe>
                </div>

                @* Form Liên Hệ Hiện Đại *@
                <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5">
                    <h3 class="fw-bold text-navy mb-2 text-center text-md-start">GỬI THÔNG TIN CHO CHÚNG TÔI</h3>

                    <p class="text-muted mb-4 text-center text-md-start">
                        Hãy để lại thông tin và tình trạng của bạn. Đội ngũ bác sĩ chuyên khoa sẽ liên hệ tư vấn và sắp xếp lịch hẹn phù hợp nhất.
                    </p>

                    <form asp-action="SubmitForm" method="post" class="modern-form">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input type="text" class="form-control" id="HoTen" name="HoTen" placeholder="Họ và tên" required>
                                    <label for="HoTen">Họ và tên *</label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input type="tel" class="form-control" id="SoDienThoai" name="SoDienThoai" placeholder="Số điện thoại" required>
                                    <label for="SoDienThoai">Số điện thoại *</label>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="form-floating">
                                    <input type="email" class="form-control" id="Email" name="Email" placeholder="Email">
                                    <label for="Email">Địa chỉ Email (Không bắt buộc)</label>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="form-floating">
                                    <textarea class="form-control" id="NoiDung" name="NoiDung" placeholder="Nội dung cần tư vấn" style="height: 150px" required></textarea>
                                    <label for="NoiDung">Tình trạng da hoặc câu hỏi của bạn *</label>
                                </div>
                            </div>
                            <div class="col-12 mt-4">
                                <button type="submit" class="btn btn-teal w-100 py-3 rounded-pill fw-bold fs-5 shadow-sm">
                                    <i class="bi bi-send me-2"></i> GỬI YÊU CẦU TƯ VẤN
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            @* ================= CỘT PHẢI: SIDEBAR TIỆN ÍCH ================= *@
            <div class="col-lg-4">
                @* --- SỬA LỖI SỐ 1: THÊM Z-INDEX: 99 ĐỂ NẰM DƯỚI NAVBAR --- *@
                <div class="sticky-top" style="top: 120px; z-index: 99;">

                    @* Box 1: Giờ làm việc *@
                    <div class="info-box-navy p-4 mb-4 shadow-sm">
                        <div class="d-flex align-items-center mb-3">
                            <i class="bi bi-clock-history fs-2 text-teal me-3"></i>
                            <h5 class="fw-bold mb-0 text-uppercase">Giờ làm việc</h5>
                        </div>
                        <ul class="list-unstyled mb-0 ms-1 opacity-75 line-height-lg">
                            <li class="mb-2"><strong>Thứ 2 - Thứ 6:</strong><br> 7h30 - 11h30 | 17h00 - 20h00</li>
                            <li><strong>Thứ 7 - Chủ nhật:</strong><br> 7h30 - 18h00</li>
                        </ul>
                    </div>

                    @* Box 2: Hotline *@
                    <div class="info-box-orange p-4 mb-4 shadow-sm d-flex align-items-center">
                        <i class="bi bi-telephone-inbound-fill fs-1 me-3"></i>
                        <div>
                            <div class="text-uppercase fw-bold small opacity-75">Tư vấn miễn phí</div>
                            <div class="fs-4 fw-bold">090.528.04.82</div>
                        </div>
                    </div>

                    @* Box 3: Lời cam kết *@
                    <div class="card border-primary-subtle shadow-sm rounded-4 mb-4">
                        <div class="card-body p-4">
                            <ul class="list-unstyled commitment-list mb-0 small">
                                <li><i class="bi bi-check-circle-fill"></i> 100% Bác sĩ thăm khám, trị liệu</li>
                                <li><i class="bi bi-check-circle-fill"></i> Quy trình điều trị Chuẩn Y Khoa</li>
                                <li><i class="bi bi-check-circle-fill"></i> Cơ sở vật chất hiện đại</li>
                                <li><i class="bi bi-check-circle-fill"></i> Nhà thuốc da liễu đạt chuẩn GPP</li>
                                <li><i class="bi bi-check-circle-fill"></i> Có giấy phép hoạt động hợp pháp</li>
                            </ul>
                        </div>
                    </div>

                    @* Box 4: Ảnh Bác sĩ tư vấn *@
                    <div class="mb-4 rounded-4 overflow-hidden shadow-sm border">
                        <img src="~/images/Layout/bac-si-tu-van.png" alt="Bác sĩ tư vấn" class="img-fluid w-100" onerror="this.src='/images/no-image.png';">
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>