@using Microsoft.AspNetCore.Identity
@using Hospital.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hello Paris Việt Pháp</title>

    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&family=Playfair+Display:wght@700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

    <link rel="stylesheet" href="~/css/main_layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/why-choose.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)

    <style>
        /* CSS hỗ trợ hiệu ứng cho Navbar */
        .transition-all {
            transition: all 0.3s ease;
        }

        .hp-hover-teal:hover {
            color: #45c3d2 !important;
            background-color: rgba(69, 195, 210, 0.05);
        }

        .bg-teal-soft {
            background-color: rgba(69, 195, 210, 0.1) !important;
        }

        /* THÊM MỚI: Hiệu ứng Dropdown Hover cho màn hình máy tính */
        @@media (min-width: 992px) {
            .nav-item.dropdown:hover .dropdown-menu

        {
            display: block;
            margin-top: 0;
        }

        }
    </style>
</head>
<body>

    @* --- TOP BAR --- *@
    <div class="hp-topbar py-2 d-none d-lg-block border-bottom bg-light">
        <div class="container d-flex justify-content-between align-items-center">
            <div class="topbar-info">
                <span class="me-4 small"><i class="bi bi-geo-alt-fill text-primary me-1"></i> 52 Chế Lan Viên, TP Huế</span>
                <span class="small"><i class="bi bi-telephone-outbound-fill text-primary me-1"></i> Hotline: 090 528 04 82</span>
            </div>
            <div class="topbar-social">
                <a asp-controller="TraCuu" asp-action="Index" class="btn-tra-cuu me-3 text-decoration-none small fw-bold">TRA CỨU KẾT QUẢ</a>
                <a href="https://www.facebook.com/ParisClinicHue" target="_blank" class="text-primary"><i class="bi bi-facebook fs-5"></i></a>
            </div>
        </div>
    </div>

    @* --- HEADER / NAVBAR --- *@
    <header class="sticky-top shadow-sm">
        <nav class="navbar navbar-expand-lg py-2 bg-white">
            <div class="container-fluid px-md-5">
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/images/layout/logo.png" alt="Hello Paris" class="logo-img" style="height: 50px;">
                    <div class="ms-2 brand-container">
                        <span class="brand-name fw-bold text-navy" style="letter-spacing: 1px;">HELLO PARIS</span>
                        <small class="brand-sub d-block text-muted" style="font-size: 0.65rem;">VIỆT PHÁP CLINIC</small>
                    </div>
                </a>

                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    @* DANH SÁCH MENU ĐÃ CẬP NHẬT GOM NHÓM TIN TỨC & BỆNH LÝ *@
                    <ul class="navbar-nav ms-auto align-items-center gap-1">

                        <li class="nav-item">
                            <a class="nav-link px-3 rounded-pill fw-bold small transition-all @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active bg-teal-soft text-teal" : "text-navy hp-hover-teal")" asp-controller="Home" asp-action="Index">TRANG CHỦ</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link px-3 rounded-pill fw-bold small transition-all @(ViewContext.RouteData.Values["Controller"]?.ToString() == "BacSi" ? "active bg-teal-soft text-teal" : "text-navy hp-hover-teal")" asp-controller="BacSi" asp-action="Index">BÁC SĨ</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link px-3 rounded-pill fw-bold small transition-all @(ViewContext.RouteData.Values["Controller"]?.ToString() == "DichVu" ? "active bg-teal-soft text-teal" : "text-navy hp-hover-teal")" asp-controller="DichVu" asp-action="Index">DỊCH VỤ</a>
                        </li>

                        @* Menu Dropdown Gom Nhóm Tin Tức & Bệnh Lý *@
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle px-3 rounded-pill fw-bold small transition-all @(ViewContext.RouteData.Values["Controller"]?.ToString() == "TinTuc" || ViewContext.RouteData.Values["Controller"]?.ToString() == "BenhLy" ? "active bg-teal-soft text-teal" : "text-navy hp-hover-teal")"
                               href="#" id="navbarTinTuc" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                KIẾN THỨC
                            </a>
                            <ul class="dropdown-menu border-0 shadow-sm rounded-4 mt-2 animate__animated animate__fadeInUp animate__faster p-2" aria-labelledby="navbarTinTuc">
                                <li>
                                    <a class="dropdown-item py-2 fw-bold small text-navy rounded-3 mb-1" asp-controller="BenhLy" asp-action="Index">
                                        <i class="bi bi-clipboard2-pulse me-2 text-teal"></i>Tra cứu Bệnh lý
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item py-2 fw-bold small text-navy rounded-3" asp-controller="TinTuc" asp-action="Index">
                                        <i class="bi bi-newspaper me-2 text-teal"></i>Tin tức & Sự kiện
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <li class="nav-item ms-lg-1">
                            <a class="nav-link px-3 rounded-pill fw-bold small transition-all @(ViewContext.RouteData.Values["Controller"]?.ToString() == "LienHe" ? "active bg-teal-soft text-teal" : "text-navy hp-hover-teal")" asp-controller="LienHe" asp-action="Index">LIÊN HỆ</a>
                        </li>

                        @if (SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item dropdown ms-lg-3">
                                <a class="nav-link hp-user-pill d-flex align-items-center px-3 py-1"
                                   href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false" style="border-radius: 50px; background: rgba(69, 195, 210, 0.1); border: 1px solid rgba(69, 195, 210, 0.2);">
                                    <div class="hp-avatar-mini me-2 d-flex align-items-center justify-content-center bg-primary text-white rounded-circle" style="width: 30px; height: 30px;">
                                        <i class="bi bi-person-fill"></i>
                                    </div>
                                    <div class="hp-user-meta d-none d-xl-block">
                                        <span class="d-block fw-bold text-navy" style="font-size: 0.75rem; line-height: 1;">CHÀO, @(User.Identity?.Name?.Split('@')[0].ToUpper())</span>
                                        <span class="hp-role-text text-primary fw-bold" style="font-size: 0.55rem; letter-spacing: 0.5px;">
                                            @if (User.IsInRole("Admin"))
                                            {
                                                <text>QUẢN TRỊ VIÊN</text>
                                            }
                                            else if (User.IsInRole("Doctor"))
                                            {
                                                <text>BÁC SĨ</text>
                                            }
                                            else if (User.IsInRole("Receptionist"))
                                            {
                                                <text>LỄ TÂN</text>
                                            }
                                            else if (User.IsInRole("Customer"))
                                            {
                                                <text>KHÁCH HÀNG</text>
                                            }
                                            else
                                            {
                                                <text>CHƯA CÓ TÀI KHOẢN</text>
                                            }
                                        </span>
                                    </div>
                                    <i class="bi bi-chevron-down ms-2 opacity-50" style="font-size: 0.7rem;"></i>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 rounded-4 p-2 mt-3 animate__animated animate__fadeInUp animate__faster">
                                    <li class="p-3 mb-1 bg-light rounded-3">
                                        <p class="mb-0 small text-muted">Tài khoản:</p>
                                        <p class="mb-0 fw-bold text-navy text-truncate">@User.Identity?.Name</p>
                                    </li>
                                    <li><hr class="dropdown-divider opacity-50"></li>
                                    <li><a class="dropdown-item rounded-3 py-2 small" asp-area="Identity" asp-page="/Account/Manage/Index"><i class="bi bi-person-circle me-2"></i>Hồ sơ cá nhân</a></li>
                                    @if (User.IsInRole("Admin") || User.IsInRole("Doctor"))
                                    {
                                        <li><a class="dropdown-item rounded-3 py-2 small" asp-area="Admin" asp-controller="Home" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i>Trang quản trị</a></li>
                                    }
                                    <li><hr class="dropdown-divider opacity-50"></li>
                                    <li>
                                        <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                                            <button type="submit" class="dropdown-item rounded-3 py-2 small text-danger fw-bold"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item ms-lg-2"><a class="nav-link btn-login px-3 fw-bold small" asp-area="Identity" asp-page="/Account/Login">ĐĂNG NHẬP</a></li>
                        }

                        <li class="nav-item ms-lg-3">
                            <a asp-controller="DatLich" asp-action="Index" class="btn btn-book text-uppercase shadow-sm fw-bold px-4" style="background-color: #45c3d2; color: white; border-radius: 50px;">
                                <i class="bi bi-calendar2-plus-fill me-1"></i> ĐẶT LỊCH NGAY
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    @* --- MAIN CONTENT --- *@
    <main role="main">
        @RenderBody()
    </main>

    @* --- FOOTER --- *@
    <footer class="hp-footer mt-5 pb-3 bg-light border-top">
        <div class="container mb-5 pt-5">
            <div class="row g-5">
                <div class="col-lg-4">
                    <div class="brand-container mb-3">
                        <span class="brand-name fw-bold" style="font-size: 1.8rem; color: #002d5b;">HELLO PARIS</span>
                        <span class="brand-sub d-block text-muted">Healthy skin, beautiful you</span>
                    </div>
                    <div class="legal-box shadow-sm p-3 bg-white rounded-4 border-0">
                        <h6 class="fw-bold mb-3 border-bottom pb-2" style="font-size: 0.8rem;">THÔNG TIN PHÁP LÝ</h6>
                        <p class="mb-1 small">GPHĐ: Đã được Sở Y Tế cấp phép</p>
                        <p class="mb-1 small">Số ĐKKD: 031613561</p>
                        <p class="mb-0 small text-muted">Ngày cấp: 27/02/2020 (Sở KH&ĐT Huế)</p>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <h6 class="footer-heading fw-bold text-navy mb-4">Giờ làm việc</h6>
                    <div class="small text-muted mb-3 border-bottom pb-2">
                        <strong>Thứ 2 - Thứ 6:</strong> 11:30 - 20:00
                    </div>
                    <div class="small text-muted">
                        <strong>Thứ 7 - Chủ Nhật:</strong> 11:30 - 18:00
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <h6 class="footer-heading fw-bold text-navy mb-4">Dịch vụ chính</h6>
                    <nav class="footer-links list-unstyled">
                        <li><a href="#" class="text-muted text-decoration-none d-block mb-2 small">Trị mụn y khoa Bio Light</a></li>
                        <li><a href="#" class="text-muted text-decoration-none d-block mb-2 small">Cấy sẹo Meso scar</a></li>
                        <li><a href="#" class="text-muted text-decoration-none d-block mb-2 small">Trị nám Melas Picostar</a></li>
                        <li><a href="#" class="text-muted text-decoration-none d-block mb-2 small">Khám bệnh lý da liễu</a></li>
                    </nav>
                </div>
                <div class="col-lg-2 col-md-6">
                    <h6 class="footer-heading fw-bold text-navy mb-4">Liên hệ</h6>
                    <p class="small text-muted mb-4"><i class="bi bi-geo-alt-fill text-primary"></i> 52 Chế Lan Viên, Huế</p>
                    <img src="~/images/Layout/BCT.png" alt="Bộ Công Thương" class="bct-img img-fluid" style="max-height: 50px;">
                </div>
            </div>
        </div>
        <div class="text-center small text-muted pt-3 border-top border-secondary border-opacity-10">
            © @DateTime.Now.Year Hello Paris - Phòng khám Da liễu Việt Pháp.
        </div>
    </footer>

    @* --- SCRIPTS ĐÃ SẮP XẾP LẠI --- *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @* Phải load thư viện Swiper TRƯỚC khi chạy script *@
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

    @* Render Scripts từ các View con (như Index.cshtml) *@
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        // Chỉ khởi tạo 1 lần duy nhất khi HTML đã tải xong
        document.addEventListener("DOMContentLoaded", function () {
            // Kiểm tra xem trên trang có phần tử nào dùng class whyChooseSwiper không thì mới chạy
            if (document.querySelector('.whyChooseSwiper')) {
                var swiper = new Swiper(".whyChooseSwiper", {
                    loop: true,
                    speed: 1000,
                    autoplay: { delay: 4000, disableOnInteraction: false },
                    pagination: { el: ".swiper-pagination", clickable: true },
                    navigation: {
                        nextEl: ".swiper-button-next",
                        prevEl: ".swiper-button-prev",
                    },
                    effect: "fade",
                    fadeEffect: { crossFade: true }
                });
            }
        });
    </script>
</body>
</html>